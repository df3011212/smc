        if na(resultBox)
            resultBox := box.new(left = leftBar, top = topValue, right = rightBar, bottom = bottomValue, xloc = xloc.bar_index, extend = extend.none, border_color = borderColor, border_width = borderWidth, bgcolor = fillColor, text = zoneText, text_color = color.white, text_size = size.tiny, text_halign = text.align_right, text_valign = textVerticalAlign)
        else
            box.set_left(resultBox, leftBar)
            box.set_right(resultBox, rightBar)
            box.set_top(resultBox, topValue)
