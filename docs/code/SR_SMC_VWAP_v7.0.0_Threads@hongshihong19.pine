// 步驟 6 掛單區中間覆蓋層：置中顯示文字，透明度可為 0%，並由後續建立的步驟 6 線與標籤覆蓋於上方。
f_syncStep6OrderOverlayBox(box currentBox, bool visible, int leftBar, int rightBar, float zoneTop, float zoneBottom, string zoneText, color borderColor, color fillColor, int borderWidth) =>
    box resultBox = currentBox
    if visible and not na(zoneTop) and not na(zoneBottom)
        float topValue = math.max(zoneTop, zoneBottom)
        float bottomValue = math.min(zoneTop, zoneBottom)
        if na(resultBox)
            resultBox := box.new(left = leftBar, top = topValue, right = rightBar, bottom = bottomValue, xloc = xloc.bar_index, extend = extend.none, border_color = borderColor, border_width = borderWidth, bgcolor = fillColor, text = zoneText, text_color = color.white, text_size = size.normal, text_halign = text.align_center, text_valign = text.align_center)
        else
            box.set_left(resultBox, leftBar)
            box.set_right(resultBox, rightBar)
            box.set_top(resultBox, topValue)
