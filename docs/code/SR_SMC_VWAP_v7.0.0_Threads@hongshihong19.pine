// ============================================================================
// ⌁SRSMC⌁ author=@hongshihong19 / Threads｜module=共用函式與基礎工具｜seal:ZDS76ED5U2TT
// 共用函式
// ============================================================================
// ╳04723EOSF7GR╳ 函數=f_trendShort｜原作 Threads(@hongshihong19)
f_trendShort(int trend) =>
    trend == 1 ? "多" : trend == -1 ? "空" : "待定"

f_structureEventText(int eventCode) =>
    eventCode == 2 ? "CHoCH↑ 結構轉多" : eventCode == 1 ? "BOS↑ 多方延續" : eventCode == -2 ? "CHoCH↓ 結構轉空" : eventCode == -1 ? "BOS↓ 空方延續" : "尚無已確認突破"

// 以下為面板與區域文字仍會使用的共用函式。
// 移除 HH／HL／LH／LL 與 BSL／SSL 圖面標記時不可刪除這些工具。
f_highStructureText(int highType) =>
    highType == 1 ? "HH 高點抬高" : highType == -1 ? "LH 高點降低" : "高點待確認"

f_lowStructureText(int lowType) =>
    lowType == 1 ? "HL 低點抬高" : lowType == -1 ? "LL 低點降低" : "低點待確認"

f_rangePositionText(int positionCode) =>
    positionCode == 1 ? "溢價區（區間上半部）" : positionCode == -1 ? "折價區（區間下半部）" : "均衡區（接近中線）"

f_rangePositionCode(float currentPrice, float swingHigh, float swingLow) =>
    float rangeTop = not na(swingHigh) and not na(swingLow) ? math.max(swingHigh, swingLow) : na
    float rangeBottom = not na(swingHigh) and not na(swingLow) ? math.min(swingHigh, swingLow) : na
    float rangeMiddle = not na(rangeTop) and not na(rangeBottom) ? (rangeTop + rangeBottom) / 2.0 : na
    float balanceBand = not na(rangeTop) and not na(rangeBottom) ? (rangeTop - rangeBottom) * 0.05 : na
    na(rangeMiddle) ? 0 : currentPrice > rangeMiddle + balanceBand ? 1 : currentPrice < rangeMiddle - balanceBand ? -1 : 0

f_marketPhaseCode(int trendState, int positionCode) =>
    trendState == 1 ? (positionCode == -1 ? 2 : 1) : trendState == -1 ? (positionCode == 1 ? -2 : -1) : 0

f_marketPhaseText(int phaseCode) =>
    phaseCode == 1 ? "多方推進／位於區間上半部" : phaseCode == 2 ? "多方回調／位於折價側" : phaseCode == -1 ? "空方推進／位於區間下半部" : phaseCode == -2 ? "空方反彈／位於溢價側" : "等待完整結構"

f_eventWithPrice(int eventCode, float eventPrice) =>
    f_structureEventText(eventCode) + (na(eventPrice) ? "" : " @ " + str.tostring(eventPrice, format.mintick))

f_structurePairText(int highType, int lowType) =>
    f_highStructureText(highType) + "｜" + f_lowStructureText(lowType)

f_tfRelationText(int mainTrend, int subTrend) =>
    mainTrend == 1 and subTrend == 1 ? "同向多方推進" : mainTrend == 1 and subTrend == -1 ? "4H 偏多｜1H 向下回調" : mainTrend == -1 and subTrend == -1 ? "同向空方推進" : mainTrend == -1 and subTrend == 1 ? "4H 偏空｜1H 向上反彈" : mainTrend == 0 ? "4H 主方向尚未確認" : "1H 結構尚未確認"

f_daily4hRelationText(int dailyTrend, int fourHourTrend) =>
    dailyTrend == 0 ? "日線尚未確認｜先看 4H 結構" : fourHourTrend == 0 ? "4H 尚未確認｜日線只作背景" : dailyTrend == fourHourTrend ? "日線與 4H 同向" : "日線與 4H 反向｜降低追價優先級"

f_breakLevelText(int trendState, float swingHigh, float swingLow) =>
    trendState == 1 ? (na(swingLow) ? "等待形成保護低點" : "多方失效觀察：收盤跌破 " + str.tostring(swingLow, format.mintick)) : trendState == -1 ? (na(swingHigh) ? "等待形成保護高點" : "空方失效觀察：收盤突破 " + str.tostring(swingHigh, format.mintick)) : not na(swingHigh) and not na(swingLow) ? "轉多看 " + str.tostring(swingHigh, format.mintick) + "｜轉空看 " + str.tostring(swingLow, format.mintick) : "等待結構高低點形成"

f_priceRangeText(float zoneTop, float zoneBottom) =>
    na(zoneTop) or na(zoneBottom) ? "尚未形成" : str.tostring(math.min(zoneTop, zoneBottom), format.mintick) + " ～ " + str.tostring(math.max(zoneTop, zoneBottom), format.mintick)

// 同價位結構事件去重：允許一個最小跳動點內的價格誤差。
f_sameMarkedPrice(float priceA, float priceB) =>
    not na(priceA) and not na(priceB) and math.abs(priceA - priceB) <= syminfo.mintick

// 依已鎖定的結構確認價回溯實際 Pivot K 棒。
// 多方 MSS 突破 Swing High，因此搜尋 high；空方 MSS 跌破 Swing Low，因此搜尋 low。
// 僅在既有 Pivot bar_index 遺失時使用，避免步驟 4 只剩右側標籤卻沒有水平線。
f_findRecentStructureBar(float targetPrice, bool searchHigh) =>
    int foundBar = na
    if not na(targetPrice)
        for offset = 1 to 499
            if math.abs((searchHigh ? high[offset] : low[offset]) - targetPrice) <= syminfo.mintick
                foundBar := bar_index - offset
                break
    foundBar


f_mssTooltip(bool isLong, float price, int sourceBar, int confirmBar, string stateText) =>
    "MSS｜市場結構轉換\n時間軸：15M\n方向：" + (isLong ? "多方" : "空方") + "\n確認價：" + str.tostring(price, format.mintick) + "\n結構來源 K 棒：" + str.tostring(sourceBar) + "\n確認 K 棒：" + (na(confirmBar) ? "尚未完成" : str.tostring(confirmBar)) + "\n狀態：" + stateText

f_eqTooltip(bool isHigh, float firstPrice, float secondPrice, float linePrice, float tolerance) =>
    (isHigh ? "EQH｜等高點流動性" : "EQL｜等低點流動性") + "\n時間軸：" + timeframe.period + "\n第一點：" + str.tostring(firstPrice, format.mintick) + "\n第二點：" + str.tostring(secondPrice, format.mintick) + "\n水平價：" + str.tostring(linePrice, format.mintick) + "\n容許誤差：" + str.tostring(tolerance, format.mintick)

f_structureBreakTooltip(string structureCode, float structurePrice, float triggerClose, float priorClose) =>
    structureCode + "｜時間軸：" + timeframe.period + "\n結構價：" + str.tostring(structurePrice, format.mintick) + "\n確認收盤：" + str.tostring(triggerClose, format.mintick) + "\n前收：" + str.tostring(priorClose, format.mintick)

f_reactionKStatus(int direction, string entryZone, float zoneTop, float zoneBottom, bool completed, bool touchEntryMode, float entryTriggerPrice) =>
    bool isLong = direction == 1
    string side = isLong ? "多單" : "空單"
    string zoneName = str.length(entryZone) > 0 ? "15M " + entryZone : isLong ? "15M 多方 OB／FVG" : "15M 空方 OB／FVG"
    string rangeText = not na(zoneTop) and not na(zoneBottom) ? f_priceRangeText(zoneTop, zoneBottom) : "區間尚未鎖定"
    string entryText = na(entryTriggerPrice) ? "建議進場價尚未取得" : "建議" + side + "進場價 " + str.tostring(entryTriggerPrice, format.mintick)
    completed ? "步驟 7 完成｜" + (touchEntryMode ? "盤中已觸碰 " : "反應 K 已確認｜") + zoneName + " " + rangeText + "\n" + entryText + "\n請設定持倉狀態為「" + side + "」並輸入實際成交價" : "步驟 6｜" + zoneName + " " + rangeText + "\n" + (touchEntryMode ? "等待盤中價格觸碰" : "等待 15M " + (isLong ? "多方" : "空方") + "反應 K 收盤確認")

f_buildCoachStepAlertMessage(int lastStage, int currentStage, int direction) =>
    currentStage > lastStage ? syminfo.ticker + "｜" + timeframe.period + "｜" + (direction == 1 ? "多單" : "空單") + "｜步驟 " + (currentStage - lastStage > 1 ? str.tostring(lastStage + 1) + "～" : "") + str.tostring(currentStage) + " 完成｜確認價格 " + str.tostring(close, format.mintick) : ""

// 專屬時間軸面板的圖上同步工具：只維持固定數量物件，不隨歷史 K 棒累積。
f_syncPanelLine(line currentLine, bool visible, int leftBar, int rightBar, float price, color guideColor, bool dashed, int width) =>
    line resultLine = currentLine
    if visible and not na(price)
        if na(resultLine)
            resultLine := line.new(leftBar, price, rightBar, price, xloc = xloc.bar_index, extend = extend.none, color = guideColor, style = dashed ? line.style_dashed : line.style_solid, width = width)
        else
            line.set_xy1(resultLine, leftBar, price)
            line.set_xy2(resultLine, rightBar, price)
            line.set_color(resultLine, guideColor)
            line.set_style(resultLine, dashed ? line.style_dashed : line.style_solid)
            line.set_width(resultLine, width)
    else if not na(resultLine)
        line.delete(resultLine)
        resultLine := na
    resultLine

f_syncPanelLabel(label currentLabel, bool visible, int labelBar, float price, string guideText, color guideColor) =>
    label resultLabel = currentLabel
    if visible and not na(price)
        if na(resultLabel)
            resultLabel := label.new(labelBar, price, guideText, xloc = xloc.bar_index, style = label.style_label_left, color = guideColor, textcolor = color.white, size = size.tiny)
        else
            label.set_xy(resultLabel, labelBar, price)
            label.set_text(resultLabel, guideText)
            label.set_color(resultLabel, guideColor)
            label.set_textcolor(resultLabel, color.white)
            label.set_size(resultLabel, size.tiny)
    else if not na(resultLabel)
        label.delete(resultLabel)
        resultLabel := na
    resultLabel

f_syncPanelBox(box currentBox, bool visible, int leftBar, int rightBar, float zoneTop, float zoneBottom, string zoneText, color borderColor, color fillColor) =>
    box resultBox = currentBox
    if visible and not na(zoneTop) and not na(zoneBottom)
        float topValue = math.max(zoneTop, zoneBottom)
        float bottomValue = math.min(zoneTop, zoneBottom)
        if na(resultBox)
            resultBox := box.new(left = leftBar, top = topValue, right = rightBar, bottom = bottomValue, xloc = xloc.bar_index, extend = extend.none, border_color = borderColor, border_width = 2, bgcolor = fillColor, text = zoneText, text_color = color.white, text_size = size.tiny, text_halign = text.align_right, text_valign = text.align_top)
        else
            box.set_left(resultBox, leftBar)
            box.set_right(resultBox, rightBar)
            box.set_top(resultBox, topValue)
            box.set_bottom(resultBox, bottomValue)
            box.set_border_color(resultBox, borderColor)
            box.set_bgcolor(resultBox, fillColor)
            box.set_text(resultBox, zoneText)
            box.set_text_color(resultBox, color.white)
            box.set_text_size(resultBox, size.tiny)
            box.set_text_halign(resultBox, text.align_right)
            box.set_text_valign(resultBox, text.align_top)
    else if not na(resultBox)
        box.delete(resultBox)
        resultBox := na
    resultBox

