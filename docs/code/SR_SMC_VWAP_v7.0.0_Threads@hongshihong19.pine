// ============================================================================
var array<box> resistanceZones = array.new<box>()
var array<box> supportZones = array.new<box>()
var array<box> bullOrderBlocks = array.new<box>()
var array<box> bearOrderBlocks = array.new<box>()
var array<box> bullFvgs = array.new<box>()
var array<box> bearFvgs = array.new<box>()
var array<box> noPriorityZones = array.new<box>()
var array<polyline> stepZoneOutlines = array.new<polyline>()
var array<box> stepZoneTextBoxes = array.new<box>()
var array<line> structureLines = array.new<line>()
var array<label> structureLabels = array.new<label>()
var array<line> mssLines = array.new<line>()
var array<label> mssLabels = array.new<label>()
var array<line> idmLines = array.new<line>()
var array<label> idmLabels = array.new<label>()
var array<line> eqhLines = array.new<line>()
var array<label> eqhLabels = array.new<label>()
var array<line> eqlLines = array.new<line>()
var array<label> eqlLabels = array.new<label>()

// 教練用 OB／FVG 狀態改由模組函式內的 var 保存，並以 tuple 回傳，降低 main body 長度。

// ============================================================================
// ◆SRSMC/P51ROMNH51KM◆ author-mark：Threads • @hongshihong19｜支撐阻力
// 支撐 / 阻力區
// Pivot 在右側指定根數後才確認，因此區域左端回推至真正 Pivot K 棒。
// 圖面只顯示區域色塊，不再繪製中心水平線。
// ============================================================================
float atrValue = ta.atr(srAtrLen)
f_processSrModule(float atrNow) =>
    float resistancePivot = ta.pivothigh(high, srPivotLen, srPivotLen)
    float supportPivot = ta.pivotlow(low, srPivotLen, srPivotLen)

    if useSRLogic and not na(resistancePivot)
        float pivotAtr = nz(atrNow[srPivotLen], syminfo.mintick * 10.0)
        float halfWidth = math.max(pivotAtr * srZoneAtr, syminfo.mintick * 2.0)
        float mergeDistance = halfWidth * mergeMultiplier
        int pivotBar = bar_index - srPivotLen
        int nearIndex = f_findNearBoxIndex(resistanceZones, resistancePivot, mergeDistance)
        if nearIndex >= 0
            f_mergeSrDrawing(resistanceZones, nearIndex, resistancePivot + halfWidth, resistancePivot - halfWidth, pivotBar, bar_index + srRightExtendBars)
            f_setSrZoneVisual(array.get(resistanceZones, nearIndex), showSR, resistanceColor, "阻力區")
        else
            box newResistance = box.new(left = pivotBar, top = resistancePivot + halfWidth, right = bar_index + srRightExtendBars, bottom = resistancePivot - halfWidth, xloc = xloc.bar_index, extend = extend.none, border_color = showSR ? color.new(resistanceColor, 45) : color.new(resistanceColor, 100), bgcolor = showSR ? color.new(resistanceColor, zoneTransparency) : color.new(resistanceColor, 100), text = showSR and showSrText ? "阻力區" : "", text_color = zoneTextColor, text_size = size.small, text_halign = text.align_left, text_valign = text.align_top)
            f_addBox(resistanceZones, newResistance, maxSRZones, suppressSameTypeZoneOverlap, sameTypeZoneOverlapPct * 0.01)

    if useSRLogic and not na(supportPivot)
        float pivotAtr = nz(atrNow[srPivotLen], syminfo.mintick * 10.0)
        float halfWidth = math.max(pivotAtr * srZoneAtr, syminfo.mintick * 2.0)
        float mergeDistance = halfWidth * mergeMultiplier
        int pivotBar = bar_index - srPivotLen
        int nearIndex = f_findNearBoxIndex(supportZones, supportPivot, mergeDistance)
        if nearIndex >= 0
            f_mergeSrDrawing(supportZones, nearIndex, supportPivot + halfWidth, supportPivot - halfWidth, pivotBar, bar_index + srRightExtendBars)
            f_setSrZoneVisual(array.get(supportZones, nearIndex), showSR, supportColor, "支撐區")
        else
            box newSupport = box.new(left = pivotBar, top = supportPivot + halfWidth, right = bar_index + srRightExtendBars, bottom = supportPivot - halfWidth, xloc = xloc.bar_index, extend = extend.none, border_color = showSR ? color.new(supportColor, 45) : color.new(supportColor, 100), bgcolor = showSR ? color.new(supportColor, zoneTransparency) : color.new(supportColor, 100), text = showSR and showSrText ? "支撐區" : "", text_color = zoneTextColor, text_size = size.small, text_halign = text.align_left, text_valign = text.align_top)
            f_addBox(supportZones, newSupport, maxSRZones, suppressSameTypeZoneOverlap, sameTypeZoneOverlapPct * 0.01)

    // 需超出區域 ATR 緩衝並連續收盤確認；有效突破後可轉為角色互換區。
    float srBreakBuffer = nz(atrNow, syminfo.mintick * 10.0) * srBreakBufferAtr
    int resistanceDeleteIndex = array.size(resistanceZones) - 1
    while resistanceDeleteIndex >= 0
        box currentResistance = array.get(resistanceZones, resistanceDeleteIndex)
        float zoneTop = box.get_top(currentResistance)
        float zoneBottom = box.get_bottom(currentResistance)
        bool resistanceBroken = close > zoneTop + srBreakBuffer and (srBreakConfirmBars == 1 or close[1] > zoneTop + nz(atrNow[1], atrNow) * srBreakBufferAtr) and (srBreakConfirmBars < 3 or close[2] > zoneTop + nz(atrNow[2], atrNow) * srBreakBufferAtr)
        if resistanceBroken
            if srEnableRoleFlip and useSRLogic
                float mid = (zoneTop + zoneBottom) / 2.0
                int sourceLeft = box.get_left(currentResistance)
                int nearFlip = f_findNearBoxIndex(supportZones, mid, math.max(srBreakBuffer, syminfo.mintick * 2.0))
                if nearFlip < 0
                    box flipSupport = box.new(left = sourceLeft, top = zoneTop, right = bar_index + srRightExtendBars, bottom = zoneBottom, xloc = xloc.bar_index, extend = extend.none, border_color = showSR ? color.new(supportColor, 45) : color.new(supportColor, 100), bgcolor = showSR ? color.new(supportColor, zoneTransparency) : color.new(supportColor, 100), text = showSR and showSrText ? "支撐區" : "", text_color = zoneTextColor, text_size = size.small, text_halign = text.align_left, text_valign = text.align_top)
                    f_addBox(supportZones, flipSupport, maxSRZones, suppressSameTypeZoneOverlap, sameTypeZoneOverlapPct * 0.01)
                else
                    f_mergeSrDrawing(supportZones, nearFlip, zoneTop, zoneBottom, sourceLeft, bar_index + srRightExtendBars)
                    f_setSrZoneVisual(array.get(supportZones, nearFlip), showSR, supportColor, "支撐區")
            box.delete(currentResistance)
            array.remove(resistanceZones, resistanceDeleteIndex)
        resistanceDeleteIndex -= 1

    int supportDeleteIndex = array.size(supportZones) - 1
    while supportDeleteIndex >= 0
        box currentSupport = array.get(supportZones, supportDeleteIndex)
        float zoneTop = box.get_top(currentSupport)
        float zoneBottom = box.get_bottom(currentSupport)
        bool supportBroken = close < zoneBottom - srBreakBuffer and (srBreakConfirmBars == 1 or close[1] < zoneBottom - nz(atrNow[1], atrNow) * srBreakBufferAtr) and (srBreakConfirmBars < 3 or close[2] < zoneBottom - nz(atrNow[2], atrNow) * srBreakBufferAtr)
        if supportBroken
            if srEnableRoleFlip and useSRLogic
                float mid = (zoneTop + zoneBottom) / 2.0
                int sourceLeft = box.get_left(currentSupport)
                int nearFlip = f_findNearBoxIndex(resistanceZones, mid, math.max(srBreakBuffer, syminfo.mintick * 2.0))
                if nearFlip < 0
                    box flipResistance = box.new(left = sourceLeft, top = zoneTop, right = bar_index + srRightExtendBars, bottom = zoneBottom, xloc = xloc.bar_index, extend = extend.none, border_color = showSR ? color.new(resistanceColor, 45) : color.new(resistanceColor, 100), bgcolor = showSR ? color.new(resistanceColor, zoneTransparency) : color.new(resistanceColor, 100), text = showSR and showSrText ? "阻力區" : "", text_color = zoneTextColor, text_size = size.small, text_halign = text.align_left, text_valign = text.align_top)
                    f_addBox(resistanceZones, flipResistance, maxSRZones, suppressSameTypeZoneOverlap, sameTypeZoneOverlapPct * 0.01)
                else
                    f_mergeSrDrawing(resistanceZones, nearFlip, zoneTop, zoneBottom, sourceLeft, bar_index + srRightExtendBars)
                    f_setSrZoneVisual(array.get(resistanceZones, nearFlip), showSR, resistanceColor, "阻力區")
            box.delete(currentSupport)
            array.remove(supportZones, supportDeleteIndex)
        supportDeleteIndex -= 1

    // 所有仍有效的支撐／阻力區域：左端保留原始 Pivot，右端同步到「最新 K 棒＋指定根數」。
    int srDisplayRightBar = bar_index + srRightExtendBars
    f_setBoxesRight(resistanceZones, srDisplayRightBar)
    f_setBoxesRight(supportZones, srDisplayRightBar)
    0


f_processSrModule(atrValue)

// ============================================================================
// ⌬HSH-LMAF0KR28JNV⌬ 著作識別｜author=@hongshihong19 / Threads｜模組：SMC 結構
// SMC 市場結構：Swing、BOS、CHoCH；HH／HL／LH／LL 與 BSL／SSL 不再繪圖，但底層 Pivot／Sweep 判斷保留。
// ============================================================================
f_processStructureModule() =>
    float structureHighPivot = ta.pivothigh(high, structureLen, structureLen)
    float structureLowPivot = ta.pivotlow(low, structureLen, structureLen)

    var float lastSwingHighState = na
    var float lastSwingLowState = na
    var int lastSwingHighBarState = na
    var int lastSwingLowBarState = na
    var float previousEqHighState = na
    var float previousEqLowState = na
    var int previousEqHighBarState = na
    var int previousEqLowBarState = na
    var bool swingHighBrokenState = false
    var bool swingLowBrokenState = false
    var bool swingHighSweptState = false
    var bool swingLowSweptState = false
    var int structureTrendState = 0

    float eqTolerance = math.max(nz(atrValue[structureLen], syminfo.mintick * 10.0) * eqToleranceAtr, syminfo.mintick)

    if not na(structureHighPivot)
        int currentHighBar = bar_index - structureLen
        if showEqLiquidity and not na(previousEqHighState) and not na(previousEqHighBarState) and math.abs(structureHighPivot - previousEqHighState) <= eqTolerance
            float eqhPrice = (structureHighPivot + previousEqHighState) * 0.5
            bool blockedByHigherPriority = f_hasStructureEventAtPrice(mssLines, eqhPrice) or f_hasStructureEventAtPrice(structureLines, eqhPrice)
            if not blockedByHigherPriority
                f_removeStructureEventAtPrice(idmLines, idmLabels, eqhPrice)
                string eqhTooltip = f_eqTooltip(true, previousEqHighState, structureHighPivot, eqhPrice, eqTolerance)
                f_addHorizontalStructureEvent(eqhLines, eqhLabels, previousEqHighBarState, currentHighBar, eqhPrice, "EQH", resistanceColor, eqhTooltip, maxEqhGroups)
        previousEqHighState := structureHighPivot
        previousEqHighBarState := currentHighBar
        lastSwingHighState := structureHighPivot
        lastSwingHighBarState := currentHighBar
        swingHighBrokenState := false
        swingHighSweptState := false

    if not na(structureLowPivot)
        int currentLowBar = bar_index - structureLen
        if showEqLiquidity and not na(previousEqLowState) and not na(previousEqLowBarState) and math.abs(structureLowPivot - previousEqLowState) <= eqTolerance
            float eqlPrice = (structureLowPivot + previousEqLowState) * 0.5
            bool blockedByHigherPriority = f_hasStructureEventAtPrice(mssLines, eqlPrice) or f_hasStructureEventAtPrice(structureLines, eqlPrice)
            if not blockedByHigherPriority
                f_removeStructureEventAtPrice(idmLines, idmLabels, eqlPrice)
                string eqlTooltip = f_eqTooltip(false, previousEqLowState, structureLowPivot, eqlPrice, eqTolerance)
                f_addHorizontalStructureEvent(eqlLines, eqlLabels, previousEqLowBarState, currentLowBar, eqlPrice, "EQL", supportColor, eqlTooltip, maxEqlGroups)
        previousEqLowState := structureLowPivot
        previousEqLowBarState := currentLowBar
        lastSwingLowState := structureLowPivot
        lastSwingLowBarState := currentLowBar
        swingLowBrokenState := false
        swingLowSweptState := false

    bool bullishBreak = barstate.isconfirmed and not na(lastSwingHighState) and not swingHighBrokenState and close > lastSwingHighState and close[1] <= lastSwingHighState
    bool bearishBreak = barstate.isconfirmed and not na(lastSwingLowState) and not swingLowBrokenState and close < lastSwingLowState and close[1] >= lastSwingLowState
    bool bullishChoch = bullishBreak and structureTrendState == -1
    bool bearishChoch = bearishBreak and structureTrendState == 1
    bool bullishBos = bullishBreak and structureTrendState != -1
    bool bearishBos = bearishBreak and structureTrendState != 1

    if bullishBreak
        bool blockedByMss = f_hasStructureEventAtPrice(mssLines, lastSwingHighState)
        if showStructure and not blockedByMss
            f_removeStructureEventAtPrice(eqhLines, eqhLabels, lastSwingHighState)
            f_removeStructureEventAtPrice(eqlLines, eqlLabels, lastSwingHighState)
            f_removeStructureEventAtPrice(idmLines, idmLabels, lastSwingHighState)
            string breakText = bullishChoch ? "CHoCH↑" : "BOS↑"
            string breakTooltip = f_structureBreakTooltip(breakText, lastSwingHighState, close, close[1])
            int breakLineRightBar = bar_index + structureBreakRightBars
            f_addHorizontalStructureEvent(structureLines, structureLabels, lastSwingHighBarState, breakLineRightBar, lastSwingHighState, breakText, bullishRoleColor, breakTooltip, maxBosChochGroups)
        structureTrendState := 1
        swingHighBrokenState := true

    if bearishBreak
        bool blockedByMss = f_hasStructureEventAtPrice(mssLines, lastSwingLowState)
        if showStructure and not blockedByMss
            f_removeStructureEventAtPrice(eqhLines, eqhLabels, lastSwingLowState)
            f_removeStructureEventAtPrice(eqlLines, eqlLabels, lastSwingLowState)
            f_removeStructureEventAtPrice(idmLines, idmLabels, lastSwingLowState)
            string breakText = bearishChoch ? "CHoCH↓" : "BOS↓"
            string breakTooltip = f_structureBreakTooltip(breakText, lastSwingLowState, close, close[1])
            int breakLineRightBar = bar_index + structureBreakRightBars
            f_addHorizontalStructureEvent(structureLines, structureLabels, lastSwingLowBarState, breakLineRightBar, lastSwingLowState, breakText, bearishRoleColor, breakTooltip, maxBosChochGroups)
        structureTrendState := -1
        swingLowBrokenState := true

    bool bearishSweep = barstate.isconfirmed and not na(lastSwingHighState) and not swingHighSweptState and not bullishBreak and high > lastSwingHighState and close < lastSwingHighState
    bool bullishSweep = barstate.isconfirmed and not na(lastSwingLowState) and not swingLowSweptState and not bearishBreak and low < lastSwingLowState and close > lastSwingLowState
    if bearishSweep
        swingHighSweptState := true
    if bullishSweep
        swingLowSweptState := true

    [structureHighPivot, structureLowPivot, lastSwingHighState, lastSwingLowState, lastSwingHighBarState, lastSwingLowBarState, swingHighBrokenState, swingLowBrokenState, structureTrendState, bullishBreak, bearishBreak, bullishChoch, bearishChoch, bullishBos, bearishBos, bearishSweep, bullishSweep]

f_processOrderBlockModule(bool bullishBreak, bool bearishBreak) =>
    var float bullTopState = na
    var float bullBottomState = na
    var int bullCreatedBarState = na
    var float bearTopState = na
    var float bearBottomState = na
    var int bearCreatedBarState = na
    if bullishBreak
        int bearishOffset = f_findLastBearish(obLookback)
        if not na(bearishOffset)
            float obTop = obUseBody ? math.max(open[bearishOffset], close[bearishOffset]) : high[bearishOffset]
            float obBottom = obUseBody ? math.min(open[bearishOffset], close[bearishOffset]) : low[bearishOffset]
            bullTopState := obTop
            bullBottomState := obBottom
            bullCreatedBarState := bar_index
            if showOB
                box newBullOb = box.new(left = bar_index - bearishOffset, top = obTop, right = bar_index + obFvgRightExtendBars, bottom = obBottom, xloc = xloc.bar_index, extend = extend.none, border_color = bullObColor, bgcolor = color.new(bullObColor, zoneTransparency), text = showObText ? "多方訂單區" : "", text_color = zoneTextColor, text_size = size.small, text_halign = text.align_left, text_valign = text.align_top)
                f_addBox(bullOrderBlocks, newBullOb, maxOBZones, suppressSameTypeZoneOverlap, sameTypeZoneOverlapPct * 0.01)
    if bearishBreak
        int bullishOffset = f_findLastBullish(obLookback)
        if not na(bullishOffset)
            float obTop = obUseBody ? math.max(open[bullishOffset], close[bullishOffset]) : high[bullishOffset]
            float obBottom = obUseBody ? math.min(open[bullishOffset], close[bullishOffset]) : low[bullishOffset]
            bearTopState := obTop
            bearBottomState := obBottom
            bearCreatedBarState := bar_index
            if showOB
                box newBearOb = box.new(left = bar_index - bullishOffset, top = obTop, right = bar_index + obFvgRightExtendBars, bottom = obBottom, xloc = xloc.bar_index, extend = extend.none, border_color = bearObColor, bgcolor = color.new(bearObColor, zoneTransparency), text = showObText ? "空方訂單區" : "", text_color = zoneTextColor, text_size = size.small, text_halign = text.align_left, text_valign = text.align_top)
                f_addBox(bearOrderBlocks, newBearOb, maxOBZones, suppressSameTypeZoneOverlap, sameTypeZoneOverlapPct * 0.01)
    f_deleteBrokenZones(bullOrderBlocks, false)
    f_deleteBrokenZones(bearOrderBlocks, true)
    if not na(bullBottomState) and close < bullBottomState
        bullTopState := na
        bullBottomState := na
        bullCreatedBarState := na
    if not na(bearTopState) and close > bearTopState
        bearTopState := na
        bearBottomState := na
        bearCreatedBarState := na
    [bullTopState, bullBottomState, bullCreatedBarState, bearTopState, bearBottomState, bearCreatedBarState]

f_processFvgModule(float atrNow) =>
    var float bullTopState = na
    var float bullBottomState = na
    var int bullCreatedBarState = na
    var float bearTopState = na
    var float bearBottomState = na
    var int bearCreatedBarState = na
    float fvgThreshold = nz(atrNow, 0.0) * minFvgAtr
    bool rawBullFvg = barstate.isconfirmed and bar_index >= 2 and low > high[2] and (low - high[2]) >= fvgThreshold
    bool rawBearFvg = barstate.isconfirmed and bar_index >= 2 and high < low[2] and (low[2] - high) >= fvgThreshold
    if rawBullFvg
        bullTopState := low
        bullBottomState := high[2]
        bullCreatedBarState := bar_index
        if showFVG
            box newBullGap = box.new(left = bar_index - 2, top = low, right = bar_index + obFvgRightExtendBars, bottom = high[2], xloc = xloc.bar_index, extend = extend.none, border_color = bullFvgColor, bgcolor = color.new(bullFvgColor, zoneTransparency), text = showFvgText ? "多方缺口" : "", text_color = zoneTextColor, text_size = size.small, text_halign = text.align_left, text_valign = text.align_top)
            f_addBox(bullFvgs, newBullGap, maxFVGZones, suppressSameTypeZoneOverlap, sameTypeZoneOverlapPct * 0.01)
    if rawBearFvg
        bearTopState := low[2]
        bearBottomState := high
        bearCreatedBarState := bar_index
        if showFVG
            box newBearGap = box.new(left = bar_index - 2, top = low[2], right = bar_index + obFvgRightExtendBars, bottom = high, xloc = xloc.bar_index, extend = extend.none, border_color = bearFvgColor, bgcolor = color.new(bearFvgColor, zoneTransparency), text = showFvgText ? "空方缺口" : "", text_color = zoneTextColor, text_size = size.small, text_halign = text.align_left, text_valign = text.align_top)
            f_addBox(bearFvgs, newBearGap, maxFVGZones, suppressSameTypeZoneOverlap, sameTypeZoneOverlapPct * 0.01)

    int displayRightBar = bar_index + obFvgRightExtendBars
    f_setBoxesRight(bullOrderBlocks, displayRightBar)
    f_setBoxesRight(bearOrderBlocks, displayRightBar)
    f_setBoxesRight(bullFvgs, displayRightBar)
    f_setBoxesRight(bearFvgs, displayRightBar)

    int bullFvgIndex = array.size(bullFvgs) - 1
    while bullFvgIndex >= 0
        box currentBullFvg = array.get(bullFvgs, bullFvgIndex)
        float gapTop = box.get_top(currentBullFvg)
        float gapBottom = box.get_bottom(currentBullFvg)
        if low <= gapBottom
            box.delete(currentBullFvg)
            array.remove(bullFvgs, bullFvgIndex)
        else if low < gapTop
            box.set_top(currentBullFvg, low)
        bullFvgIndex -= 1
    if not na(bullBottomState)
        if low <= bullBottomState
            bullTopState := na
            bullBottomState := na
            bullCreatedBarState := na
        else if low < bullTopState
            bullTopState := low

    int bearFvgIndex = array.size(bearFvgs) - 1
    while bearFvgIndex >= 0
        box currentBearFvg = array.get(bearFvgs, bearFvgIndex)
        float gapTop = box.get_top(currentBearFvg)
        float gapBottom = box.get_bottom(currentBearFvg)
        if high >= gapTop
            box.delete(currentBearFvg)
            array.remove(bearFvgs, bearFvgIndex)
        else if high > gapBottom
            box.set_bottom(currentBearFvg, high)
        bearFvgIndex -= 1
    if not na(bearTopState)
        if high >= bearTopState
            bearTopState := na
            bearBottomState := na
            bearCreatedBarState := na
        else if high > bearBottomState
            bearBottomState := high
    [bullTopState, bullBottomState, bullCreatedBarState, bearTopState, bearBottomState, bearCreatedBarState]

[structureHighPivot, structureLowPivot, lastSwingHigh, lastSwingLow, lastSwingHighBar, lastSwingLowBar, swingHighBroken, swingLowBroken, structureTrend, bullishBreak, bearishBreak, bullishChoch, bearishChoch, bullishBos, bearishBos, bearishSweep, bullishSweep] = f_processStructureModule()

[coachBullObTop, coachBullObBottom, coachBullObCreatedBar, coachBearObTop, coachBearObBottom, coachBearObCreatedBar] = f_processOrderBlockModule(bullishBreak, bearishBreak)
[coachBullFvgTop, coachBullFvgBottom, coachBullFvgCreatedBar, coachBearFvgTop, coachBearFvgBottom, coachBearFvgCreatedBar] = f_processFvgModule(atrValue)

// ============================================================================
// ⟦HS19·XVR8I5ZB3JV2⟧ ©2026 Threads(@hongshihong19)｜模組：SMC 區域共振
// 共振訊號：SMC 事件同時觸碰同方向的區域
// 這是提示訊號，不等於保證進場或獲利。
// ============================================================================
bool bullObTouch = f_rangeTouches(bullOrderBlocks, high, low)
bool bearObTouch = f_rangeTouches(bearOrderBlocks, high, low)
bool bullFvgTouch = f_rangeTouches(bullFvgs, high, low)
bool bearFvgTouch = f_rangeTouches(bearFvgs, high, low)


// 最後一根 K 棒重建同類重疊區域的階梯形聯集視覺。
// 原始 box 保留供計算；只有圖面切換為單一外框、單一填色與單一文字。
f_renderMergedZoneVisuals() =>
    if barstate.islast
        f_clearStepZoneVisuals(stepZoneOutlines, stepZoneTextBoxes)
        float stepOverlapThreshold = sameTypeZoneOverlapPct * 0.01
        // 顯示優先級：OB ＞ FVG ＞ 支撐／阻力；完整包含時由 helper 保留內外兩區。
        f_renderStepZonePair(bullOrderBlocks, showOB, bullObColor, color.new(bullObColor, zoneTransparency), "多方訂單區", showObText, stepOverlapThreshold, noPriorityZones, noPriorityZones, false, false, false, stepZoneOutlines, stepZoneTextBoxes)
        f_renderStepZonePair(bearOrderBlocks, showOB, bearObColor, color.new(bearObColor, zoneTransparency), "空方訂單區", showObText, stepOverlapThreshold, noPriorityZones, noPriorityZones, false, false, false, stepZoneOutlines, stepZoneTextBoxes)
        f_renderStepZonePair(bullFvgs, showFVG, bullFvgColor, color.new(bullFvgColor, zoneTransparency), "多方缺口", showFvgText, stepOverlapThreshold, bullOrderBlocks, noPriorityZones, showOB, false, prioritizeCrossTypeZones, stepZoneOutlines, stepZoneTextBoxes)
        f_renderStepZonePair(bearFvgs, showFVG, bearFvgColor, color.new(bearFvgColor, zoneTransparency), "空方缺口", showFvgText, stepOverlapThreshold, bearOrderBlocks, noPriorityZones, showOB, false, prioritizeCrossTypeZones, stepZoneOutlines, stepZoneTextBoxes)
        f_renderStepZonePair(supportZones, showSR, color.new(supportColor, 45), color.new(supportColor, zoneTransparency), "支撐區", showSrText, stepOverlapThreshold, bullOrderBlocks, bullFvgs, showOB, showFVG, prioritizeCrossTypeZones, stepZoneOutlines, stepZoneTextBoxes)
        f_renderStepZonePair(resistanceZones, showSR, color.new(resistanceColor, 45), color.new(resistanceColor, zoneTransparency), "阻力區", showSrText, stepOverlapThreshold, bearOrderBlocks, bearFvgs, showOB, showFVG, prioritizeCrossTypeZones, stepZoneOutlines, stepZoneTextBoxes)
    0

f_renderMergedZoneVisuals()

// ============================================================================
// ╳HSH-OHXPGYH3K0EJ╳ 原作署名｜Threads • @hongshihong19｜自動通道
// 自動平行通道
// 4H：主方向；1H：主要交易區域；15M：微型結構參考（預設關閉）。
// 通道只使用已確認 Pivot；因此會延遲，但不會提前預知尚未確認的轉折。
// ============================================================================
bool channelChartIs15m = timeframe.in_seconds() == 15 * 60
float channelTf4hSeconds = timeframe.in_seconds(coachTf4h)
float channelTf1hSeconds = timeframe.in_seconds(coachTf1h)
bool channelTfConfigValid = channelTf1hSeconds >= 60 * 60 and channelTf4hSeconds >= channelTf1hSeconds
bool channelDisplayAllowed = showAutoChannels and channelTfConfigValid and (not channelOnlyOn15m or channelChartIs15m)
channelChosenStyle = f_channelLineStyle(channelLineStyleInput)

[channel4hDirection, channel4hTime1, channel4hPrice1, channel4hTime2, channel4hPrice2, channel4hWidth] = request.security(syminfo.tickerid, coachTf4h, f_swingChannel(channelPivotLen, channelAtrLen, channelMinWidthAtr), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)
[channel1hDirection, channel1hTime1, channel1hPrice1, channel1hTime2, channel1hPrice2, channel1hWidth] = request.security(syminfo.tickerid, coachTf1h, f_swingChannel(channelPivotLen, channelAtrLen, channelMinWidthAtr), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)
[channel15mDirection, channel15mTime1, channel15mPrice1, channel15mTime2, channel15mPrice2, channel15mWidth] = f_swingChannel(channelPivotLen, channelAtrLen, channelMinWidthAtr)

float channel4hBaseNow = f_lineValueAtTime(channel4hTime1, channel4hPrice1, channel4hTime2, channel4hPrice2, time)
float channel4hLowerNow = channel4hDirection == 1 ? channel4hBaseNow : channel4hDirection == -1 ? channel4hBaseNow - channel4hWidth : na
float channel4hUpperNow = channel4hDirection == 1 ? channel4hBaseNow + channel4hWidth : channel4hDirection == -1 ? channel4hBaseNow : na
float channel4hMidNow = not na(channel4hLowerNow) and not na(channel4hUpperNow) ? (channel4hLowerNow + channel4hUpperNow) / 2.0 : na

float channel1hBaseNow = f_lineValueAtTime(channel1hTime1, channel1hPrice1, channel1hTime2, channel1hPrice2, time)
float channel1hLowerNow = channel1hDirection == 1 ? channel1hBaseNow : channel1hDirection == -1 ? channel1hBaseNow - channel1hWidth : na
float channel1hUpperNow = channel1hDirection == 1 ? channel1hBaseNow + channel1hWidth : channel1hDirection == -1 ? channel1hBaseNow : na
float channel1hMidNow = not na(channel1hLowerNow) and not na(channel1hUpperNow) ? (channel1hLowerNow + channel1hUpperNow) / 2.0 : na

float channel15mBaseNow = f_lineValueAtTime(channel15mTime1, channel15mPrice1, channel15mTime2, channel15mPrice2, time)
float channel15mLowerNow = channel15mDirection == 1 ? channel15mBaseNow : channel15mDirection == -1 ? channel15mBaseNow - channel15mWidth : na
float channel15mUpperNow = channel15mDirection == 1 ? channel15mBaseNow + channel15mWidth : channel15mDirection == -1 ? channel15mBaseNow : na
float channel15mMidNow = not na(channel15mLowerNow) and not na(channel15mUpperNow) ? (channel15mLowerNow + channel15mUpperNow) / 2.0 : na

string channel1hCoachStatus = not showAutoChannels ? "已關閉" : not channelTfConfigValid ? "時間軸設定錯誤" : f_channelPositionText(channel1hDirection, channel1hLowerNow, channel1hUpperNow, close, channelNearPercent)

f_renderChannelVisuals() =>
    var line channel4hBaseLine = na
    var line channel4hParallelLine = na
    var line channel4hMidLine = na
    var linefill channel4hFill = na
    var label channel4hUpperHover = na
    var label channel4hMiddleHover = na
    var label channel4hLowerHover = na
    var line channel1hBaseLine = na
    var line channel1hParallelLine = na
    var line channel1hMidLine = na
    var linefill channel1hFill = na
    var label channel1hUpperHover = na
    var label channel1hMiddleHover = na
    var label channel1hLowerHover = na
    var line channel15mBaseLine = na
    var line channel15mParallelLine = na
    var line channel15mMidLine = na
    var linefill channel15mFill = na
    var label channel15mUpperHover = na
    var label channel15mMiddleHover = na
    var label channel15mLowerHover = na

    if barstate.islast
        bool valid4hChannel = channelDisplayAllowed and showChannel4h and channel4hDirection != 0 and not na(channel4hTime1) and not na(channel4hTime2) and not na(channel4hWidth)
        bool valid1hChannel = channelDisplayAllowed and showChannel1h and channel1hDirection != 0 and not na(channel1hTime1) and not na(channel1hTime2) and not na(channel1hWidth)
        bool valid15mChannel = channelDisplayAllowed and showChannel15m and channel15mDirection != 0 and not na(channel15mTime1) and not na(channel15mTime2) and not na(channel15mWidth)

        // 4H 通道
        if valid4hChannel
            float p1Base = channel4hPrice1
            float p1Parallel = channel4hDirection == 1 ? p1Base + channel4hWidth : p1Base - channel4hWidth
            [channel4hEndTime, channel4hBaseEnd, channel4hParallelEnd, channel4hMiddleEnd] = f_channelRightEndpoint(channel4hTime1, channel4hPrice1, channel4hTime2, channel4hPrice2, channel4hDirection, channel4hWidth, srRightExtendBars)
            float channel4hUpperEnd = math.max(channel4hBaseEnd, channel4hParallelEnd)
            float channel4hLowerEnd = math.min(channel4hBaseEnd, channel4hParallelEnd)
            if na(channel4hBaseLine)
                channel4hBaseLine := line.new(channel4hTime1, p1Base, channel4hEndTime, channel4hBaseEnd, xloc = xloc.bar_time, extend = extend.none, color = channel4hColor, width = channelLineWidth, style = channelChosenStyle)
                channel4hParallelLine := line.new(channel4hTime1, p1Parallel, channel4hEndTime, channel4hParallelEnd, xloc = xloc.bar_time, extend = extend.none, color = channel4hColor, width = channelLineWidth, style = channelChosenStyle)
                channel4hMidLine := line.new(channel4hTime1, (p1Base + p1Parallel) / 2.0, channel4hEndTime, channel4hMiddleEnd, xloc = xloc.bar_time, extend = extend.none, color = color.new(channel4hColor, 35), width = 1, style = line.style_dashed)
                channel4hFill := linefill.new(channel4hBaseLine, channel4hParallelLine, fillChannels ? color.new(channel4hColor, channelFillTransparency) : color.new(channel4hColor, 100))
            line.set_xy1(channel4hBaseLine, channel4hTime1, p1Base)
            line.set_xy2(channel4hBaseLine, channel4hEndTime, channel4hBaseEnd)
            line.set_xy1(channel4hParallelLine, channel4hTime1, p1Parallel)
            line.set_xy2(channel4hParallelLine, channel4hEndTime, channel4hParallelEnd)
            line.set_color(channel4hBaseLine, channel4hColor)
            line.set_color(channel4hParallelLine, channel4hColor)
            line.set_style(channel4hBaseLine, channelChosenStyle)
            line.set_style(channel4hParallelLine, channelChosenStyle)
            line.set_width(channel4hBaseLine, channelLineWidth)
            line.set_width(channel4hParallelLine, channelLineWidth)
            line.set_xy1(channel4hMidLine, channel4hTime1, (p1Base + p1Parallel) / 2.0)
            line.set_xy2(channel4hMidLine, channel4hEndTime, channel4hMiddleEnd)
            line.set_color(channel4hMidLine, showChannelMidline ? color.new(channel4hColor, 35) : color.new(channel4hColor, 100))
            linefill.set_color(channel4hFill, fillChannels ? color.new(channel4hColor, channelFillTransparency) : color.new(channel4hColor, 100))
            string channel4hTooltip = f_channelHoverTooltip("4H", channel4hDirection, channel4hLowerNow, channel4hUpperNow, close, channelNearPercent)
            channel4hUpperHover := f_syncChannelHoverLabel(channel4hUpperHover, showChannelLabels, channel4hEndTime, channel4hUpperEnd, channel4hTooltip)
            channel4hMiddleHover := f_syncChannelHoverLabel(channel4hMiddleHover, showChannelLabels, channel4hEndTime, channel4hMiddleEnd, channel4hTooltip)
            channel4hLowerHover := f_syncChannelHoverLabel(channel4hLowerHover, showChannelLabels, channel4hEndTime, channel4hLowerEnd, channel4hTooltip)
        else
            if not na(channel4hBaseLine)
                line.set_color(channel4hBaseLine, color.new(channel4hColor, 100))
                line.set_color(channel4hParallelLine, color.new(channel4hColor, 100))
                line.set_color(channel4hMidLine, color.new(channel4hColor, 100))
                linefill.set_color(channel4hFill, color.new(channel4hColor, 100))
                channel4hUpperHover := f_syncChannelHoverLabel(channel4hUpperHover, false, time, na, "")
                channel4hMiddleHover := f_syncChannelHoverLabel(channel4hMiddleHover, false, time, na, "")
                channel4hLowerHover := f_syncChannelHoverLabel(channel4hLowerHover, false, time, na, "")

        // 1H 通道
        if valid1hChannel
            float p1Base = channel1hPrice1
            float p1Parallel = channel1hDirection == 1 ? p1Base + channel1hWidth : p1Base - channel1hWidth
            [channel1hEndTime, channel1hBaseEnd, channel1hParallelEnd, channel1hMiddleEnd] = f_channelRightEndpoint(channel1hTime1, channel1hPrice1, channel1hTime2, channel1hPrice2, channel1hDirection, channel1hWidth, srRightExtendBars)
            float channel1hUpperEnd = math.max(channel1hBaseEnd, channel1hParallelEnd)
            float channel1hLowerEnd = math.min(channel1hBaseEnd, channel1hParallelEnd)
            if na(channel1hBaseLine)
                channel1hBaseLine := line.new(channel1hTime1, p1Base, channel1hEndTime, channel1hBaseEnd, xloc = xloc.bar_time, extend = extend.none, color = channel1hColor, width = channelLineWidth, style = channelChosenStyle)
                channel1hParallelLine := line.new(channel1hTime1, p1Parallel, channel1hEndTime, channel1hParallelEnd, xloc = xloc.bar_time, extend = extend.none, color = channel1hColor, width = channelLineWidth, style = channelChosenStyle)
                channel1hMidLine := line.new(channel1hTime1, (p1Base + p1Parallel) / 2.0, channel1hEndTime, channel1hMiddleEnd, xloc = xloc.bar_time, extend = extend.none, color = color.new(channel1hColor, 35), width = 1, style = line.style_dashed)
                channel1hFill := linefill.new(channel1hBaseLine, channel1hParallelLine, fillChannels ? color.new(channel1hColor, channelFillTransparency) : color.new(channel1hColor, 100))
            line.set_xy1(channel1hBaseLine, channel1hTime1, p1Base)
            line.set_xy2(channel1hBaseLine, channel1hEndTime, channel1hBaseEnd)
            line.set_xy1(channel1hParallelLine, channel1hTime1, p1Parallel)
            line.set_xy2(channel1hParallelLine, channel1hEndTime, channel1hParallelEnd)
            line.set_color(channel1hBaseLine, channel1hColor)
            line.set_color(channel1hParallelLine, channel1hColor)
            line.set_style(channel1hBaseLine, channelChosenStyle)
            line.set_style(channel1hParallelLine, channelChosenStyle)
            line.set_width(channel1hBaseLine, channelLineWidth)
            line.set_width(channel1hParallelLine, channelLineWidth)
            line.set_xy1(channel1hMidLine, channel1hTime1, (p1Base + p1Parallel) / 2.0)
            line.set_xy2(channel1hMidLine, channel1hEndTime, channel1hMiddleEnd)
            line.set_color(channel1hMidLine, showChannelMidline ? color.new(channel1hColor, 35) : color.new(channel1hColor, 100))
            linefill.set_color(channel1hFill, fillChannels ? color.new(channel1hColor, channelFillTransparency) : color.new(channel1hColor, 100))
            string channel1hTooltip = f_channelHoverTooltip("1H", channel1hDirection, channel1hLowerNow, channel1hUpperNow, close, channelNearPercent)
            channel1hUpperHover := f_syncChannelHoverLabel(channel1hUpperHover, showChannelLabels, channel1hEndTime, channel1hUpperEnd, channel1hTooltip)
            channel1hMiddleHover := f_syncChannelHoverLabel(channel1hMiddleHover, showChannelLabels, channel1hEndTime, channel1hMiddleEnd, channel1hTooltip)
            channel1hLowerHover := f_syncChannelHoverLabel(channel1hLowerHover, showChannelLabels, channel1hEndTime, channel1hLowerEnd, channel1hTooltip)
        else
            if not na(channel1hBaseLine)
                line.set_color(channel1hBaseLine, color.new(channel1hColor, 100))
                line.set_color(channel1hParallelLine, color.new(channel1hColor, 100))
                line.set_color(channel1hMidLine, color.new(channel1hColor, 100))
                linefill.set_color(channel1hFill, color.new(channel1hColor, 100))
                channel1hUpperHover := f_syncChannelHoverLabel(channel1hUpperHover, false, time, na, "")
                channel1hMiddleHover := f_syncChannelHoverLabel(channel1hMiddleHover, false, time, na, "")
                channel1hLowerHover := f_syncChannelHoverLabel(channel1hLowerHover, false, time, na, "")

        // 15M 微型通道（選配）
        if valid15mChannel
            float p1Base = channel15mPrice1
            float p1Parallel = channel15mDirection == 1 ? p1Base + channel15mWidth : p1Base - channel15mWidth
            [channel15mEndTime, channel15mBaseEnd, channel15mParallelEnd, channel15mMiddleEnd] = f_channelRightEndpoint(channel15mTime1, channel15mPrice1, channel15mTime2, channel15mPrice2, channel15mDirection, channel15mWidth, srRightExtendBars)
            float channel15mUpperEnd = math.max(channel15mBaseEnd, channel15mParallelEnd)
            float channel15mLowerEnd = math.min(channel15mBaseEnd, channel15mParallelEnd)
            if na(channel15mBaseLine)
                channel15mBaseLine := line.new(channel15mTime1, p1Base, channel15mEndTime, channel15mBaseEnd, xloc = xloc.bar_time, extend = extend.none, color = channel15mColor, width = 1, style = line.style_dashed)
                channel15mParallelLine := line.new(channel15mTime1, p1Parallel, channel15mEndTime, channel15mParallelEnd, xloc = xloc.bar_time, extend = extend.none, color = channel15mColor, width = 1, style = line.style_dashed)
                channel15mMidLine := line.new(channel15mTime1, (p1Base + p1Parallel) / 2.0, channel15mEndTime, channel15mMiddleEnd, xloc = xloc.bar_time, extend = extend.none, color = color.new(channel15mColor, 45), width = 1, style = line.style_dotted)
                channel15mFill := linefill.new(channel15mBaseLine, channel15mParallelLine, fillChannels ? color.new(channel15mColor, math.min(channelFillTransparency + 4, 100)) : color.new(channel15mColor, 100))
            line.set_xy1(channel15mBaseLine, channel15mTime1, p1Base)
            line.set_xy2(channel15mBaseLine, channel15mEndTime, channel15mBaseEnd)
            line.set_xy1(channel15mParallelLine, channel15mTime1, p1Parallel)
            line.set_xy2(channel15mParallelLine, channel15mEndTime, channel15mParallelEnd)
            line.set_color(channel15mBaseLine, channel15mColor)
            line.set_color(channel15mParallelLine, channel15mColor)
            line.set_xy1(channel15mMidLine, channel15mTime1, (p1Base + p1Parallel) / 2.0)
            line.set_xy2(channel15mMidLine, channel15mEndTime, channel15mMiddleEnd)
            line.set_color(channel15mMidLine, showChannelMidline ? color.new(channel15mColor, 45) : color.new(channel15mColor, 100))
            linefill.set_color(channel15mFill, fillChannels ? color.new(channel15mColor, math.min(channelFillTransparency + 4, 100)) : color.new(channel15mColor, 100))
            string channel15mTooltip = f_channelHoverTooltip("15M", channel15mDirection, channel15mLowerNow, channel15mUpperNow, close, channelNearPercent)
            channel15mUpperHover := f_syncChannelHoverLabel(channel15mUpperHover, showChannelLabels, channel15mEndTime, channel15mUpperEnd, channel15mTooltip)
            channel15mMiddleHover := f_syncChannelHoverLabel(channel15mMiddleHover, showChannelLabels, channel15mEndTime, channel15mMiddleEnd, channel15mTooltip)
            channel15mLowerHover := f_syncChannelHoverLabel(channel15mLowerHover, showChannelLabels, channel15mEndTime, channel15mLowerEnd, channel15mTooltip)
        else
            if not na(channel15mBaseLine)
                line.set_color(channel15mBaseLine, color.new(channel15mColor, 100))
                line.set_color(channel15mParallelLine, color.new(channel15mColor, 100))
                line.set_color(channel15mMidLine, color.new(channel15mColor, 100))
                linefill.set_color(channel15mFill, color.new(channel15mColor, 100))
                channel15mUpperHover := f_syncChannelHoverLabel(channel15mUpperHover, false, time, na, "")
                channel15mMiddleHover := f_syncChannelHoverLabel(channel15mMiddleHover, false, time, na, "")
                channel15mLowerHover := f_syncChannelHoverLabel(channel15mLowerHover, false, time, na, "")
    0

f_renderChannelVisuals()

bool channel1hUpperTouch = channelDisplayAllowed and showChannel1h and not na(channel1hUpperNow) and high >= channel1hUpperNow and low <= channel1hUpperNow
bool channel1hLowerTouch = channelDisplayAllowed and showChannel1h and not na(channel1hLowerNow) and high >= channel1hLowerNow and low <= channel1hLowerNow
bool channel1hBreakAbove = channelDisplayAllowed and showChannel1h and barstate.isconfirmed and not na(channel1hUpperNow) and close > channel1hUpperNow and close[1] <= channel1hUpperNow[1]
bool channel1hBreakBelow = channelDisplayAllowed and showChannel1h and barstate.isconfirmed and not na(channel1hLowerNow) and close < channel1hLowerNow and close[1] >= channel1hLowerNow[1]

// ============================================================================
// ⌁SRSMC⌁ author=@hongshihong19 / Threads｜module=多空教練｜seal:CBUYI7K887PN
// 多週期多空雙向教練
// 日線看大環境、4H 定主方向、1H 辨識推進／回調與區域、15M 等 Sweep → CHoCH → BOS → 回測。
// 建議模式由 4H 已確認結構決定主軸；1H 反向視為回調／反彈，日線可選擇是否作過濾。
// ============================================================================
float coachChartSeconds = timeframe.in_seconds()
bool coachOn15m = coachChartSeconds == 15 * 60
float coachTf1dSeconds = timeframe.in_seconds(coachTf1d)
float coachTf4hSeconds = timeframe.in_seconds(coachTf4h)
float coachTf1hSeconds = timeframe.in_seconds(coachTf1h)
bool coachOn1d = coachChartSeconds == coachTf1dSeconds
bool coachOn1h = coachChartSeconds == coachTf1hSeconds
bool coachOn4h = coachChartSeconds == coachTf4hSeconds


// 手動持倉設定是步驟 8 的啟動來源。程式不改寫 input；觸碰指定 TP 後只改變有效持倉與面板狀態。
int positionRequestedDirection = positionStatusInput == "多單" ? 1 : positionStatusInput == "空單" ? -1 : 0
bool positionRequestedHasValidEntry = positionRequestedDirection != 0 and positionEntryPriceInput > 0
string positionRequestedDirectionText = positionRequestedDirection == 1 ? "多單" : positionRequestedDirection == -1 ? "空單" : "無持倉"
int positionPlannedTpNumber = f_plannedTpNumber(positionPlannedTpInput)
bool positionManualTpMode = positionPlannedTpInput == "手動輸入 TP"
bool positionManualTpValid = positionManualTpMode and positionRequestedHasValidEntry and positionManualTpPriceInput > 0 and (positionRequestedDirection == 1 ? positionManualTpPriceInput > positionEntryPriceInput : positionManualTpPriceInput < positionEntryPriceInput)

// 每筆手動持倉在 1H 首次啟動時鎖定 TP 清單，避免後續新區域插入造成 TP 編號跳動。
var array<float> positionTpTops = array.new_float()
var array<float> positionTpBottoms = array.new_float()
var array<int> positionTpTypes = array.new_int()
var string positionTradeSnapshotKey = ""
var bool positionTradeClosed = false
var int positionTradeClosedTp = 0
var float positionTradeClosedPrice = na
var float positionLockedStopPrice = na
var float positionLockedStopZoneTop = na
var float positionLockedStopZoneBottom = na
var string positionLockedStopSource = ""
var int positionLockedStopType = 0

string positionCurrentSnapshotKey = syminfo.tickerid + "|" + str.tostring(positionRequestedDirection) + "|" + str.tostring(positionEntryPriceInput, format.mintick) + "|" + positionPlannedTpInput + "|" + str.tostring(positionManualTpMode ? positionManualTpPriceInput : 0.0, format.mintick) + "|" + positionStopSourceInput
bool positionSnapshotChanged = positionCurrentSnapshotKey != positionTradeSnapshotKey
if barstate.islast and coachOn1h
    if not positionRequestedHasValidEntry
        array.clear(positionTpTops)
        array.clear(positionTpBottoms)
        array.clear(positionTpTypes)
        positionTradeSnapshotKey := positionCurrentSnapshotKey
        positionTradeClosed := false
        positionTradeClosedTp := 0
        positionTradeClosedPrice := na
        positionLockedStopPrice := na
        positionLockedStopZoneTop := na
        positionLockedStopZoneBottom := na
        positionLockedStopSource := ""
        positionLockedStopType := 0
    else if positionSnapshotChanged or (array.size(positionTpTops) == 0 and not positionTradeClosed)
        if positionRequestedDirection == 1
            f_buildSrExitZones(resistanceZones, positionEntryPriceInput, false, positionTpTops, positionTpBottoms, positionTpTypes, POSITION_MAX_TP)
        else
            f_buildSrExitZones(supportZones, positionEntryPriceInput, true, positionTpTops, positionTpBottoms, positionTpTypes, POSITION_MAX_TP)
        positionTradeSnapshotKey := positionCurrentSnapshotKey
        positionTradeClosed := false
        positionTradeClosedTp := 0
        positionTradeClosedPrice := na
        positionLockedStopPrice := na
        positionLockedStopZoneTop := na
        positionLockedStopZoneBottom := na
        positionLockedStopSource := ""
        positionLockedStopType := 0

int positionTpCount = array.size(positionTpTops)
bool positionAutoTpValid = positionPlannedTpNumber > 0 and positionPlannedTpNumber <= positionTpCount
bool positionSelectedTpValid = positionManualTpMode ? positionManualTpValid : positionAutoTpValid
float positionSelectedTpTop = na
float positionSelectedTpBottom = na
int positionSelectedTpType = positionManualTpMode ? 5 : 0
float positionSelectedTpExitPrice = na
if positionManualTpValid
    positionSelectedTpTop := positionManualTpPriceInput + syminfo.mintick
    positionSelectedTpBottom := positionManualTpPriceInput - syminfo.mintick
    positionSelectedTpExitPrice := positionManualTpPriceInput
else if positionAutoTpValid
    int selectedTpIndex = positionPlannedTpNumber - 1
    positionSelectedTpTop := array.get(positionTpTops, selectedTpIndex)
    positionSelectedTpBottom := array.get(positionTpBottoms, selectedTpIndex)
    positionSelectedTpType := array.get(positionTpTypes, selectedTpIndex)
    positionSelectedTpExitPrice := f_exitZoneNearEdge(positionRequestedDirection, positionSelectedTpTop, positionSelectedTpBottom)

// SL 固定讀取 15M 同方向區域；TP 清單仍維持 1H。
// SL 價格採純 SMC 結構邊界，不額外加 ATR 緩衝。
[position15mBullObTop, position15mBullObBottom, position15mBullFvgTop, position15mBullFvgBottom, position15mBearObTop, position15mBearObBottom, position15mBearFvgTop, position15mBearFvgBottom, position15mStructureHigh, position15mStructureLow] = request.security(syminfo.tickerid, "15", f_positionStopZones15m(positionEntryPriceInput, structureLen, obLookback, obUseBody, maxOBZones, srAtrLen, minFvgAtr, maxFVGZones), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)

float positionStopObTop = positionRequestedDirection == 1 ? position15mBullObTop : positionRequestedDirection == -1 ? position15mBearObTop : na
float positionStopObBottom = positionRequestedDirection == 1 ? position15mBullObBottom : positionRequestedDirection == -1 ? position15mBearObBottom : na
float positionStopFvgTop = positionRequestedDirection == 1 ? position15mBullFvgTop : positionRequestedDirection == -1 ? position15mBearFvgTop : na
float positionStopFvgBottom = positionRequestedDirection == 1 ? position15mBullFvgBottom : positionRequestedDirection == -1 ? position15mBearFvgBottom : na

float positionStopObEdgeRaw = not na(positionStopObTop) and not na(positionStopObBottom) ? f_stopZoneOrderBlockEdge(positionRequestedDirection, positionStopObTop, positionStopObBottom) : na
float positionStopFvgEdgeRaw = not na(positionStopFvgTop) and not na(positionStopFvgBottom) ? f_stopZoneGapEdge(positionRequestedDirection, positionStopFvgTop, positionStopFvgBottom) : na
float positionStopStructureRaw = positionRequestedDirection == -1 ? position15mStructureHigh : positionRequestedDirection == 1 ? position15mStructureLow : na

// 只接受位於進場價正確方向的停損候選：空單必須在進場價上方，多單必須在進場價下方。
float positionStopObEdge = positionRequestedDirection == -1 ? (not na(positionStopObEdgeRaw) and positionStopObEdgeRaw > positionEntryPriceInput ? positionStopObEdgeRaw : na) : positionRequestedDirection == 1 ? (not na(positionStopObEdgeRaw) and positionStopObEdgeRaw < positionEntryPriceInput ? positionStopObEdgeRaw : na) : na
float positionStopFvgEdge = positionRequestedDirection == -1 ? (not na(positionStopFvgEdgeRaw) and positionStopFvgEdgeRaw > positionEntryPriceInput ? positionStopFvgEdgeRaw : na) : positionRequestedDirection == 1 ? (not na(positionStopFvgEdgeRaw) and positionStopFvgEdgeRaw < positionEntryPriceInput ? positionStopFvgEdgeRaw : na) : na
float positionStopStructureEdge = positionRequestedDirection == -1 ? (not na(positionStopStructureRaw) and positionStopStructureRaw > positionEntryPriceInput ? positionStopStructureRaw : na) : positionRequestedDirection == 1 ? (not na(positionStopStructureRaw) and positionStopStructureRaw < positionEntryPriceInput ? positionStopStructureRaw : na) : na

float positionStopCandidatePrice = na
float positionStopCandidateZoneTop = na
float positionStopCandidateZoneBottom = na
string positionStopCandidateSource = ""
int positionStopCandidateType = 0

if positionStopSourceInput == "15M 保護高低點"
    if not na(positionStopStructureEdge)
        positionStopCandidatePrice := positionStopStructureEdge
        positionStopCandidateZoneTop := positionStopStructureEdge + syminfo.mintick
        positionStopCandidateZoneBottom := positionStopStructureEdge - syminfo.mintick
        positionStopCandidateSource := positionRequestedDirection == -1 ? "15M 保護高點" : "15M 保護低點"
        positionStopCandidateType := 3
else if positionStopSourceInput == "15M 最近 FVG"
    if not na(positionStopFvgEdge)
        positionStopCandidatePrice := positionStopFvgEdge
        positionStopCandidateZoneTop := math.max(positionStopFvgTop, positionStopFvgBottom)
        positionStopCandidateZoneBottom := math.min(positionStopFvgTop, positionStopFvgBottom)
        positionStopCandidateSource := positionRequestedDirection == -1 ? "15M 最近空方 FVG 下緣" : "15M 最近多方 FVG 上緣"
        positionStopCandidateType := 1
else if positionStopSourceInput == "15M 訂單區"
    if not na(positionStopObEdge)
        positionStopCandidatePrice := positionStopObEdge
        positionStopCandidateZoneTop := math.max(positionStopObTop, positionStopObBottom)
        positionStopCandidateZoneBottom := math.min(positionStopObTop, positionStopObBottom)
        positionStopCandidateSource := positionRequestedDirection == -1 ? "15M 空方 OB 上緣" : "15M 多方 OB 下緣"
        positionStopCandidateType := 2

// 建立或修改持倉時鎖定 SL；後續新形成的 FVG／OB 不會令 SL 跳動。
if barstate.islast
    if not positionRequestedHasValidEntry
        positionLockedStopPrice := na
        positionLockedStopZoneTop := na
        positionLockedStopZoneBottom := na
        positionLockedStopSource := ""
        positionLockedStopType := 0
    else if positionSnapshotChanged or na(positionLockedStopPrice)
        positionLockedStopPrice := positionStopCandidatePrice
        positionLockedStopZoneTop := positionStopCandidateZoneTop
        positionLockedStopZoneBottom := positionStopCandidateZoneBottom
        positionLockedStopSource := positionStopCandidateSource
        positionLockedStopType := positionStopCandidateType

float positionSelectedStopPrice = positionLockedStopPrice
float positionStopZoneTop = positionLockedStopZoneTop
float positionStopZoneBottom = positionLockedStopZoneBottom
float positionRiskDistance = positionRequestedHasValidEntry and not na(positionSelectedStopPrice) ? math.abs(positionSelectedStopPrice - positionEntryPriceInput) : na
string positionStopSourceLabel = str.length(positionLockedStopSource) > 0 ? positionLockedStopSource + "｜無 ATR 緩衝" : ""
string positionStopPanelText = not positionRequestedHasValidEntry ? "請先設定持倉方向與進場價格" : na(positionSelectedStopPrice) ? "找不到符合進場方向的 15M SMC 停損位置" : positionStopSourceLabel + "｜SL " + str.tostring(positionSelectedStopPrice, format.mintick) + "｜SL 區 " + f_priceRangeText(positionStopZoneTop, positionStopZoneBottom)

// 1H 判斷 TP／SL；同根 K 同時觸碰時採保守規則：SL 優先。-1 代表 SL，0 代表手動 TP。
bool positionSelectedTpTouchedNow = barstate.islast and coachOn1h and positionRequestedHasValidEntry and not positionTradeClosed and positionSelectedTpValid and (positionManualTpMode ? (positionRequestedDirection == 1 ? high >= positionSelectedTpExitPrice : low <= positionSelectedTpExitPrice) : high >= positionSelectedTpBottom and low <= positionSelectedTpTop)
bool positionSelectedStopTouchedNow = barstate.islast and coachOn1h and positionRequestedHasValidEntry and not positionTradeClosed and not na(positionSelectedStopPrice) and (positionRequestedDirection == 1 ? low <= positionSelectedStopPrice : high >= positionSelectedStopPrice)
if positionSelectedStopTouchedNow or positionSelectedTpTouchedNow
    positionTradeClosed := true
    positionTradeClosedTp := positionSelectedStopTouchedNow ? -1 : positionManualTpMode ? 0 : positionPlannedTpNumber
    positionTradeClosedPrice := positionSelectedStopTouchedNow ? positionSelectedStopPrice : positionSelectedTpExitPrice

bool positionHasValidEntry = positionRequestedHasValidEntry and not positionTradeClosed
int positionDirection = positionHasValidEntry ? positionRequestedDirection : 0
string positionPanelText = positionTradeClosed ? (positionTradeClosedTp == -1 ? "已觸碰 SL｜停損出場｜無持倉" : positionTradeClosedTp == 0 ? "已觸碰手動 TP｜出場獲利｜無持倉" : "已觸碰 TP" + str.tostring(positionTradeClosedTp) + "｜出場獲利｜無持倉") : positionHasValidEntry ? positionRequestedDirectionText + "｜進場 " + str.tostring(positionEntryPriceInput, format.mintick) : positionRequestedDirection == 0 ? "無持倉" : positionRequestedDirectionText + "｜請輸入大於 0 的進場價格"
color positionLineColor = positionRequestedDirection == 1 ? bullishRoleColor : positionRequestedDirection == -1 ? bearishRoleColor : color.new(color.gray, 100)

// 進場價格水平實線：有效持倉期間全圖延伸；指定 TP 出場後自動移除。
var line positionEntryLine = na
if barstate.islast
    if positionHasValidEntry
        if na(positionEntryLine)
            positionEntryLine := line.new(bar_index, positionEntryPriceInput, bar_index + 1, positionEntryPriceInput, xloc = xloc.bar_index, extend = extend.both, color = positionLineColor, style = line.style_solid, width = 2)
        else
            line.set_xy1(positionEntryLine, bar_index, positionEntryPriceInput)
            line.set_xy2(positionEntryLine, bar_index + 1, positionEntryPriceInput)
            line.set_extend(positionEntryLine, extend.both)
            line.set_color(positionEntryLine, positionLineColor)
            line.set_style(positionEntryLine, line.style_solid)
            line.set_width(positionEntryLine, 2)
    else if not na(positionEntryLine)
        line.delete(positionEntryLine)
        positionEntryLine := na
bool coachTfConfigValid = coachTf1hSeconds >= 60 * 60 and coachTf4hSeconds >= coachTf1hSeconds and coachTf1dSeconds >= coachTf4hSeconds
string coachTfConfigErrorText = "時間軸設定錯誤：建議日線／4H／1H／15M"

// ◈H19-L9XHKHXN4CGJ◈ 原始設計：Threads(@hongshihong19)｜多週期資料請求
[coachTrend1d, coachEvent1d, coachHighType1d, coachLowType1d, coachSwingHigh1d, coachSwingLow1d, coachEventPrice1d, coachHighBroken1d, coachLowBroken1d, coachSweep1d] = request.security(syminfo.tickerid, coachTf1d, f_htfStructureSnapshot(coachPivotLen), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)
[coachTrend4h, coachEvent4h, coachHighType4h, coachLowType4h, coachSwingHigh4h, coachSwingLow4h, coachEventPrice4h, coachHighBroken4h, coachLowBroken4h, coachSweep4h] = request.security(syminfo.tickerid, coachTf4h, f_htfStructureSnapshot(coachPivotLen), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)
[coachTrend1h, coachEvent1h, coachHighType1h, coachLowType1h, coachSwingHigh1h, coachSwingLow1h, coachEventPrice1h, coachHighBroken1h, coachLowBroken1h, coachSweep1h] = request.security(syminfo.tickerid, coachTf1h, f_htfStructureSnapshot(coachPivotLen), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)
int coachPosition1d = f_rangePositionCode(close, coachSwingHigh1d, coachSwingLow1d)
int coachPosition4h = f_rangePositionCode(close, coachSwingHigh4h, coachSwingLow4h)
int coachPosition1h = f_rangePositionCode(close, coachSwingHigh1h, coachSwingLow1h)
int coachPhase1d = f_marketPhaseCode(coachTrend1d, coachPosition1d)
int coachPhase4h = f_marketPhaseCode(coachTrend4h, coachPosition4h)
int coachPhase1h = f_marketPhaseCode(coachTrend1h, coachPosition1h)
[coach1hBearTurnTriggerPrice, coach1hLastBearTurnPrice] = request.security(syminfo.tickerid, coachTf1h, f_htfBearTurnData(coachPivotLen), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)

// ============================================================================
// 步驟 2 候選區來源規則（不可移除／不可與主圖即時區域混為一談）
// 1. 候選區透過 request.security()，分別在 1H／4H 內部執行 f_htfVisibleZones()。
// 2. f_htfVisibleZones() 回傳 resistanceTop[1]、resistanceBottom[1] 等 [1] 資料，
//    代表「上一根已確認完成的高週期 K 棒」，避免使用尚未收盤的 1H／4H 區域。
// 3. 空單候選函式只從以下區域選最近有效區：
//    1H 阻力區、1H 空方訂單區、1H 空方缺口、4H 阻力區、4H 空方訂單區、4H 空方缺口。
// 4. 多單候選函式反向只選支撐、多方訂單區、多方缺口。
// 5. 候選框在 15M 顯示交易流程，並在候選來源時間軸（1H 或 4H）額外顯示供驗證。
// 6. 例如選到「1H 阻力區 64154.1～64424.7」，表示上一根已確認 1H K 的最近有效阻力區。
// ============================================================================
// 15M 面板與 1H／4H 候選驗證框使用同一組 request.security 高週期快照。
[coach4hSupportTop, coach4hSupportBottom, coach4hBullObTop, coach4hBullObBottom, coach4hBullFvgTop, coach4hBullFvgBottom, coach4hResistanceTop, coach4hResistanceBottom, coach4hBearObTop, coach4hBearObBottom, coach4hBearFvgTop, coach4hBearFvgBottom] = request.security(syminfo.tickerid, coachTf4h, f_htfVisibleZones(useSRLogic, srPivotLen, srAtrLen, srZoneAtr, mergeMultiplier, maxSRZones, srBreakBufferAtr, srBreakConfirmBars, srEnableRoleFlip, structureLen, obLookback, obUseBody, maxOBZones, minFvgAtr, maxFVGZones), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)
[coach1hSupportTop, coach1hSupportBottom, coach1hBullObTop, coach1hBullObBottom, coach1hBullFvgTop, coach1hBullFvgBottom, coach1hResistanceTop, coach1hResistanceBottom, coach1hBearObTop, coach1hBearObBottom, coach1hBearFvgTop, coach1hBearFvgBottom] = request.security(syminfo.tickerid, coachTf1h, f_htfVisibleZones(useSRLogic, srPivotLen, srAtrLen, srZoneAtr, mergeMultiplier, maxSRZones, srBreakBufferAtr, srBreakConfirmBars, srEnableRoleFlip, structureLen, obLookback, obUseBody, maxOBZones, minFvgAtr, maxFVGZones), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)

// 15M 預覽重用既有 1H 快照：空單預覽最近支撐區；多單預覽最近阻力區。
float previewTp1Top = positionRequestedDirection == -1 ? coach1hSupportTop : positionRequestedDirection == 1 ? coach1hResistanceTop : na
float previewTp1Bottom = positionRequestedDirection == -1 ? coach1hSupportBottom : positionRequestedDirection == 1 ? coach1hResistanceBottom : na
float previewTp1Exit = f_exitZoneNearEdge(positionRequestedDirection, previewTp1Top, previewTp1Bottom)
bool previewTp1Valid = positionRequestedHasValidEntry and not na(previewTp1Exit) and (positionRequestedDirection == -1 ? previewTp1Exit < positionEntryPriceInput : previewTp1Exit > positionEntryPriceInput)
int previewTpCount = previewTp1Valid ? 1 : 0
int previewTp1Type = previewTp1Valid ? 4 : 0
float previewTp2Top = na
float previewTp2Bottom = na
int previewTp2Type = 0

// 15M／1H／4H 共用同一份區域快照；不在 request.security() 內建立生命週期狀態，避免 Token 膨脹。
[localBullObTop, localBullObBottom] = f_nearestBoxBelow(bullOrderBlocks, close)
[localBullFvgTop, localBullFvgBottom] = f_nearestBoxBelow(bullFvgs, close)
[localSupportTop, localSupportBottom] = f_nearestBoxBelow(supportZones, close)
[localBearObTop, localBearObBottom] = f_nearestBoxAbove(bearOrderBlocks, close)
[localBearFvgTop, localBearFvgBottom] = f_nearestBoxAbove(bearFvgs, close)
[localResistanceTop, localResistanceBottom] = f_nearestBoxAbove(resistanceZones, close)


// 步驟 8｜1H 持倉離場區：自動模式使用 1H 支撐／阻力 TP1～TP4；手動模式只讀取手動 TP 價格。
string positionSelectedTpName = positionManualTpMode ? "手動 TP" : positionPlannedTpInput
string positionPlannedTpPanelText = positionManualTpMode ? (positionManualTpValid ? "手動 TP｜離場點 " + str.tostring(positionManualTpPriceInput, format.mintick) : "手動 TP｜請輸入正確方向且大於 0 的價格") : positionPlannedTpNumber == 0 ? "不指定｜僅顯示 TP，不自動結束持倉" : not coachOn1h ? positionPlannedTpInput + "｜請切到 1H 鎖定區域" : positionSelectedTpValid ? positionPlannedTpInput + "｜" + f_exitZoneTypeText(positionRequestedDirection, positionSelectedTpType) + "｜區域中線 " + str.tostring(positionSelectedTpExitPrice, format.mintick) : positionPlannedTpInput + "｜目前只有 " + str.tostring(positionTpCount) + " 個有效 TP"
string positionTpCountText = not positionRequestedHasValidEntry ? "請先設定持倉方向與進場價格" : positionManualTpMode ? (positionManualTpValid ? "手動 TP 已設定｜" + str.tostring(positionManualTpPriceInput, format.mintick) : "手動 TP 價格無效或方向錯誤") : not coachOn1h ? "請切換到 1H 查看" : positionTpCount > 0 ? "已鎖定 " + str.tostring(positionTpCount) + " 個 1H " + (positionRequestedDirection == -1 ? "支撐區" : "阻力區") + " TP" + (not na(positionRiskDistance) and positionRiskDistance > 0 ? "｜已可計算盈虧比" : "｜等待 SL 區") : "進場方向前方尚無有效 1H " + (positionRequestedDirection == -1 ? "支撐區" : "阻力區")
string positionExitCoachText = positionTradeClosed ? (positionTradeClosedTp == -1 ? "已觸碰 SL｜離場點 " + str.tostring(positionTradeClosedPrice, format.mintick) + "｜停損出場｜有效持倉已切換無持倉" : "已觸碰 " + (positionTradeClosedTp == 0 ? "手動 TP" : "TP" + str.tostring(positionTradeClosedTp)) + "｜離場點 " + str.tostring(positionTradeClosedPrice, format.mintick) + "｜出場獲利｜有效持倉已切換無持倉") : not positionRequestedHasValidEntry ? "無持倉｜步驟 8 尚未啟動" : positionManualTpMode ? (positionManualTpValid ? "手動 TP｜等待 1H 觸碰 " + str.tostring(positionManualTpPriceInput, format.mintick) : "手動 TP｜請輸入正確方向的價格") : not coachOn1h ? "步驟 8 已啟動｜請切到 1H 查看 TP1～TP4、SL 區與盈虧比倉位圖" : positionTpCount > 0 ? "依距離由近到遠管理 TP1～TP" + str.tostring(positionTpCount) + (positionPlannedTpNumber > 0 ? "｜預計於 " + positionPlannedTpInput + " 出場" : "｜尚未指定自動出場 TP") + (not na(positionSelectedStopPrice) ? "｜SL " + str.tostring(positionSelectedStopPrice, format.mintick) : "｜等待 SL 區") : "目前尚無符合方向的 1H 支撐／阻力離場區"

// 15M 結構轉變、結構突破與回踩／回測的實際價格文字。
int latestBullTurnBar = ta.valuewhen(bullishChoch, bar_index, 0)
int latestBearTurnBar = ta.valuewhen(bearishChoch, bar_index, 0)
int latestBullBreakBar = ta.valuewhen(bullishBos, bar_index, 0)
int latestBearBreakBar = ta.valuewhen(bearishBos, bar_index, 0)
float latestBullTurnPrice = ta.valuewhen(bullishChoch, lastSwingHigh, 0)
float latestBearTurnPrice = ta.valuewhen(bearishChoch, lastSwingLow, 0)
float latestBullBreakPrice = ta.valuewhen(bullishBos, lastSwingHigh, 0)
float latestBearBreakPrice = ta.valuewhen(bearishBos, lastSwingLow, 0)
string bullTurnTriggerText = na(lastSwingHigh) ? "15M 結構轉多｜等待結構高點形成" : "15M 結構轉多｜收盤突破 " + str.tostring(lastSwingHigh, format.mintick)
string bearTurnTriggerText = na(lastSwingLow) ? "15M 結構轉空｜等待結構低點形成" : "15M 結構轉空｜收盤跌破 " + str.tostring(lastSwingLow, format.mintick)
string bullBreakTriggerText = na(lastSwingHigh) or swingHighBroken ? "15M 多方結構突破｜等待新的結構高點" : "15M 多方結構突破｜收盤突破 " + str.tostring(lastSwingHigh, format.mintick)
string bearBreakTriggerText = na(lastSwingLow) or swingLowBroken ? "15M 空方結構突破｜等待新的結構低點" : "15M 空方結構突破｜收盤跌破 " + str.tostring(lastSwingLow, format.mintick)
bool useLocalBullOb = not na(localBullObTop) and not na(localBullObBottom) and (na(localBullFvgTop) or math.abs(close - (localBullObTop + localBullObBottom) / 2.0) <= math.abs(close - (localBullFvgTop + localBullFvgBottom) / 2.0))
bool useLocalBearOb = not na(localBearObTop) and not na(localBearObBottom) and (na(localBearFvgTop) or math.abs(close - (localBearObTop + localBearObBottom) / 2.0) <= math.abs(close - (localBearFvgTop + localBearFvgBottom) / 2.0))

// 步驟 6 候選區：步驟 5 完成後立即預覽；真正回踩／回測完成後才鎖定為步驟 6。
float coachStep6LongCandidateTop = useLocalBullOb ? localBullObTop : localBullFvgTop
float coachStep6LongCandidateBottom = useLocalBullOb ? localBullObBottom : localBullFvgBottom
string coachStep6LongCandidateName = useLocalBullOb ? "15M 多方訂單區" : not na(localBullFvgTop) and not na(localBullFvgBottom) ? "15M 多方缺口" : ""
float coachStep6ShortCandidateTop = useLocalBearOb ? localBearObTop : localBearFvgTop
float coachStep6ShortCandidateBottom = useLocalBearOb ? localBearObBottom : localBearFvgBottom
string coachStep6ShortCandidateName = useLocalBearOb ? "15M 空方訂單區" : not na(localBearFvgTop) and not na(localBearFvgBottom) ? "15M 空方缺口" : ""

string localBullRetestText = str.length(coachStep6LongCandidateName) > 0 ? (coachTouchTriggersEntry ? "步驟 6｜多單掛單區 " + f_priceRangeText(coachStep6LongCandidateTop, coachStep6LongCandidateBottom) + "｜來源：" + coachStep6LongCandidateName + "｜等待盤中價格觸碰；觸碰即完成步驟 6 並進入步驟 7" : "步驟 6｜多單掛單＋反應 K 區域 " + f_priceRangeText(coachStep6LongCandidateTop, coachStep6LongCandidateBottom) + "｜來源：" + coachStep6LongCandidateName + "｜等待價格回踩並確認多方反應 K") : "步驟 6｜等待新的 15M 多方訂單區／多方缺口形成｜目前沒有可用的多單掛單區"
string localBearRetestText = str.length(coachStep6ShortCandidateName) > 0 ? (coachTouchTriggersEntry ? "步驟 6｜空單掛單區 " + f_priceRangeText(coachStep6ShortCandidateTop, coachStep6ShortCandidateBottom) + "｜來源：" + coachStep6ShortCandidateName + "｜等待盤中價格觸碰；觸碰即完成步驟 6 並進入步驟 7" : "步驟 6｜空單掛單＋反應 K 區域 " + f_priceRangeText(coachStep6ShortCandidateTop, coachStep6ShortCandidateBottom) + "｜來源：" + coachStep6ShortCandidateName + "｜等待價格回測並確認空方反應 K") : "步驟 6｜等待新的 15M 空方訂單區／空方缺口形成｜目前沒有可用的空單掛單區"

f_refreshPrecisionZoneLife() =>
    array<float> tops = array.from(coach1hBullObTop, coach1hBullFvgTop, coach1hSupportTop, coach4hBullObTop, coach4hBullFvgTop, coach4hSupportTop, localBullObTop, localBullFvgTop, localSupportTop, coach1hBearObTop, coach1hBearFvgTop, coach1hResistanceTop, coach4hBearObTop, coach4hBearFvgTop, coach4hResistanceTop, localBearObTop, localBearFvgTop, localResistanceTop)
    array<float> bottoms = array.from(coach1hBullObBottom, coach1hBullFvgBottom, coach1hSupportBottom, coach4hBullObBottom, coach4hBullFvgBottom, coach4hSupportBottom, localBullObBottom, localBullFvgBottom, localSupportBottom, coach1hBearObBottom, coach1hBearFvgBottom, coach1hResistanceBottom, coach4hBearObBottom, coach4hBearFvgBottom, coach4hResistanceBottom, localBearObBottom, localBearFvgBottom, localResistanceBottom)
    f_updatePrecisionZoneLife(tops, bottoms)

f_refreshPrecisionZoneLife()

// 多方高週期區域生命週期判斷：OB 優先、FVG 次之、支撐最後備援。
bool coachAnyBullZoneTouch = f_precisionZoneEntry(0) or f_precisionZoneEntry(3) or f_precisionZoneEntry(1) or f_precisionZoneEntry(4) or (useSRLogic and (f_precisionZoneEntry(2) or f_precisionZoneEntry(5)))
string coachBullZoneName = f_precisionZoneEntry(0) ? "1H 多方訂單區" : f_precisionZoneEntry(3) ? "4H 多方訂單區" : f_precisionZoneEntry(1) ? "1H 多方缺口" : f_precisionZoneEntry(4) ? "4H 多方缺口" : useSRLogic and f_precisionZoneEntry(2) ? "1H 支撐區" : useSRLogic and f_precisionZoneEntry(5) ? "4H 支撐區" : "尚未進入有效區域"
float coachBullZoneTop = f_precisionZoneEntry(0) ? coach1hBullObTop : f_precisionZoneEntry(3) ? coach4hBullObTop : f_precisionZoneEntry(1) ? coach1hBullFvgTop : f_precisionZoneEntry(4) ? coach4hBullFvgTop : useSRLogic and f_precisionZoneEntry(2) ? coach1hSupportTop : useSRLogic and f_precisionZoneEntry(5) ? coach4hSupportTop : na
float coachBullZoneBottom = f_precisionZoneEntry(0) ? coach1hBullObBottom : f_precisionZoneEntry(3) ? coach4hBullObBottom : f_precisionZoneEntry(1) ? coach1hBullFvgBottom : f_precisionZoneEntry(4) ? coach4hBullFvgBottom : useSRLogic and f_precisionZoneEntry(2) ? coach1hSupportBottom : useSRLogic and f_precisionZoneEntry(5) ? coach4hSupportBottom : na

// 空方高週期區域生命週期判斷：OB 優先、FVG 次之、阻力最後備援。
bool coachAnyBearZoneTouch = f_precisionZoneEntry(9) or f_precisionZoneEntry(12) or f_precisionZoneEntry(10) or f_precisionZoneEntry(13) or (useSRLogic and (f_precisionZoneEntry(11) or f_precisionZoneEntry(14)))
string coachBearZoneName = f_precisionZoneEntry(9) ? "1H 空方訂單區" : f_precisionZoneEntry(12) ? "4H 空方訂單區" : f_precisionZoneEntry(10) ? "1H 空方缺口" : f_precisionZoneEntry(13) ? "4H 空方缺口" : useSRLogic and f_precisionZoneEntry(11) ? "1H 阻力區" : useSRLogic and f_precisionZoneEntry(14) ? "4H 阻力區" : "尚未進入有效區域"
float coachBearZoneTop = f_precisionZoneEntry(9) ? coach1hBearObTop : f_precisionZoneEntry(12) ? coach4hBearObTop : f_precisionZoneEntry(10) ? coach1hBearFvgTop : f_precisionZoneEntry(13) ? coach4hBearFvgTop : useSRLogic and f_precisionZoneEntry(11) ? coach1hResistanceTop : useSRLogic and f_precisionZoneEntry(14) ? coach4hResistanceTop : na
float coachBearZoneBottom = f_precisionZoneEntry(9) ? coach1hBearObBottom : f_precisionZoneEntry(12) ? coach4hBearObBottom : f_precisionZoneEntry(10) ? coach1hBearFvgBottom : f_precisionZoneEntry(13) ? coach4hBearFvgBottom : useSRLogic and f_precisionZoneEntry(11) ? coach1hResistanceBottom : useSRLogic and f_precisionZoneEntry(14) ? coach4hResistanceBottom : na

bool coachLongBiasCore = switch coachBiasRule
    "4H 與 1H 同方向" => coachTrend4h == 1 and coachTrend1h == 1
    "4H 或 1H 任一方向" => coachTrend4h == 1 or coachTrend1h == 1
    => coachTrend4h == 1

bool coachShortBiasCore = switch coachBiasRule
    "4H 與 1H 同方向" => coachTrend4h == -1 and coachTrend1h == -1
    "4H 或 1H 任一方向" => coachTrend4h == -1 or coachTrend1h == -1
    => coachTrend4h == -1

bool coachLongBiasPassed = coachLongBiasCore
bool coachShortBiasPassed = coachShortBiasCore
bool coachStrictAlignment = coachBiasRule == "4H 與 1H 同方向"
bool coachTrendConflict = coachStrictAlignment and coachTrend4h != 0 and coachTrend1h != 0 and coachTrend4h != coachTrend1h

int coachSelectedDirection = 0
if coachTfConfigValid
    coachSelectedDirection := switch coachMode
        "只顯示多單" => 1
        "只顯示空單" => -1
        => coachLongBiasPassed ? 1 : coachShortBiasPassed ? -1 : 0

bool coachAllowLong = coachTfConfigValid and coachSelectedDirection == 1
bool coachAllowShort = coachTfConfigValid and coachSelectedDirection == -1
// 進場教練只依多週期方向規則運作。
bool coachProcessLong = showCoach and coachAllowLong
bool coachProcessShort = showCoach and coachAllowShort

// --------------------------------------------------------------------------
// 多單流程狀態
// 步驟 4／5 使用本次 Setup 的局部結構；預設模式下，步驟 6 於盤中觸碰掛單區時完成並立即進入步驟 7；選配模式才等待 15M 反應 K 收盤確認。
// --------------------------------------------------------------------------
varip int coachLongStage = 0
varip int coachLongStageStartBar = na
varip int coachLongSweepBar = na
varip int coachLongTurnBar = na
varip int coachLongTurnTriggerBar = na
varip int coachLongBosTriggerSetBar = na
varip int coachLongBosBar = na
varip float coachLongSweepLow = na
varip float coachLongIdmPrice = na
varip int coachLongIdmSourceBar = na
varip float coachLongTurnTriggerPrice = na
varip float coachLongBosCandidatePrice = na
varip float coachLongBosTriggerPrice = na
varip float coachLongPullbackTop = na
varip float coachLongPullbackBottom = na
varip float coachLongReactionTriggerPrice = na
varip string coachLongEntryZone = ""
varip string coachLongEnteredHtfZone = ""
varip float coachLongEnteredZoneTop = na
varip float coachLongEnteredZoneBottom = na
varip int coachLongLastAlertedStage = 0

varip string coachLongInvalidText = ""

bool coachLongPositionManaged = coachLongStage >= 7 and positionRequestedHasValidEntry and positionRequestedDirection == 1 and not positionTradeClosed
bool coachLongExpired = coachLongStage > 0 and coachLongStage < 7 and not na(coachLongStageStartBar) and bar_index - coachLongStageStartBar > coachMaxWaitBars
int coachLongGlobalInvalidCode = not coachLongPositionManaged and coachLongStage > 0 ? (coachLongExpired ? 2 : ((not coachProcessLong or coachTrend4h == -1 or bearishChoch or bearishBos) ? 1 : 0)) : 0
float coachLongHtfInvalidEdge = f_zoneLowerEdge(coachLongEnteredZoneTop, coachLongEnteredZoneBottom)
float coachLongEntryInvalidEdge = f_zoneLowerEdge(coachLongPullbackTop, coachLongPullbackBottom)
int coachLongPathInvalidCode = coachOn15m and not coachLongPositionManaged ? f_pathInvalidCode(coachLongStage, 1, coachLongHtfInvalidEdge, coachLongSweepLow, coachLongEntryInvalidEdge) : 0
bool coachLongInvalidatedNow = coachLongGlobalInvalidCode > 0 or coachLongPathInvalidCode > 0

if coachLongInvalidatedNow
    int failedStage = coachLongStage
    int invalidCode = coachLongGlobalInvalidCode > 0 ? coachLongGlobalInvalidCode : coachLongPathInvalidCode
    int returnStage = invalidCode <= 2 ? 0 : invalidCode == 3 ? 1 : invalidCode == 4 ? 2 : 5
    float invalidPrice = invalidCode == 3 ? coachLongHtfInvalidEdge : invalidCode == 4 ? coachLongSweepLow : invalidCode == 5 ? coachLongEntryInvalidEdge : na
    coachLongInvalidText := f_pathInvalidText(1, failedStage, invalidCode, invalidPrice)
    coachLongStage := returnStage
    coachLongStageStartBar := returnStage == 0 ? na : bar_index
    coachLongLastAlertedStage := returnStage
    if returnStage <= 1
        coachLongEnteredHtfZone := ""
        coachLongEnteredZoneTop := na
        coachLongEnteredZoneBottom := na
    if returnStage <= 2
        coachLongSweepBar := na
        coachLongTurnBar := na
        coachLongTurnTriggerBar := na
        coachLongBosTriggerSetBar := na
        coachLongBosBar := na
        coachLongSweepLow := na
        coachLongIdmPrice := na
        coachLongIdmSourceBar := na
        coachLongTurnTriggerPrice := na
        coachLongBosCandidatePrice := na
        coachLongBosTriggerPrice := na
    if returnStage <= 5
        coachLongPullbackTop := na
        coachLongPullbackBottom := na
        coachLongReactionTriggerPrice := na
        coachLongEntryZone := ""

int coachLongStageBeforeProgress = coachLongStage
if coachOn15m and coachProcessLong and not coachLongInvalidatedNow
    if coachLongStage == 0 and coachLongBiasPassed
        coachLongStage := 1
        coachLongStageStartBar := bar_index

    if coachLongStage <= 1 and coachLongBiasPassed and coachAnyBullZoneTouch
        coachLongStage := 2
        coachLongEnteredHtfZone := coachBullZoneName + " " + f_priceRangeText(coachBullZoneTop, coachBullZoneBottom)
        coachLongEnteredZoneTop := coachBullZoneTop
        coachLongEnteredZoneBottom := coachBullZoneBottom

    if coachLongStage == 2 and bullishSweep
        coachLongStage := 3
        coachLongSweepBar := bar_index
        coachLongSweepLow := low
        coachLongIdmPrice := lastSwingLow
        coachLongIdmSourceBar := lastSwingLowBar
        coachLongTurnTriggerPrice := lastSwingHigh
        coachLongTurnTriggerBar := not na(lastSwingHighBar) ? lastSwingHighBar : f_findRecentStructureBar(lastSwingHigh, true)
        coachLongTurnBar := na
        coachLongBosTriggerSetBar := na
        coachLongBosCandidatePrice := na
        coachLongBosTriggerPrice := na
        coachLongReactionTriggerPrice := na

    if coachLongStage == 3 and na(coachLongTurnTriggerPrice) and not na(lastSwingHigh)
        coachLongTurnTriggerPrice := lastSwingHigh
        coachLongTurnTriggerBar := not na(lastSwingHighBar) ? lastSwingHighBar : f_findRecentStructureBar(lastSwingHigh, true)

    bool coachLongLocalTurnNow = coachLongStage == 3 and barstate.isconfirmed and not na(coachLongSweepBar) and bar_index > coachLongSweepBar and not na(coachLongTurnTriggerPrice) and close > coachLongTurnTriggerPrice
    if coachLongLocalTurnNow
        coachLongStage := 4
        coachLongTurnBar := bar_index
        coachLongBosCandidatePrice := high
        int coachLongMssSourceBar = not na(coachLongTurnTriggerBar) ? coachLongTurnTriggerBar : f_findRecentStructureBar(coachLongTurnTriggerPrice, true)
        coachLongTurnTriggerBar := coachLongMssSourceBar
        if showMssGuide and showCoachStepGuideLines and not na(coachLongMssSourceBar) and not na(coachLongTurnTriggerPrice)
            f_removeStructureEventAtPrice(structureLines, structureLabels, coachLongTurnTriggerPrice)
            f_removeStructureEventAtPrice(eqhLines, eqhLabels, coachLongTurnTriggerPrice)
            f_removeStructureEventAtPrice(eqlLines, eqlLabels, coachLongTurnTriggerPrice)
            f_removeStructureEventAtPrice(idmLines, idmLabels, coachLongTurnTriggerPrice)
            string longMssTooltip = f_mssTooltip(true, coachLongTurnTriggerPrice, coachLongMssSourceBar, bar_index, "15M 收盤站上確認價｜多方 MSS 完成｜進入步驟 5 BOS")
            f_addHorizontalStructureEvent(mssLines, mssLabels, coachLongMssSourceBar, bar_index, coachLongTurnTriggerPrice, "MSS", color.new(color.rgb(171, 71, 188), coachStepGuideLineTransparency), longMssTooltip, maxMssGroups)
        bool longIdmDistinct = showIdmGuide and showCoachStepGuideLines and not na(coachLongIdmPrice) and not na(coachLongIdmSourceBar) and not f_sameMarkedPrice(coachLongIdmPrice, coachLongTurnTriggerPrice) and not f_hasStructureEventAtPrice(structureLines, coachLongIdmPrice) and not f_hasStructureEventAtPrice(mssLines, coachLongIdmPrice) and not f_hasStructureEventAtPrice(eqhLines, coachLongIdmPrice) and not f_hasStructureEventAtPrice(eqlLines, coachLongIdmPrice)
        if longIdmDistinct
            string longIdmTooltip = "IDM｜誘導流動性\n時間軸：15M\n方向：多方進場流程\nIDM 價格：" + str.tostring(coachLongIdmPrice, format.mintick) + "\n成立條件：步驟 3 掃過此已確認 Pivot，之後 15M 收盤完成多方 MSS。\n完成事件：此價位確認為本次 Setup 的誘導流動性；不是單獨進場訊號。"
            f_addHorizontalStructureEvent(idmLines, idmLabels, coachLongIdmSourceBar, bar_index, coachLongIdmPrice, "IDM", color.new(bullishRoleColor, coachStepGuideLineTransparency), longIdmTooltip, maxIdmGroups)

    if coachLongStage == 4 and not na(coachLongTurnBar) and bar_index >= coachLongTurnBar
        coachLongBosCandidatePrice := na(coachLongBosCandidatePrice) ? high : math.max(coachLongBosCandidatePrice, high)
    int coachLongPivotBarNow = not na(structureHighPivot) ? bar_index - structureLen : na
    if coachLongStage == 4 and na(coachLongBosTriggerPrice) and not na(coachLongTurnBar) and not na(coachLongPivotBarNow) and coachLongPivotBarNow >= coachLongTurnBar
        coachLongBosTriggerPrice := structureHighPivot
        coachLongBosCandidatePrice := structureHighPivot
        coachLongBosTriggerSetBar := bar_index

    bool coachLongLocalBosNow = coachLongStage == 4 and barstate.isconfirmed and not na(coachLongBosTriggerPrice) and not na(coachLongBosTriggerSetBar) and bar_index > coachLongBosTriggerSetBar and close > coachLongBosTriggerPrice
    if coachLongLocalBosNow
        coachLongStage := 5
        coachLongBosBar := bar_index

    bool coachLongObPullbackNow = coachLongStage == 5 and not na(coachLongBosBar) and bar_index > coachLongBosBar and not na(coachBullObCreatedBar) and coachBullObCreatedBar >= coachLongBosBar and f_priceTouches(coachBullObTop, coachBullObBottom)
    bool coachLongFvgPullbackNow = coachLongStage == 5 and not na(coachLongBosBar) and bar_index > coachLongBosBar and not na(coachBullFvgCreatedBar) and coachBullFvgCreatedBar >= coachLongBosBar and f_priceTouches(coachBullFvgTop, coachBullFvgBottom)

    if coachLongObPullbackNow or coachLongFvgPullbackNow
        coachLongStage := 6
        coachLongPullbackTop := coachLongObPullbackNow ? coachBullObTop : coachBullFvgTop
        coachLongPullbackBottom := coachLongObPullbackNow ? coachBullObBottom : coachBullFvgBottom
        coachLongEntryZone := coachLongObPullbackNow ? "多方訂單區" : "多方缺口"
        // 多單由區域上方往下接觸，掛單近端邊界採區域上緣。
        coachLongReactionTriggerPrice := coachTouchTriggersEntry ? f_zoneUpperEdge(coachLongPullbackTop, coachLongPullbackBottom) : na
        if coachTouchTriggersEntry
            coachLongStage := 7

    float coachLongReactionLevel = not na(coachLongPullbackTop) and not na(coachLongPullbackBottom) ? (coachLongPullbackTop + coachLongPullbackBottom) / 2.0 : na
    bool coachBullReaction = not coachTouchTriggersEntry and coachLongStage == 6 and barstate.isconfirmed and not na(coachLongReactionLevel) and close > open and close > coachLongReactionLevel
    if coachBullReaction
        coachLongReactionTriggerPrice := close
        coachLongStage := 7

if not coachLongInvalidatedNow and coachLongStage > coachLongStageBeforeProgress
    coachLongInvalidText := ""

// --------------------------------------------------------------------------
// 空單流程狀態
// 步驟 4／5 使用本次 Setup 的局部結構；預設模式下，步驟 6 於盤中觸碰掛單區時完成並立即進入步驟 7；選配模式才等待 15M 反應 K 收盤確認。
// --------------------------------------------------------------------------
varip int coachShortStage = 0
varip int coachShortStageStartBar = na
varip int coachShortSweepBar = na
varip int coachShortTurnBar = na
varip int coachShortTurnTriggerBar = na
varip int coachShortBosTriggerSetBar = na
varip int coachShortBosBar = na
varip float coachShortSweepHigh = na
varip float coachShortIdmPrice = na
varip int coachShortIdmSourceBar = na
varip float coachShortTurnTriggerPrice = na
varip float coachShortBosCandidatePrice = na
varip float coachShortBosTriggerPrice = na
varip float coachShortPullbackTop = na
varip float coachShortPullbackBottom = na
varip float coachShortReactionTriggerPrice = na
varip string coachShortEntryZone = ""
varip string coachShortEnteredHtfZone = ""
varip float coachShortEnteredZoneTop = na
varip float coachShortEnteredZoneBottom = na
varip int coachShortLastAlertedStage = 0

varip string coachShortInvalidText = ""

bool coachShortPositionManaged = coachShortStage >= 7 and positionRequestedHasValidEntry and positionRequestedDirection == -1 and not positionTradeClosed
bool coachShortExpired = coachShortStage > 0 and coachShortStage < 7 and not na(coachShortStageStartBar) and bar_index - coachShortStageStartBar > coachMaxWaitBars
int coachShortGlobalInvalidCode = not coachShortPositionManaged and coachShortStage > 0 ? (coachShortExpired ? 2 : ((not coachProcessShort or coachTrend4h == 1 or bullishChoch or bullishBos) ? 1 : 0)) : 0
float coachShortHtfInvalidEdge = f_zoneUpperEdge(coachShortEnteredZoneTop, coachShortEnteredZoneBottom)
float coachShortEntryInvalidEdge = f_zoneUpperEdge(coachShortPullbackTop, coachShortPullbackBottom)
int coachShortPathInvalidCode = coachOn15m and not coachShortPositionManaged ? f_pathInvalidCode(coachShortStage, -1, coachShortHtfInvalidEdge, coachShortSweepHigh, coachShortEntryInvalidEdge) : 0
bool coachShortInvalidatedNow = coachShortGlobalInvalidCode > 0 or coachShortPathInvalidCode > 0

if coachShortInvalidatedNow
    int failedStage = coachShortStage
    int invalidCode = coachShortGlobalInvalidCode > 0 ? coachShortGlobalInvalidCode : coachShortPathInvalidCode
    int returnStage = invalidCode <= 2 ? 0 : invalidCode == 3 ? 1 : invalidCode == 4 ? 2 : 5
    float invalidPrice = invalidCode == 3 ? coachShortHtfInvalidEdge : invalidCode == 4 ? coachShortSweepHigh : invalidCode == 5 ? coachShortEntryInvalidEdge : na
    coachShortInvalidText := f_pathInvalidText(-1, failedStage, invalidCode, invalidPrice)
    coachShortStage := returnStage
    coachShortStageStartBar := returnStage == 0 ? na : bar_index
    coachShortLastAlertedStage := returnStage
    if returnStage <= 1
        coachShortEnteredHtfZone := ""
        coachShortEnteredZoneTop := na
        coachShortEnteredZoneBottom := na
    if returnStage <= 2
        coachShortSweepBar := na
        coachShortTurnBar := na
        coachShortTurnTriggerBar := na
        coachShortBosTriggerSetBar := na
        coachShortBosBar := na
        coachShortSweepHigh := na
        coachShortIdmPrice := na
        coachShortIdmSourceBar := na
        coachShortTurnTriggerPrice := na
        coachShortBosCandidatePrice := na
        coachShortBosTriggerPrice := na
    if returnStage <= 5
        coachShortPullbackTop := na
        coachShortPullbackBottom := na
        coachShortReactionTriggerPrice := na
        coachShortEntryZone := ""

int coachShortStageBeforeProgress = coachShortStage
if coachOn15m and coachProcessShort and not coachShortInvalidatedNow
    if coachShortStage == 0 and coachShortBiasPassed
        coachShortStage := 1
        coachShortStageStartBar := bar_index

    if coachShortStage <= 1 and coachShortBiasPassed and coachAnyBearZoneTouch
        coachShortStage := 2
        coachShortEnteredHtfZone := coachBearZoneName + " " + f_priceRangeText(coachBearZoneTop, coachBearZoneBottom)
        coachShortEnteredZoneTop := coachBearZoneTop
        coachShortEnteredZoneBottom := coachBearZoneBottom

    if coachShortStage == 2 and bearishSweep
        coachShortStage := 3
        coachShortSweepBar := bar_index
        coachShortSweepHigh := high
        coachShortIdmPrice := lastSwingHigh
        coachShortIdmSourceBar := lastSwingHighBar
        coachShortTurnTriggerPrice := lastSwingLow
        coachShortTurnTriggerBar := not na(lastSwingLowBar) ? lastSwingLowBar : f_findRecentStructureBar(lastSwingLow, false)
        coachShortTurnBar := na
        coachShortBosTriggerSetBar := na
        coachShortBosCandidatePrice := na
        coachShortBosTriggerPrice := na
        coachShortReactionTriggerPrice := na

    if coachShortStage == 3 and na(coachShortTurnTriggerPrice) and not na(lastSwingLow)
        coachShortTurnTriggerPrice := lastSwingLow
        coachShortTurnTriggerBar := not na(lastSwingLowBar) ? lastSwingLowBar : f_findRecentStructureBar(lastSwingLow, false)

    bool coachShortLocalTurnNow = coachShortStage == 3 and barstate.isconfirmed and not na(coachShortSweepBar) and bar_index > coachShortSweepBar and not na(coachShortTurnTriggerPrice) and close < coachShortTurnTriggerPrice
    if coachShortLocalTurnNow
        coachShortStage := 4
        coachShortTurnBar := bar_index
        coachShortBosCandidatePrice := low
        int coachShortMssSourceBar = not na(coachShortTurnTriggerBar) ? coachShortTurnTriggerBar : f_findRecentStructureBar(coachShortTurnTriggerPrice, false)
        coachShortTurnTriggerBar := coachShortMssSourceBar
        if showMssGuide and showCoachStepGuideLines and not na(coachShortMssSourceBar) and not na(coachShortTurnTriggerPrice)
            f_removeStructureEventAtPrice(structureLines, structureLabels, coachShortTurnTriggerPrice)
            f_removeStructureEventAtPrice(eqhLines, eqhLabels, coachShortTurnTriggerPrice)
            f_removeStructureEventAtPrice(eqlLines, eqlLabels, coachShortTurnTriggerPrice)
            f_removeStructureEventAtPrice(idmLines, idmLabels, coachShortTurnTriggerPrice)
            string shortMssTooltip = f_mssTooltip(false, coachShortTurnTriggerPrice, coachShortMssSourceBar, bar_index, "15M 收盤跌破確認價｜空方 MSS 完成｜進入步驟 5 BOS")
            f_addHorizontalStructureEvent(mssLines, mssLabels, coachShortMssSourceBar, bar_index, coachShortTurnTriggerPrice, "MSS", color.new(color.rgb(171, 71, 188), coachStepGuideLineTransparency), shortMssTooltip, maxMssGroups)
        bool shortIdmDistinct = showIdmGuide and showCoachStepGuideLines and not na(coachShortIdmPrice) and not na(coachShortIdmSourceBar) and not f_sameMarkedPrice(coachShortIdmPrice, coachShortTurnTriggerPrice) and not f_hasStructureEventAtPrice(structureLines, coachShortIdmPrice) and not f_hasStructureEventAtPrice(mssLines, coachShortIdmPrice) and not f_hasStructureEventAtPrice(eqhLines, coachShortIdmPrice) and not f_hasStructureEventAtPrice(eqlLines, coachShortIdmPrice)
        if shortIdmDistinct
            string shortIdmTooltip = "IDM｜誘導流動性\n時間軸：15M\n方向：空方進場流程\nIDM 價格：" + str.tostring(coachShortIdmPrice, format.mintick) + "\n成立條件：步驟 3 掃過此已確認 Pivot，之後 15M 收盤完成空方 MSS。\n完成事件：此價位確認為本次 Setup 的誘導流動性；不是單獨進場訊號。"
            f_addHorizontalStructureEvent(idmLines, idmLabels, coachShortIdmSourceBar, bar_index, coachShortIdmPrice, "IDM", color.new(bearishRoleColor, coachStepGuideLineTransparency), shortIdmTooltip, maxIdmGroups)

    if coachShortStage == 4 and not na(coachShortTurnBar) and bar_index >= coachShortTurnBar
        coachShortBosCandidatePrice := na(coachShortBosCandidatePrice) ? low : math.min(coachShortBosCandidatePrice, low)
    int coachShortPivotBarNow = not na(structureLowPivot) ? bar_index - structureLen : na
    if coachShortStage == 4 and na(coachShortBosTriggerPrice) and not na(coachShortTurnBar) and not na(coachShortPivotBarNow) and coachShortPivotBarNow >= coachShortTurnBar
        coachShortBosTriggerPrice := structureLowPivot
        coachShortBosCandidatePrice := structureLowPivot
        coachShortBosTriggerSetBar := bar_index

    bool coachShortLocalBosNow = coachShortStage == 4 and barstate.isconfirmed and not na(coachShortBosTriggerPrice) and not na(coachShortBosTriggerSetBar) and bar_index > coachShortBosTriggerSetBar and close < coachShortBosTriggerPrice
    if coachShortLocalBosNow
        coachShortStage := 5
        coachShortBosBar := bar_index

    bool coachShortObPullbackNow = coachShortStage == 5 and not na(coachShortBosBar) and bar_index > coachShortBosBar and not na(coachBearObCreatedBar) and coachBearObCreatedBar >= coachShortBosBar and f_priceTouches(coachBearObTop, coachBearObBottom)
    bool coachShortFvgPullbackNow = coachShortStage == 5 and not na(coachShortBosBar) and bar_index > coachShortBosBar and not na(coachBearFvgCreatedBar) and coachBearFvgCreatedBar >= coachShortBosBar and f_priceTouches(coachBearFvgTop, coachBearFvgBottom)

    if coachShortObPullbackNow or coachShortFvgPullbackNow
        coachShortStage := 6
        coachShortPullbackTop := coachShortObPullbackNow ? coachBearObTop : coachBearFvgTop
        coachShortPullbackBottom := coachShortObPullbackNow ? coachBearObBottom : coachBearFvgBottom
        coachShortEntryZone := coachShortObPullbackNow ? "空方訂單區" : "空方缺口"
        // 空單由區域下方往上接觸，掛單近端邊界採區域下緣。
        coachShortReactionTriggerPrice := coachTouchTriggersEntry ? f_zoneLowerEdge(coachShortPullbackTop, coachShortPullbackBottom) : na
        if coachTouchTriggersEntry
            coachShortStage := 7

    float coachShortReactionLevel = not na(coachShortPullbackTop) and not na(coachShortPullbackBottom) ? (coachShortPullbackTop + coachShortPullbackBottom) / 2.0 : na
    bool coachBearReaction = not coachTouchTriggersEntry and coachShortStage == 6 and barstate.isconfirmed and not na(coachShortReactionLevel) and close < open and close < coachShortReactionLevel
    if coachBearReaction
        coachShortReactionTriggerPrice := close
        coachShortStage := 7

if not coachShortInvalidatedNow and coachShortStage > coachShortStageBeforeProgress
    coachShortInvalidText := ""

// 單一 alert()：15M 通知步驟前進、任何退回與步驟 8 啟動；1H 通知 TP／SL。
varip string coachLastStep8AlertKey = ""
string coachLongStepAlertMessage = coachLongInvalidatedNow ? syminfo.ticker + "｜15M｜多單｜" + coachLongInvalidText + "｜確認收盤 " + str.tostring(close, format.mintick) : f_buildCoachStepAlertMessage(coachLongLastAlertedStage, coachLongStage, 1)
string coachShortStepAlertMessage = coachShortInvalidatedNow ? syminfo.ticker + "｜15M｜空單｜" + coachShortInvalidText + "｜確認收盤 " + str.tostring(close, format.mintick) : f_buildCoachStepAlertMessage(coachShortLastAlertedStage, coachShortStage, -1)
bool coachHasLongStepAlert = coachOn15m and str.length(coachLongStepAlertMessage) > 0
bool coachHasShortStepAlert = coachOn15m and str.length(coachShortStepAlertMessage) > 0
string coachStep8AlertKey = positionRequestedHasValidEntry and not positionTradeClosed ? syminfo.tickerid + "|" + str.tostring(positionRequestedDirection) + "|" + str.tostring(positionEntryPriceInput, format.mintick) : ""
bool coachStep8Ready = barstate.islast and coachOn15m and str.length(coachStep8AlertKey) > 0 and coachStep8AlertKey != coachLastStep8AlertKey and (positionRequestedDirection == 1 ? coachLongStage >= 7 : coachShortStage >= 7)
string coachStep8AlertMessage = coachStep8Ready ? syminfo.ticker + "｜15M｜" + positionRequestedDirectionText + "｜步驟 8 啟動｜實際進場 " + str.tostring(positionEntryPriceInput, format.mintick) + "｜請切換 1H 管理 TP／SL" : ""
string coachExitAlertMessage = positionSelectedStopTouchedNow ? syminfo.ticker + "｜1H｜" + positionRequestedDirectionText + "｜步驟 8｜SL 觸碰｜停損價 " + str.tostring(positionSelectedStopPrice, format.mintick) : positionSelectedTpTouchedNow ? syminfo.ticker + "｜1H｜" + positionRequestedDirectionText + "｜步驟 8｜" + positionSelectedTpName + " 觸碰｜出場價 " + str.tostring(positionSelectedTpExitPrice, format.mintick) : ""
string coachAlertMessage = coachHasLongStepAlert and coachHasShortStepAlert ? coachLongStepAlertMessage + "\n\n" + coachShortStepAlertMessage : coachHasLongStepAlert ? coachLongStepAlertMessage : coachHasShortStepAlert ? coachShortStepAlertMessage : ""
coachAlertMessage += str.length(coachStep8AlertMessage) > 0 ? (str.length(coachAlertMessage) > 0 ? "\n\n" : "") + coachStep8AlertMessage : ""
coachAlertMessage += str.length(coachExitAlertMessage) > 0 ? (str.length(coachAlertMessage) > 0 ? "\n\n" : "") + coachExitAlertMessage : ""
if enableCoachStepAlerts and str.length(coachAlertMessage) > 0
    alert(coachAlertMessage, alert.freq_all)
    if coachHasLongStepAlert and not coachLongInvalidatedNow
        coachLongLastAlertedStage := coachLongStage
    if coachHasShortStepAlert and not coachShortInvalidatedNow
        coachShortLastAlertedStage := coachShortStage
    if coachStep8Ready
        coachLastStep8AlertKey := coachStep8AlertKey
if barstate.islast and not positionRequestedHasValidEntry
    coachLastStep8AlertKey := ""

// 步驟 6 管理掛單區觸發；預設盤中觸碰即完成步驟 6 並進入步驟 7。只有選配模式才等待反應 K 收盤確認。

// 15M 最近已確認結構事件文字，供進場教練面板使用。
string latestBullTurnDoneText = na(latestBullTurnPrice) ? "15M 結構轉多完成" : "15M 結構轉多完成｜突破 " + str.tostring(latestBullTurnPrice, format.mintick)
string latestBearTurnDoneText = na(latestBearTurnPrice) ? "15M 結構轉空完成" : "15M 結構轉空完成｜跌破 " + str.tostring(latestBearTurnPrice, format.mintick)
string latestBullBreakDoneText = na(latestBullBreakPrice) ? "15M 多方結構突破完成" : "15M 多方結構突破完成｜突破 " + str.tostring(latestBullBreakPrice, format.mintick)
string latestBearBreakDoneText = na(latestBearBreakPrice) ? "15M 空方結構突破完成" : "15M 空方結構突破完成｜跌破 " + str.tostring(latestBearBreakPrice, format.mintick)

string coachLongLocalTurnStatus = coachLongStage >= 4 and not na(coachLongTurnTriggerPrice) ? "15M 收盤已站上 " + str.tostring(coachLongTurnTriggerPrice, format.mintick) + "｜多方 MSS 確認完成" : not na(coachLongTurnTriggerPrice) ? "等待 15M 收盤站上 MSS 確認價 " + str.tostring(coachLongTurnTriggerPrice, format.mintick) : "完成前低 Sweep 後鎖定多方 MSS 確認價"
string coachShortLocalTurnStatus = coachShortStage >= 4 and not na(coachShortTurnTriggerPrice) ? "15M 收盤已跌破 " + str.tostring(coachShortTurnTriggerPrice, format.mintick) + "｜空方 MSS 確認完成" : not na(coachShortTurnTriggerPrice) ? "等待 15M 收盤跌破 MSS 確認價 " + str.tostring(coachShortTurnTriggerPrice, format.mintick) : "完成前高 Sweep 後鎖定空方 MSS 確認價"
string coachLongLocalBosStatus = coachLongStage >= 5 and not na(coachLongBosTriggerPrice) ? "15M 多方 BOS↑ 完成｜收盤突破 " + str.tostring(coachLongBosTriggerPrice, format.mintick) : not na(coachLongBosTriggerPrice) ? "等待 15M 收盤突破 BOS↑ 確認價 " + str.tostring(coachLongBosTriggerPrice, format.mintick) : not na(coachLongBosCandidatePrice) ? "多方延續高點候選 " + str.tostring(coachLongBosCandidatePrice, format.mintick) : "等待形成多方延續高點"
string coachShortLocalBosStatus = coachShortStage >= 5 and not na(coachShortBosTriggerPrice) ? "15M 空方 BOS↓ 完成｜收盤跌破 " + str.tostring(coachShortBosTriggerPrice, format.mintick) : not na(coachShortBosTriggerPrice) ? "等待 15M 收盤跌破 BOS↓ 確認價 " + str.tostring(coachShortBosTriggerPrice, format.mintick) : not na(coachShortBosCandidatePrice) ? "空方延續低點候選 " + str.tostring(coachShortBosCandidatePrice, format.mintick) : "等待形成空方延續低點"

string coachLongStageBaseText = switch coachLongStage
    0 => "等待大方向偏多"
    1 => "方向通過｜4H 主多｜等待進入 4H／1H 多方區"
    2 => "已進入 " + coachLongEnteredHtfZone + "｜等待 15M 掃過前低"
    3 => "前低已掃｜" + coachLongLocalTurnStatus
    4 => "局部轉多完成｜" + coachLongLocalBosStatus
    5 => "多方 BOS 延續完成｜等待回踩新形成的多方 OB／FVG"
    6 => f_reactionKStatus(1, coachLongEntryZone, coachLongPullbackTop, coachLongPullbackBottom, false, coachTouchTriggersEntry, coachLongReactionTriggerPrice)
    => f_reactionKStatus(1, coachLongEntryZone, coachLongPullbackTop, coachLongPullbackBottom, true, coachTouchTriggersEntry, coachLongReactionTriggerPrice) + "\n狀態持續保留"
string coachLongStageText = str.length(coachLongInvalidText) > 0 ? coachLongInvalidText : coachLongStageBaseText

string coachShortStageBaseText = switch coachShortStage
    0 => "等待大方向偏空"
    1 => "方向通過｜4H 主空｜等待進入 4H／1H 空方區"
    2 => "已進入 " + coachShortEnteredHtfZone + "｜等待 15M 掃過前高"
    3 => "前高已掃｜" + coachShortLocalTurnStatus
    4 => "局部轉空完成｜" + coachShortLocalBosStatus
    5 => "空方 BOS 延續完成｜等待回測新形成的空方 OB／FVG"
    6 => f_reactionKStatus(-1, coachShortEntryZone, coachShortPullbackTop, coachShortPullbackBottom, false, coachTouchTriggersEntry, coachShortReactionTriggerPrice)
    => f_reactionKStatus(-1, coachShortEntryZone, coachShortPullbackTop, coachShortPullbackBottom, true, coachTouchTriggersEntry, coachShortReactionTriggerPrice) + "\n狀態持續保留"
string coachShortStageText = str.length(coachShortInvalidText) > 0 ? coachShortInvalidText : coachShortStageBaseText

bool coachIsLongView = coachSelectedDirection == 1
bool coachIsShortView = coachSelectedDirection == -1
int coachActiveStage = coachIsLongView ? coachLongStage : coachIsShortView ? coachShortStage : 0

string coach4h1hStateText = "4H " + f_trendShort(coachTrend4h) + "｜1H " + f_trendShort(coachTrend1h)
string coach1d4hStateText = "日線 " + f_trendShort(coachTrend1d) + "｜4H " + f_trendShort(coachTrend4h)
string coach1hRelationText = f_tfRelationText(coachTrend4h, coachTrend1h)
string coachDailyRelationText = f_daily4hRelationText(coachTrend1d, coachTrend4h)
bool coachWaitingFor1h = coachStrictAlignment and coachTrend4h != 0 and coachTrend1h != coachTrend4h
bool coachWaitingFor4h = coachTrend4h == 0
string coach1hBearTurnPanelText = f_trendText(coachTrend1h) + "｜" + coach1hRelationText + (coachTrend1h == -1 and not na(coach1hLastBearTurnPrice) ? "｜最近轉空 " + str.tostring(coach1hLastBearTurnPrice, format.mintick) : "")
string coachAlignmentWaitText = coachTrend4h == 0 ? "等待 4H 確認主方向" : coachWaitingFor1h ? (coachTrend4h == 1 ? "等待 1H 轉多｜4H 偏多" : "等待 1H 轉空｜4H 偏空") : coachBiasRule == "4H 主方向＋1H 回調判讀" ? coach1hRelationText : "等待方向規則通過"
string coachModeText = not coachTfConfigValid ? "時間軸設定錯誤" : coachMode == "只顯示多單" ? "固定：多單" : coachMode == "只顯示空單" ? "固定：空單" : coachIsLongView ? "自動：多單｜" + coach1hRelationText : coachIsShortView ? "自動：空單｜" + coach1hRelationText : coachAlignmentWaitText
string coachDirectionText = coachIsLongView ? "多單主軸｜" + coach1hRelationText : coachIsShortView ? "空單主軸｜" + coach1hRelationText : coachWaitingFor1h ? "暫停進場｜" + coachAlignmentWaitText : coachWaitingFor4h ? "尚未啟動｜" + coachAlignmentWaitText : "等待方向｜" + coach4h1hStateText
string coachZoneRowTitle = "市場位置（全部區域）"
string coachSweepRowTitle = coachIsLongView ? "15M 掃過前低" : coachIsShortView ? "15M 掃過前高" : "15M 流動性掃蕩"
string coachChochRowTitle = coachIsLongView ? "15M 局部轉多" : coachIsShortView ? "15M 局部轉空" : "15M 局部結構轉向"
string coachPullbackRowTitle = coachTouchTriggersEntry ? (coachIsLongView ? "盤中掛單觸發（多）" : coachIsShortView ? "盤中掛單觸發（空）" : "盤中掛單區") : (coachIsLongView ? "掛單＋反應 K（多）" : coachIsShortView ? "掛單＋反應 K（空）" : "掛單＋反應 K 區域")

// 重要不變規則：市場位置列與步驟 2 候選區是兩套不同用途。
// 市場位置列：可顯示全部支撐／阻力／多空 OB／FVG，僅描述價格目前在哪裡。
// 步驟 2 候選：必須符合交易方向與正確價格側，禁止空單引用支撐／多方區，禁止多單引用阻力／空方區。
// 右下角區域列改用目前價格 close 判斷，不受 4H／1H 是否同向影響。
// 候選包含 4H 與 1H 的支撐、阻力、多空 OB 與多空 FVG，共 12 種有效區域。
f_detectCoachHtfZone() =>
    array<float> tops = array.from(
        coach1hResistanceTop, coach1hBearObTop, coach1hBearFvgTop,
        coach1hSupportTop, coach1hBullObTop, coach1hBullFvgTop,
        coach4hResistanceTop, coach4hBearObTop, coach4hBearFvgTop,
        coach4hSupportTop, coach4hBullObTop, coach4hBullFvgTop)
    array<float> bottoms = array.from(
        coach1hResistanceBottom, coach1hBearObBottom, coach1hBearFvgBottom,
        coach1hSupportBottom, coach1hBullObBottom, coach1hBullFvgBottom,
        coach4hResistanceBottom, coach4hBearObBottom, coach4hBearFvgBottom,
        coach4hSupportBottom, coach4hBullObBottom, coach4hBullFvgBottom)
    array<string> names = array.from(
        "1H 阻力區", "1H 空方訂單區", "1H 空方缺口",
        "1H 支撐區", "1H 多方訂單區", "1H 多方缺口",
        "4H 阻力區", "4H 空方訂單區", "4H 空方缺口",
        "4H 支撐區", "4H 多方訂單區", "4H 多方缺口")
    int insideCount = 0
    string insideNames = ""
    string insideSingleRange = ""
    int insideBias = 0
    float nearestDistance = na
    float nearestEdge = na
    string nearestName = ""
    int nearestBias = 0
    bool nearestAbove = false
    for zoneIndex = 0 to array.size(tops) - 1
        float zoneUpper = f_zoneUpperEdge(array.get(tops, zoneIndex), array.get(bottoms, zoneIndex))
        float zoneLower = f_zoneLowerEdge(array.get(tops, zoneIndex), array.get(bottoms, zoneIndex))
        string zoneName = array.get(names, zoneIndex)
        int zoneBias = zoneIndex % 6 < 3 ? -1 : 1
        if not na(zoneUpper) and not na(zoneLower)
            if close >= zoneLower and close <= zoneUpper
                insideCount += 1
                if insideCount == 1
                    insideNames := zoneName
                    insideSingleRange := f_priceRangeText(zoneUpper, zoneLower)
                    insideBias := zoneBias
                else
                    insideNames := insideCount == 2 ? insideNames + "＋" + zoneName : insideCount == 3 ? insideNames + "＋其他重疊區" : insideNames
                    insideBias := insideBias == zoneBias ? insideBias : 0
            else
                bool zoneIsAbove = close < zoneLower
                float zoneDistance = zoneIsAbove ? zoneLower - close : close - zoneUpper
                if na(nearestDistance) or zoneDistance < nearestDistance
                    nearestDistance := zoneDistance
                    nearestEdge := zoneIsAbove ? zoneLower : zoneUpper
                    nearestName := zoneName
                    nearestBias := zoneBias
                    nearestAbove := zoneIsAbove
    string nearestText = na(nearestDistance) ? "" : (nearestAbove ? "上方最近：" : "下方最近：") + nearestName + " @ " + str.tostring(nearestEdge, format.mintick)
    string status = insideCount == 1 ? "目前位於：" + insideNames + " " + insideSingleRange : insideCount > 1 ? "目前位於重疊區：" + insideNames : str.length(nearestText) > 0 ? nearestText : "尚未形成有效 4H／1H 支撐、阻力、OB、FVG"
    int displayBias = insideCount > 0 ? insideBias : nearestBias
    [insideCount, status, displayBias]

[coachInsideZoneCount, coachHtfZoneStatus, coachHtfZoneDisplayBias] = f_detectCoachHtfZone()

// 市場位置與步驟 2 候選區必須分離：
// 1. 市場位置可顯示全部 1H／4H 支撐、阻力、OB、FVG。
// 2. 空單步驟 2 只接受上方／目前所在的阻力、空方 OB、空方 FVG。
// 3. 多單步驟 2 只接受下方／目前所在的支撐、多方 OB、多方 FVG。
// 4. 支撐／阻力僅在 useSRLogic 開啟時可成為步驟 2 候選。
f_detectCoachStep2DirectionalPreview(int direction) =>
    array<float> tops = array.from(
        coach1hResistanceTop, coach1hBearObTop, coach1hBearFvgTop,
        coach1hSupportTop, coach1hBullObTop, coach1hBullFvgTop,
        coach4hResistanceTop, coach4hBearObTop, coach4hBearFvgTop,
        coach4hSupportTop, coach4hBullObTop, coach4hBullFvgTop)
    array<float> bottoms = array.from(
        coach1hResistanceBottom, coach1hBearObBottom, coach1hBearFvgBottom,
        coach1hSupportBottom, coach1hBullObBottom, coach1hBullFvgBottom,
        coach4hResistanceBottom, coach4hBearObBottom, coach4hBearFvgBottom,
        coach4hSupportBottom, coach4hBullObBottom, coach4hBullFvgBottom)
    array<string> names = array.from(
        "1H 阻力區", "1H 空方訂單區", "1H 空方缺口",
        "1H 支撐區", "1H 多方訂單區", "1H 多方缺口",
        "4H 阻力區", "4H 空方訂單區", "4H 空方缺口",
        "4H 支撐區", "4H 多方訂單區", "4H 多方缺口")
    float selectedTop = na
    float selectedBottom = na
    float selectedDistance = na
    string selectedName = ""
    int selectedBias = 0
    bool selectedInside = false
    if direction != 0
        for zoneIndex = 0 to array.size(tops) - 1
            float zoneUpper = f_zoneUpperEdge(array.get(tops, zoneIndex), array.get(bottoms, zoneIndex))
            float zoneLower = f_zoneLowerEdge(array.get(tops, zoneIndex), array.get(bottoms, zoneIndex))
            string zoneName = array.get(names, zoneIndex)
            int groupIndex = zoneIndex % 6
            int zoneBias = groupIndex < 3 ? -1 : 1
            bool isSrZone = groupIndex == 0 or groupIndex == 3
            bool zoneLogicEnabled = not isSrZone or useSRLogic
            bool directionMatch = zoneBias == direction
            if directionMatch and zoneLogicEnabled and not na(zoneUpper) and not na(zoneLower)
                bool inside = close >= zoneLower and close <= zoneUpper
                bool correctSide = inside or (direction == -1 and close < zoneLower) or (direction == 1 and close > zoneUpper)
                if correctSide
                    float distance = inside ? 0.0 : direction == -1 ? zoneLower - close : close - zoneUpper
                    bool replaceSelection = na(selectedDistance) or (inside and not selectedInside) or (inside == selectedInside and distance < selectedDistance)
                    if replaceSelection
                        selectedTop := zoneUpper
                        selectedBottom := zoneLower
                        selectedDistance := distance
                        selectedName := zoneName
                        selectedBias := zoneBias
                        selectedInside := inside
    [selectedName, selectedTop, selectedBottom, selectedBias, selectedInside]

[coachStep2PreviewName, coachStep2PreviewTop, coachStep2PreviewBottom, coachStep2PreviewBias, coachStep2PreviewInside] = f_detectCoachStep2DirectionalPreview(coachSelectedDirection)

// 候選區的時間軸來源由名稱明確標示；1H／4H 面板與圖面都引用同一組上下界。
bool coachStep2PreviewFrom1h = str.contains(coachStep2PreviewName, "1H ")
bool coachStep2PreviewFrom4h = str.contains(coachStep2PreviewName, "4H ")
string coachStep2PreviewSourceTf = coachStep2PreviewFrom1h ? "1H" : coachStep2PreviewFrom4h ? "4H" : ""
string coachStep2PreviewConfirmedText = str.length(coachStep2PreviewName) > 0 ? coachStep2PreviewName + "｜" + f_priceRangeText(coachStep2PreviewTop, coachStep2PreviewBottom) + "｜來源：request.security 上一根已確認 " + coachStep2PreviewSourceTf + " K" : "目前沒有符合方向的步驟 2 候選區"

string coachNoDirectionProcessText = coachWaitingFor1h ? coachAlignmentWaitText + "｜流程暫停" : coachWaitingFor4h ? coachAlignmentWaitText + "｜流程未啟動" : "方向規則尚未通過｜流程未啟動"
string coachActiveZoneStatus = coachHtfZoneStatus
string coachActiveSweepStatus = coachIsLongView ? (coachLongStage >= 3 ? "完成：掃過前低" : "等待掃過前低") : coachIsShortView ? (coachShortStage >= 3 ? "完成：掃過前高" : "等待掃過前高") : bullishSweep ? "最新完成：掃過前低" : bearishSweep ? "最新完成：掃過前高" : coachNoDirectionProcessText
string coachActiveChochStatus = coachIsLongView ? coachLongLocalTurnStatus : coachIsShortView ? coachShortLocalTurnStatus : bullishChoch ? latestBullTurnDoneText : bearishChoch ? latestBearTurnDoneText : coachNoDirectionProcessText
string coachActiveBosStatus = coachIsLongView ? coachLongLocalBosStatus : coachIsShortView ? coachShortLocalBosStatus : bullishBos ? latestBullBreakDoneText : bearishBos ? latestBearBreakDoneText : coachNoDirectionProcessText
string coachActiveInvalidText = coachIsLongView ? coachLongInvalidText : coachIsShortView ? coachShortInvalidText : ""
bool coachActiveInvalid = str.length(coachActiveInvalidText) > 0
bool coachReturnedStep2 = coachActiveInvalid and str.contains(coachActiveInvalidText, "退回步驟 2")
bool coachReturnedStep5 = coachActiveInvalid and str.contains(coachActiveInvalidText, "退回步驟 5")
bool coachReturnedStep1 = coachActiveInvalid and (str.contains(coachActiveInvalidText, "退回步驟 1") or str.contains(coachActiveInvalidText, "重置步驟 1"))
string coachActivePullbackStatus = coachActiveInvalid ? coachActiveInvalidText : coachIsLongView ? (coachLongStage == 7 ? f_reactionKStatus(1, coachLongEntryZone, coachLongPullbackTop, coachLongPullbackBottom, true, coachTouchTriggersEntry, coachLongReactionTriggerPrice) : coachLongStage == 6 ? f_reactionKStatus(1, coachLongEntryZone, coachLongPullbackTop, coachLongPullbackBottom, false, coachTouchTriggersEntry, coachLongReactionTriggerPrice) : coachLongStage >= 5 ? localBullRetestText : "尚未進入回踩步驟") : coachIsShortView ? (coachShortStage == 7 ? f_reactionKStatus(-1, coachShortEntryZone, coachShortPullbackTop, coachShortPullbackBottom, true, coachTouchTriggersEntry, coachShortReactionTriggerPrice) : coachShortStage == 6 ? f_reactionKStatus(-1, coachShortEntryZone, coachShortPullbackTop, coachShortPullbackBottom, false, coachTouchTriggersEntry, coachShortReactionTriggerPrice) : coachShortStage >= 5 ? localBearRetestText : "尚未進入回測步驟") : coachNoDirectionProcessText
string coachActiveStageText = not coachTfConfigValid ? coachTfConfigErrorText : coachIsLongView ? coachLongStageText : coachIsShortView ? coachShortStageText : coachWaitingFor1h ? coachAlignmentWaitText + "；暫停進場，區域位置仍持續判斷" : coachWaitingFor4h ? coachAlignmentWaitText + "；先觀察區域位置" : "方向規則尚未通過，先觀察區域並等待確認"
string coachWrongTfText = "請切換日線／4H／1H／15M"

color coachPassBg = color.new(color.rgb(0, 150, 136), 70)
color coachReactionDoneBg = color.new(color.rgb(255, 235, 59), 36)
color coachWaitBg = color.new(color.rgb(255, 152, 0), 76)
color coachFailBg = color.new(color.rgb(239, 83, 80), 72)
// 步驟 8 狀態色：尚未手動設定持倉使用紅色；設定完成並啟動持倉管理使用橘色。
color coachStep8ManualPendingBg = color.new(color.rgb(244, 67, 54), 18)
color coachStep8ActiveBg = color.new(color.rgb(255, 152, 0), 24)
color coachNeutralBg = color.new(color.rgb(55, 71, 79), 35)
color coachLongBg = color.new(bullishRoleColor, 30)
color coachShortBg = color.new(bearishRoleColor, 30)
color coachHeaderBg = coachIsLongView ? color.new(bullishRoleColor, 18) : coachIsShortView ? color.new(bearishRoleColor, 18) : color.rgb(13, 37, 63)
color coachHtfZoneBg = coachInsideZoneCount > 0 ? (coachHtfZoneDisplayBias == 1 ? coachLongBg : coachHtfZoneDisplayBias == -1 ? coachShortBg : coachWaitBg) : coachHtfZoneDisplayBias == 1 ? color.new(bullishRoleColor, 68) : coachHtfZoneDisplayBias == -1 ? color.new(bearishRoleColor, 68) : coachNeutralBg
color channel1hCoachBg = channel1hBreakAbove ? color.new(bullishRoleColor, 30) : channel1hBreakBelow ? color.new(bearishRoleColor, 30) : channel1hUpperTouch or channel1hLowerTouch ? coachWaitBg : coachNeutralBg
color coachText = color.white
color positionStatusBg = positionTradeClosed ? coachPassBg : positionDirection == 1 ? coachLongBg : positionDirection == -1 ? coachShortBg : coachNeutralBg
// 步驟 7 完成後，若使用者尚未在設定中輸入多／空持倉與實際成交價，頂部進度列正式進入步驟 8 待手動設定狀態。
bool coachStep8WaitingManualPosition = coachActiveStage >= 7 and not positionHasValidEntry and not positionTradeClosed
bool coachStep8PositionActive = positionHasValidEntry and not positionTradeClosed
string coachStep8WaitingManualText = "步驟 8｜待手動修正持倉狀態"
string coachStageDisplayText = positionTradeClosed ? positionExitCoachText : coachStep8PositionActive ? positionExitCoachText : coachStep8WaitingManualPosition ? coachStep8WaitingManualText : coachActiveStageText
color coachStageDisplayBg = positionTradeClosed ? coachPassBg : coachStep8PositionActive ? coachStep8ActiveBg : coachStep8WaitingManualPosition ? coachStep8ManualPendingBg : coachActiveInvalid ? coachFailBg : coachWaitBg

// 步驟 8 右上角大型提醒面板：只在 15M 顯示，切到 1H 後自動隱藏。
// 1. 尚未手動切換持倉：紅色顯示「請在設定面板中修改持倉狀態」。
// 2. 已完成持倉方向與進場價設定：只有該持倉方向已完成步驟 7、正式進入步驟 8，才以橘色顯示持倉狀態。
// 3. 使用者若在步驟 1～6 提前輸入持倉，右上角面板保持隱藏。
bool coachStep8ReachedForPosition = positionDirection == 1 ? coachLongStage >= 7 : positionDirection == -1 ? coachShortStage >= 7 : false
bool coachStep8TopRightPositionActive = coachStep8PositionActive and coachStep8ReachedForPosition
bool coachStep8TopRightVisible = showStep8TopRightPanel and coachOn15m and (coachStep8WaitingManualPosition or coachStep8TopRightPositionActive)
string coachStep8TopRightText = coachStep8WaitingManualPosition ? "步驟 8｜等待設定\n請修改持倉狀態" : coachStep8TopRightPositionActive ? "步驟 8｜持倉管理\n" + positionPanelText + "\n請切換到 1H" : ""
color coachStep8TopRightBg = coachStep8WaitingManualPosition ? coachStep8ManualPendingBg : coachStep8ActiveBg

string coachPanelTextSize = coachPanelTextSizeInput == "極小" ? size.tiny : coachPanelTextSizeInput == "一般" ? size.normal : size.small
string coachPanelPosition = coachPanelPositionInput == "右上" ? position.top_right : coachPanelPositionInput == "右中" ? position.middle_right : position.bottom_right


int coachWaitFlowDirection = coachIsLongView ? 1 : coachIsShortView ? -1 : coachTrend4h == 1 ? 1 : coachTrend4h == -1 ? -1 : 0
int coachWaitFlowStage = coachIsLongView ? coachLongStage : coachIsShortView ? coachShortStage : 0
string coachWaitFlowTitle = coachWaitFlowDirection == 1 ? "多方轉向確認流程" : coachWaitFlowDirection == -1 ? "空方轉向確認流程" : "等待方向確認流程"
string coachWaitStep1 = coachWaitFlowDirection == 1 ? (coachLongStage >= 1 ? "方向通過｜4H 主多｜" + coach1hRelationText : "方向判斷｜等待 4H 主方向偏多") : coachWaitFlowDirection == -1 ? (coachShortStage >= 1 ? "方向通過｜4H 主空｜" + coach1hRelationText : "方向判斷｜等待 4H 主方向偏空") : "方向判斷｜等待 4H 主方向確認"
string coachStep2PreviewRange = f_priceRangeText(coachStep2PreviewTop, coachStep2PreviewBottom)
string coachStep2PreviewStatus = str.length(coachStep2PreviewName) == 0 ? (coachWaitFlowDirection == 1 ? "目前沒有多單候選區｜1H／4H 支撐、多方 OB 或 FVG" : coachWaitFlowDirection == -1 ? "目前沒有空單候選區｜1H／4H 阻力、空方 OB 或 FVG" : "等待方向確認") : coachStep2PreviewInside ? "目前位於候選區｜" + coachStep2PreviewName + " " + coachStep2PreviewRange : (coachWaitFlowDirection == 1 ? "下方候選區｜" : "上方候選區｜") + coachStep2PreviewName + " " + coachStep2PreviewRange
string coachWaitStep2 = coachReturnedStep1 ? coachActiveInvalidText : coachWaitFlowDirection == 1 ? (coachLongStage >= 2 and str.length(coachLongEnteredHtfZone) > 0 ? "已進入多方區｜" + coachLongEnteredHtfZone : "多單候選區｜" + coachStep2PreviewStatus) : coachWaitFlowDirection == -1 ? (coachShortStage >= 2 and str.length(coachShortEnteredHtfZone) > 0 ? "已進入空方區｜" + coachShortEnteredHtfZone : "空單候選區｜" + coachStep2PreviewStatus) : "候選區｜等待方向確認"
string coachWaitStep3 = coachReturnedStep2 ? coachActiveInvalidText : coachWaitFlowDirection == 1 ? (coachLongStage >= 3 and not na(coachLongSweepLow) ? "掃過前低｜價格 " + str.tostring(coachLongSweepLow, format.mintick) : not na(lastSwingLow) ? "等待掃過前低｜目標 " + str.tostring(lastSwingLow, format.mintick) : "等待形成前低") : coachWaitFlowDirection == -1 ? (coachShortStage >= 3 and not na(coachShortSweepHigh) ? "掃過前高｜價格 " + str.tostring(coachShortSweepHigh, format.mintick) : not na(lastSwingHigh) ? "等待掃過前高｜目標 " + str.tostring(lastSwingHigh, format.mintick) : "等待形成前高") : "流動性掃蕩｜等待有效 Sweep"
string coachWaitStep4 = coachWaitFlowDirection == 1 ? coachLongLocalTurnStatus : coachWaitFlowDirection == -1 ? coachShortLocalTurnStatus : "等待方向確認｜尚未鎖定 MSS 確認價"
string coachWaitStep5 = coachWaitFlowDirection == 1 ? coachLongLocalBosStatus : coachWaitFlowDirection == -1 ? coachShortLocalBosStatus : "局部結構延續｜等待 BOS"
string coachWaitStep6 = (coachReturnedStep2 or coachReturnedStep5) ? coachActiveInvalidText : coachWaitFlowDirection == 1 ? (coachLongStage >= 7 ? (coachTouchTriggersEntry ? "步驟 6 完成｜盤中價格已觸碰多單掛單區｜" : "步驟 6 完成｜多方反應 K 已確認｜") + f_priceRangeText(coachLongPullbackTop, coachLongPullbackBottom) : coachLongStage == 6 ? str.replace_all(f_reactionKStatus(1, coachLongEntryZone, coachLongPullbackTop, coachLongPullbackBottom, false, coachTouchTriggersEntry, coachLongReactionTriggerPrice), "｜等待", "\n等待") : str.replace_all(localBullRetestText, "｜來源：", "\n來源：")) : coachWaitFlowDirection == -1 ? (coachShortStage >= 7 ? (coachTouchTriggersEntry ? "步驟 6 完成｜盤中價格已觸碰空單掛單區｜" : "步驟 6 完成｜空方反應 K 已確認｜") + f_priceRangeText(coachShortPullbackTop, coachShortPullbackBottom) : coachShortStage == 6 ? str.replace_all(f_reactionKStatus(-1, coachShortEntryZone, coachShortPullbackTop, coachShortPullbackBottom, false, coachTouchTriggersEntry, coachShortReactionTriggerPrice), "｜等待", "\n等待") : str.replace_all(localBearRetestText, "｜來源：", "\n來源：")) : "步驟 6｜等待方向確認後建立 15M 掛單區"
string coachWaitStep7 = (coachReturnedStep2 or coachReturnedStep5) ? coachActiveInvalidText : coachWaitFlowDirection == 1 ? (coachLongStage >= 7 ? f_reactionKStatus(1, coachLongEntryZone, coachLongPullbackTop, coachLongPullbackBottom, true, coachTouchTriggersEntry, coachLongReactionTriggerPrice) : coachTouchTriggersEntry ? "步驟 7 尚未完成｜等待盤中觸碰多單掛單區" : "步驟 7 尚未完成｜等待多方反應 K 確認") : coachWaitFlowDirection == -1 ? (coachShortStage >= 7 ? f_reactionKStatus(-1, coachShortEntryZone, coachShortPullbackTop, coachShortPullbackBottom, true, coachTouchTriggersEntry, coachShortReactionTriggerPrice) : coachTouchTriggersEntry ? "步驟 7 尚未完成｜等待盤中觸碰空單掛單區" : "步驟 7 尚未完成｜等待空方反應 K 確認") : "步驟 7 尚未完成｜等待步驟 6 完成"

f_waitStepText(stepNo) =>
    switch stepNo
        1 => coachWaitStep1
        2 => coachWaitStep2
        3 => coachWaitStep3
        4 => coachWaitStep4
        5 => coachWaitStep5
        6 => coachWaitStep6
        => coachWaitStep7

f_waitStepBg(stepNo) =>
    bool invalidRow = coachReturnedStep1 ? stepNo <= 2 : coachReturnedStep2 ? (stepNo == 3 or stepNo >= 6) : coachReturnedStep5 ? stepNo >= 6 : false
    invalidRow ? coachFailBg : stepNo == 6 ? (coachWaitFlowStage >= 7 ? coachPassBg : coachWaitFlowStage >= 5 ? coachWaitBg : coachNeutralBg) : stepNo == 7 ? (coachWaitFlowStage >= 7 ? coachReactionDoneBg : coachNeutralBg) : coachWaitFlowStage >= stepNo ? coachPassBg : coachWaitFlowStage == stepNo - 1 ? coachWaitBg : coachNeutralBg

// ============================================================================
// 日線／4H／1H 專屬市場背景面板資料
// 日線看大環境；4H 看主方向、主要流動性與區域；1H 看內部推進／回調；15M 保留進場流程。
// ============================================================================
f_buildPanelTexts() =>
    string panelDailyStructure = f_structurePairText(coachHighType1d, coachLowType1d)
    string panel4hStructure = f_structurePairText(coachHighType4h, coachLowType4h)
    string panel1hStructure = f_structurePairText(coachHighType1h, coachLowType1h)
    string panelDailyEvent = f_eventWithPrice(coachEvent1d, coachEventPrice1d)
    string panel4hEvent = f_eventWithPrice(coachEvent4h, coachEventPrice4h)
    string panel1hEvent = f_eventWithPrice(coachEvent1h, coachEventPrice1h)
    string panelDailyHigh = na(coachSwingHigh1d) ? "尚未形成" : str.tostring(coachSwingHigh1d, format.mintick) + (coachHighBroken1d == 1 ? "｜已突破" : "｜待觀察")
    string panelDailyLow = na(coachSwingLow1d) ? "尚未形成" : str.tostring(coachSwingLow1d, format.mintick) + (coachLowBroken1d == 1 ? "｜已跌破" : "｜待觀察")
    string panel4hHigh = na(coachSwingHigh4h) ? "尚未形成" : str.tostring(coachSwingHigh4h, format.mintick) + (coachHighBroken4h == 1 ? "｜已突破" : "｜上方結構／流動性")
    string panel4hLow = na(coachSwingLow4h) ? "尚未形成" : str.tostring(coachSwingLow4h, format.mintick) + (coachLowBroken4h == 1 ? "｜已跌破" : "｜下方結構／流動性")
    string panel1hHigh = na(coachSwingHigh1h) ? "尚未形成" : str.tostring(coachSwingHigh1h, format.mintick) + (coachHighBroken1h == 1 ? "｜已突破" : "｜待突破／掃蕩")
    string panel1hLow = na(coachSwingLow1h) ? "尚未形成" : str.tostring(coachSwingLow1h, format.mintick) + (coachLowBroken1h == 1 ? "｜已跌破" : "｜待跌破／掃蕩")
    string panelDailySweep = coachSweep1d == 1 ? "最近：掃過前低後收回" : coachSweep1d == -1 ? "最近：掃過前高後跌回" : "尚無已確認 Sweep"
    string panel4hSweep = coachSweep4h == 1 ? "最近：掃過前低後收回" : coachSweep4h == -1 ? "最近：掃過前高後跌回" : "尚無已確認 Sweep"
    string panel1hSweep = coachSweep1h == 1 ? "最近：掃過前低後收回" : coachSweep1h == -1 ? "最近：掃過前高後跌回" : "尚無已確認 Sweep"
    string panel4hBullZone = f_bullZoneSummary("4H", coach4hBullObTop, coach4hBullObBottom, coach4hBullFvgTop, coach4hBullFvgBottom, coach4hSupportTop, coach4hSupportBottom)
    string panel4hBearZone = f_bearZoneSummary("4H", coach4hBearObTop, coach4hBearObBottom, coach4hBearFvgTop, coach4hBearFvgBottom, coach4hResistanceTop, coach4hResistanceBottom)
    string panel1hBullZone = f_bullZoneSummary("1H", coach1hBullObTop, coach1hBullObBottom, coach1hBullFvgTop, coach1hBullFvgBottom, coach1hSupportTop, coach1hSupportBottom)
    string panel1hBearZone = f_bearZoneSummary("1H", coach1hBearObTop, coach1hBearObBottom, coach1hBearFvgTop, coach1hBearFvgBottom, coach1hResistanceTop, coach1hResistanceBottom)
    string panelDailyAction = coachTrend1d == 1 ? "日線偏多：4H 優先找回調多方區，不追高" : coachTrend1d == -1 ? "日線偏空：4H 優先找反彈空方區，不追空" : "日線待定：降低方向信心，先看 4H 結構"
    string panel4hAction = coachTrend4h == 1 and coachTrend1h == -1 ? "主多、1H 回調：等待進入多方區後由 15M 轉多" : coachTrend4h == 1 ? "多方主軸：等待回踩區域，不追價" : coachTrend4h == -1 and coachTrend1h == 1 ? "主空、1H 反彈：等待進入空方區後由 15M 轉空" : coachTrend4h == -1 ? "空方主軸：等待反彈區域，不追價" : "4H 待定：等待 BOS／CHoCH 確認主方向"
    string panel1hAction = coachTrend4h == 1 and coachTrend1h == -1 ? "回調中：等多方區＋15M SSL Sweep→CHoCH↑" : coachTrend4h == -1 and coachTrend1h == 1 ? "反彈中：等空方區＋15M BSL Sweep→CHoCH↓" : coachTrend4h == 1 and coachTrend1h == 1 ? "同向多方：等回踩，不追高；15M 完成進場確認" : coachTrend4h == -1 and coachTrend1h == -1 ? "同向空方：等反彈，不追空；15M 完成進場確認" : "等待 4H 主方向與 1H 結構形成"
    [panelDailyStructure, panel4hStructure, panel1hStructure, panelDailyEvent, panel4hEvent, panel1hEvent, panelDailyHigh, panelDailyLow, panel4hHigh, panel4hLow, panel1hHigh, panel1hLow, panelDailySweep, panel4hSweep, panel1hSweep, panel4hBullZone, panel4hBearZone, panel1hBullZone, panel1hBearZone, panelDailyAction, panel4hAction, panel1hAction]

[panelDailyStructure, panel4hStructure, panel1hStructure, panelDailyEvent, panel4hEvent, panel1hEvent, panelDailyHigh, panelDailyLow, panel4hHigh, panel4hLow, panel1hHigh, panel1hLow, panelDailySweep, panel4hSweep, panel1hSweep, panel4hBullZone, panel4hBearZone, panel1hBullZone, panel1hBearZone, panelDailyAction, panel4hAction, panel1hAction] = f_buildPanelTexts()

// ============================================================================
// 日線／4H／1H 面板位置同步到圖表
// 有單一價格的項目使用水平線；有上下緣的項目使用區域；純文字判讀仍留在面板。
// 15M 已有實際 SMC、OB、FVG 與支撐阻力，避免重複疊圖。
// ============================================================================
f_renderPanelMapVisuals() =>
    bool panelMapActive = showPanelMapOnChart and coachTfConfigValid and (coachOn1d or coachOn4h or coachOn1h)
    string panelMapTfName = coachOn1d ? "日線" : coachOn4h ? "4H" : "1H"
    int panelMapTrend = coachOn1d ? coachTrend1d : coachOn4h ? coachTrend4h : coachTrend1h
    int panelMapEvent = coachOn1d ? coachEvent1d : coachOn4h ? coachEvent4h : coachEvent1h
    float panelMapHigh = coachOn1d ? coachSwingHigh1d : coachOn4h ? coachSwingHigh4h : coachSwingHigh1h
    float panelMapLow = coachOn1d ? coachSwingLow1d : coachOn4h ? coachSwingLow4h : coachSwingLow1h
    float panelMapEventPrice = coachOn1d ? coachEventPrice1d : coachOn4h ? coachEventPrice4h : coachEventPrice1h
    float panelMapMiddle = not na(panelMapHigh) and not na(panelMapLow) ? (panelMapHigh + panelMapLow) / 2.0 : na
    int panelMapLeftBar = math.max(bar_index - math.min(panelMapRightBars, 30), 0)
    int panelMapRightBar = bar_index + panelMapRightBars

    bool panelMapEventAtHigh = not na(panelMapEventPrice) and not na(panelMapHigh) and math.abs(panelMapEventPrice - panelMapHigh) <= syminfo.mintick
    bool panelMapEventAtLow = not na(panelMapEventPrice) and not na(panelMapLow) and math.abs(panelMapEventPrice - panelMapLow) <= syminfo.mintick
    string panelMapEventShort = panelMapEvent == 2 ? "CHoCH↑" : panelMapEvent == 1 ? "BOS↑" : panelMapEvent == -2 ? "CHoCH↓" : panelMapEvent == -1 ? "BOS↓" : ""
    string panelMapHighSuffix = panelMapTrend == -1 ? "｜空方失效／轉多觀察" : "｜上方結構／流動性"
    string panelMapLowSuffix = panelMapTrend == 1 ? "｜多方失效／轉空觀察" : "｜下方結構／流動性"
    color panelMapHighColor = panelMapTrend == -1 ? coachWaitBg : coachNeutralBg
    color panelMapLowColor = panelMapTrend == 1 ? coachWaitBg : coachNeutralBg
    color panelMapEventColor = panelMapEvent > 0 ? bullishRoleColor : bearishRoleColor
    int panelMapEventLabelBar = panelMapLeftBar + int(math.floor((panelMapRightBar - panelMapLeftBar) * 0.5))
    string panelMapEventTooltip = panelMapTfName + "｜" + f_structureEventText(panelMapEvent) + "\n結構價位：" + str.tostring(panelMapEventPrice, format.mintick) + "\n圖面僅顯示英文縮寫；右下表格保留完整中文說明。"

    [panelMap4hBullTop, panelMap4hBullBottom] = f_selectPanelZone(coach4hBullObTop, coach4hBullObBottom, coach4hBullFvgTop, coach4hBullFvgBottom, coach4hSupportTop, coach4hSupportBottom)
    [panelMap4hBearTop, panelMap4hBearBottom] = f_selectPanelZone(coach4hBearObTop, coach4hBearObBottom, coach4hBearFvgTop, coach4hBearFvgBottom, coach4hResistanceTop, coach4hResistanceBottom)
    [panelMap1hBullTop, panelMap1hBullBottom] = f_selectPanelZone(coach1hBullObTop, coach1hBullObBottom, coach1hBullFvgTop, coach1hBullFvgBottom, coach1hSupportTop, coach1hSupportBottom)
    [panelMap1hBearTop, panelMap1hBearBottom] = f_selectPanelZone(coach1hBearObTop, coach1hBearObBottom, coach1hBearFvgTop, coach1hBearFvgBottom, coach1hResistanceTop, coach1hResistanceBottom)
    int panelMap4hBullType = f_selectPanelZoneType(coach4hBullObTop, coach4hBullObBottom, coach4hBullFvgTop, coach4hBullFvgBottom, coach4hSupportTop, coach4hSupportBottom)
    int panelMap4hBearType = f_selectPanelZoneType(coach4hBearObTop, coach4hBearObBottom, coach4hBearFvgTop, coach4hBearFvgBottom, coach4hResistanceTop, coach4hResistanceBottom)
    int panelMap1hBullType = f_selectPanelZoneType(coach1hBullObTop, coach1hBullObBottom, coach1hBullFvgTop, coach1hBullFvgBottom, coach1hSupportTop, coach1hSupportBottom)
    int panelMap1hBearType = f_selectPanelZoneType(coach1hBearObTop, coach1hBearObBottom, coach1hBearFvgTop, coach1hBearFvgBottom, coach1hResistanceTop, coach1hResistanceBottom)
    float panelMapBullTop = coachOn4h ? panelMap4hBullTop : coachOn1h ? panelMap1hBullTop : na
    float panelMapBullBottom = coachOn4h ? panelMap4hBullBottom : coachOn1h ? panelMap1hBullBottom : na
    float panelMapBearTop = coachOn4h ? panelMap4hBearTop : coachOn1h ? panelMap1hBearTop : na
    float panelMapBearBottom = coachOn4h ? panelMap4hBearBottom : coachOn1h ? panelMap1hBearBottom : na
    int panelMapBullType = coachOn4h ? panelMap4hBullType : coachOn1h ? panelMap1hBullType : 0
    int panelMapBearType = coachOn4h ? panelMap4hBearType : coachOn1h ? panelMap1hBearType : 0
    string panelMapBullText = coachOn4h ? panel4hBullZone : coachOn1h ? panel1hBullZone : ""
    string panelMapBearText = coachOn4h ? panel4hBearZone : coachOn1h ? panel1hBearZone : ""
    float panelMapOverlapThreshold = sameTypeZoneOverlapPct * 0.01
    bool panelMapBullDuplicatesNative = suppressSameTypeZoneOverlap and not coachOn1d and (panelMapBullType == 1 ? showOB and f_hasSameTypeZoneOverlap(bullOrderBlocks, panelMapBullTop, panelMapBullBottom, panelMapOverlapThreshold) : panelMapBullType == 2 ? showFVG and f_hasSameTypeZoneOverlap(bullFvgs, panelMapBullTop, panelMapBullBottom, panelMapOverlapThreshold) : panelMapBullType == 3 ? showSR and f_hasSameTypeZoneOverlap(supportZones, panelMapBullTop, panelMapBullBottom, panelMapOverlapThreshold) : false)
    bool panelMapBearDuplicatesNative = suppressSameTypeZoneOverlap and not coachOn1d and (panelMapBearType == 1 ? showOB and f_hasSameTypeZoneOverlap(bearOrderBlocks, panelMapBearTop, panelMapBearBottom, panelMapOverlapThreshold) : panelMapBearType == 2 ? showFVG and f_hasSameTypeZoneOverlap(bearFvgs, panelMapBearTop, panelMapBearBottom, panelMapOverlapThreshold) : panelMapBearType == 3 ? showSR and f_hasSameTypeZoneOverlap(resistanceZones, panelMapBearTop, panelMapBearBottom, panelMapOverlapThreshold) : false)
    bool panelMapBullPrioritySuppressed = prioritizeCrossTypeZones and not coachOn1d and (panelMapBullType == 2 ? showOB and f_floatZonePartiallyOverlapsHigher(panelMapBullTop, panelMapBullBottom, panelMapLeftBar, panelMapRightBar, bullOrderBlocks, panelMapOverlapThreshold) : panelMapBullType == 3 ? (showOB and f_floatZonePartiallyOverlapsHigher(panelMapBullTop, panelMapBullBottom, panelMapLeftBar, panelMapRightBar, bullOrderBlocks, panelMapOverlapThreshold)) or (showFVG and f_floatZonePartiallyOverlapsHigher(panelMapBullTop, panelMapBullBottom, panelMapLeftBar, panelMapRightBar, bullFvgs, panelMapOverlapThreshold)) : false)
    bool panelMapBearPrioritySuppressed = prioritizeCrossTypeZones and not coachOn1d and (panelMapBearType == 2 ? showOB and f_floatZonePartiallyOverlapsHigher(panelMapBearTop, panelMapBearBottom, panelMapLeftBar, panelMapRightBar, bearOrderBlocks, panelMapOverlapThreshold) : panelMapBearType == 3 ? (showOB and f_floatZonePartiallyOverlapsHigher(panelMapBearTop, panelMapBearBottom, panelMapLeftBar, panelMapRightBar, bearOrderBlocks, panelMapOverlapThreshold)) or (showFVG and f_floatZonePartiallyOverlapsHigher(panelMapBearTop, panelMapBearBottom, panelMapLeftBar, panelMapRightBar, bearFvgs, panelMapOverlapThreshold)) : false)

    var line panelMapHighLine = na
    var line panelMapLowLine = na
    var line panelMapMidLine = na
    var line panelMapEventLine = na
    var label panelMapHighLabel = na
    var label panelMapLowLabel = na
    var label panelMapMidLabel = na
    var label panelMapEventLabel = na
    var box panelMapPremiumBox = na
    var box panelMapDiscountBox = na
    var box panelMapBullBox = na
    var box panelMapBearBox = na
    var box panelMap1hSupportOn15mBox = na
    var box panelMap1hResistanceOn15mBox = na

    panelMapHighLine := f_syncPanelLine(panelMapHighLine, panelMapActive and not panelMapEventAtHigh, panelMapLeftBar, panelMapRightBar, panelMapHigh, panelMapHighColor, true, 2)
    panelMapLowLine := f_syncPanelLine(panelMapLowLine, panelMapActive and not panelMapEventAtLow, panelMapLeftBar, panelMapRightBar, panelMapLow, panelMapLowColor, true, 2)
    panelMapMidLine := f_syncPanelLine(panelMapMidLine, panelMapActive and showPanelRangeBands, panelMapLeftBar, panelMapRightBar, panelMapMiddle, coachWaitBg, true, 1)
    panelMapEventLine := f_syncPanelLine(panelMapEventLine, panelMapActive and not na(panelMapEventPrice), panelMapLeftBar, panelMapRightBar, panelMapEventPrice, panelMapEventColor, false, 1)
    panelMapHighLabel := f_syncPanelLabel(panelMapHighLabel, panelMapActive and showPanelMapText and not na(panelMapHigh) and not panelMapEventAtHigh, panelMapRightBar, panelMapHigh, panelMapTfName + " " + str.tostring(panelMapHigh, format.mintick) + panelMapHighSuffix, panelMapHighColor)
    panelMapLowLabel := f_syncPanelLabel(panelMapLowLabel, panelMapActive and showPanelMapText and not na(panelMapLow) and not panelMapEventAtLow, panelMapRightBar, panelMapLow, panelMapTfName + " " + str.tostring(panelMapLow, format.mintick) + panelMapLowSuffix, panelMapLowColor)
    panelMapMidLabel := f_syncPanelLabel(panelMapMidLabel, panelMapActive and showPanelMapText and showPanelRangeBands and not na(panelMapMiddle), panelMapRightBar, panelMapMiddle, panelMapTfName + " 均衡線 " + str.tostring(panelMapMiddle, format.mintick), coachWaitBg)
    panelMapEventLabel := f_syncPanelLabel(panelMapEventLabel, panelMapActive and showPanelMapText and showStructureText and not na(panelMapEventPrice), panelMapEventLabelBar, panelMapEventPrice, panelMapEventShort, panelMapEventColor)
    if not na(panelMapEventLabel)
        label.set_style(panelMapEventLabel, label.style_label_down)
        label.set_color(panelMapEventLabel, color.new(panelMapEventColor, 100))
        label.set_textcolor(panelMapEventLabel, panelMapEventColor)
        label.set_tooltip(panelMapEventLabel, panelMapEventTooltip)
    panelMapPremiumBox := f_syncPanelBox(panelMapPremiumBox, panelMapActive and showPanelRangeBands, panelMapLeftBar, panelMapRightBar, panelMapHigh, panelMapMiddle, showPanelMapText ? panelMapTfName + " 溢價區" : "", color.new(bearishRoleColor, 70), color.new(bearishRoleColor, 93))
    panelMapDiscountBox := f_syncPanelBox(panelMapDiscountBox, panelMapActive and showPanelRangeBands, panelMapLeftBar, panelMapRightBar, panelMapMiddle, panelMapLow, showPanelMapText ? panelMapTfName + " 折價區" : "", color.new(bullishRoleColor, 70), color.new(bullishRoleColor, 93))
    panelMapBullBox := f_syncPanelBox(panelMapBullBox, panelMapActive and not coachOn1d and not panelMapBullDuplicatesNative and not panelMapBullPrioritySuppressed, panelMapLeftBar, panelMapRightBar, panelMapBullTop, panelMapBullBottom, showPanelMapText ? panelMapBullText : "", bullishRoleColor, coachLongBg)
    panelMapBearBox := f_syncPanelBox(panelMapBearBox, panelMapActive and not coachOn1d and not panelMapBearDuplicatesNative and not panelMapBearPrioritySuppressed, panelMapLeftBar, panelMapRightBar, panelMapBearTop, panelMapBearBottom, showPanelMapText ? panelMapBearText : "", bearishRoleColor, coachShortBg)
    bool show1hSrOn15m = showPanelMapOnChart and show1hSrZonesOn15m and coachOn15m and coachTfConfigValid
    int zone1hLeftBar15m = math.max(bar_index - math.min(panelMapRightBars, 30), 0)
    int zone1hRightBar15m = bar_index + panelMapRightBars
    panelMap1hSupportOn15mBox := f_syncPanelBox(panelMap1hSupportOn15mBox, show1hSrOn15m, zone1hLeftBar15m, zone1hRightBar15m, coach1hSupportTop, coach1hSupportBottom, showPanelMapText ? "1H 支撐區" : "", color.new(supportColor, 0), color.new(supportColor, 88))
    panelMap1hResistanceOn15mBox := f_syncPanelBox(panelMap1hResistanceOn15mBox, show1hSrOn15m, zone1hLeftBar15m, zone1hRightBar15m, coach1hResistanceTop, coach1hResistanceBottom, showPanelMapText ? "1H 阻力區" : "", color.new(resistanceColor, 0), color.new(resistanceColor, 88))
    0

f_renderPanelMapVisuals()

// 持倉盈虧比倉位圖：SL 使用 15M SMC；自動 TP 使用 1H 支撐／阻力，手動模式使用輸入價格。
f_renderPositionRiskRewardVisuals() =>
    var box positionStopZoneBox = na
    var box positionRiskBox = na
    var line positionEntryMapLine = na
    var label positionEntryMapLabel = na
    var array<box> positionRewardBoxes = array.new<box>()
    if barstate.islast
        while array.size(positionRewardBoxes) < POSITION_MAX_TP
            box emptyRewardBox = na
            array.push(positionRewardBoxes, emptyRewardBox)
        // 1H／15M 盈虧比區域距離最新 K 棒可在設定調整，預設 100 根。
        int rrStartOffsetBars = positionMapRightOffsetBars
        int rrWidthBars = math.min(coachOn1h ? 24 : math.max(panelMapRightBars, 1), 500 - rrStartOffsetBars)
        int rrLeftBar = bar_index + rrStartOffsetBars
        int rrRightBar = rrLeftBar + rrWidthBars
        bool positionDirectionStep7Completed = positionRequestedDirection == 1 ? coachLongStage >= 7 : positionRequestedDirection == -1 ? coachShortStage >= 7 : false
        bool previewPositionMap15m = coachOn15m and showPositionRiskRewardPreview15m and positionDirectionStep7Completed
        bool showPositionMap = showPositionRiskRewardMap and (coachOn1h or previewPositionMap15m) and positionRequestedHasValidEntry and (not positionTradeClosed or positionTradeClosedTp >= 0)
        string positionMapModeText = previewPositionMap15m ? "15M 預覽｜" : "1H 正式｜"
        string riskTextVerticalAlign = positionRequestedDirection == 1 ? text.align_bottom : text.align_top
        string rewardTextVerticalAlign = positionRequestedDirection == 1 ? text.align_top : text.align_bottom
        positionEntryMapLine := f_syncPanelLine(positionEntryMapLine, showPositionMap, rrLeftBar, rrRightBar, positionEntryPriceInput, color.rgb(255, 193, 7), false, 3)
        positionEntryMapLabel := f_syncPositionEntryLabel(positionEntryMapLabel, showPositionMap, rrLeftBar - 2, positionEntryPriceInput, positionMapModeText + "進場位置｜" + str.tostring(positionEntryPriceInput, format.mintick), color.rgb(255, 193, 7))
        bool showStopZone = showPositionMap and not na(positionStopZoneTop) and not na(positionStopZoneBottom)
        string stopZoneText = showStopZone ? "15M SMC SL 區｜" + positionStopSourceLabel + "｜止損 " + str.tostring(positionSelectedStopPrice, format.mintick) : ""
        positionStopZoneBox := f_syncPositionMapBox(positionStopZoneBox, showStopZone, rrLeftBar, rrRightBar, positionStopZoneTop, positionStopZoneBottom, stopZoneText, color.new(color.rgb(244, 67, 54), 0), color.new(color.rgb(244, 67, 54), 83), 3, riskTextVerticalAlign)
        bool showRiskBox = showPositionMap and not na(positionSelectedStopPrice)
        float riskTop = showRiskBox ? math.max(positionEntryPriceInput, positionSelectedStopPrice) : na
        float riskBottom = showRiskBox ? math.min(positionEntryPriceInput, positionSelectedStopPrice) : na
        string riskText = showRiskBox ? "風險區｜SL " + str.tostring(positionSelectedStopPrice, format.mintick) : ""
        positionRiskBox := f_syncPositionMapBox(positionRiskBox, showRiskBox, rrLeftBar, rrRightBar, riskTop, riskBottom, riskText, color.new(color.rgb(229, 57, 53), 0), color.new(color.rgb(229, 57, 53), 90), 2, riskTextVerticalAlign)
        for i = 0 to POSITION_MAX_TP - 1
            int tpNumber = i + 1
            bool manualSlot = positionManualTpMode and i == 0
            bool previewZoneAvailable = previewPositionMap15m and i < previewTpCount
            bool hasZone = positionManualTpMode ? manualSlot and positionManualTpValid : previewPositionMap15m ? previewZoneAvailable : i < positionTpCount
            float zoneTop = manualSlot and positionManualTpValid ? positionManualTpPriceInput + syminfo.mintick : previewPositionMap15m ? (i == 0 ? previewTp1Top : i == 1 ? previewTp2Top : na) : hasZone ? array.get(positionTpTops, i) : na
            float zoneBottom = manualSlot and positionManualTpValid ? positionManualTpPriceInput - syminfo.mintick : previewPositionMap15m ? (i == 0 ? previewTp1Bottom : i == 1 ? previewTp2Bottom : na) : hasZone ? array.get(positionTpBottoms, i) : na
            int zoneType = manualSlot ? 5 : previewPositionMap15m ? (i == 0 ? previewTp1Type : i == 1 ? previewTp2Type : 0) : hasZone ? array.get(positionTpTypes, i) : 0
            float exitPrice = manualSlot ? positionManualTpPriceInput : hasZone ? f_exitZoneNearEdge(positionRequestedDirection, zoneTop, zoneBottom) : na
            bool selectedTp = positionManualTpMode ? manualSlot : positionPlannedTpNumber == tpNumber
            bool touchedTp = positionTradeClosed and (manualSlot ? positionTradeClosedTp == 0 : positionTradeClosedTp == tpNumber)
            bool showRewardBox = showPositionMap and hasZone and not na(exitPrice) and (not positionTradeClosed or touchedTp)
            float rewardTop = showRewardBox ? math.max(positionEntryPriceInput, exitPrice) : na
            float rewardBottom = showRewardBox ? math.min(positionEntryPriceInput, exitPrice) : na
            float rewardDistance = showRewardBox ? math.abs(positionEntryPriceInput - exitPrice) : na
            float rrMultiple = showRewardBox and not na(positionRiskDistance) and positionRiskDistance > 0 ? rewardDistance / positionRiskDistance : na
            string tpLabel = manualSlot ? "手動 TP" : "TP" + str.tostring(tpNumber)
            color rewardColor = selectedTp ? color.rgb(255, 235, 59) : f_tpPaletteColor(tpNumber)
            string rrText = showRewardBox ? (touchedTp ? "✓ " : selectedTp ? "★ " : "") + tpLabel + " 報酬區｜" + f_exitZoneTypeText(positionRequestedDirection, zoneType) + "｜區域中線 " + str.tostring(exitPrice, format.mintick) + (not na(rrMultiple) ? "｜盈虧比 1:" + str.tostring(rrMultiple, "#.##") : "") : ""
            box rewardBox = array.get(positionRewardBoxes, i)
            box updatedRewardBox = f_syncPositionMapBox(rewardBox, showRewardBox, rrLeftBar, rrRightBar, rewardTop, rewardBottom, rrText, color.new(rewardColor, 0), color.new(rewardColor, selectedTp ? 84 : 90), selectedTp ? 3 : 2, rewardTextVerticalAlign)
            array.set(positionRewardBoxes, i, updatedRewardBox)
    0

f_renderPositionRiskRewardVisuals()

// 1H TP1～TP4／手動 TP 區域。預計出場 TP 使用亮黃色粗框；出場後只保留已觸碰的指定 TP 作為結果提示。
f_renderPositionExitVisuals() =>
    var array<box> positionTpVisualBoxes = array.new<box>()
    if barstate.islast
        while array.size(positionTpVisualBoxes) < POSITION_MAX_TP
            box emptyTpBox = na
            array.push(positionTpVisualBoxes, emptyTpBox)
        int exitLeftBar = math.max(bar_index - math.min(panelMapRightBars, 30), 0)
        int exitRightBar = bar_index + panelMapRightBars
        for i = 0 to POSITION_MAX_TP - 1
            int tpNumber = i + 1
            bool manualSlot = positionManualTpMode and i == 0
            bool hasZone = positionManualTpMode ? manualSlot and positionManualTpValid : i < positionTpCount
            bool selectedTp = positionManualTpMode ? manualSlot : positionPlannedTpNumber == tpNumber
            bool showThisTp = coachOn1h and positionRequestedHasValidEntry and hasZone and (not positionTradeClosed or selectedTp)
            float zoneTop = manualSlot ? positionManualTpPriceInput + syminfo.mintick : hasZone ? array.get(positionTpTops, i) : na
            float zoneBottom = manualSlot ? positionManualTpPriceInput - syminfo.mintick : hasZone ? array.get(positionTpBottoms, i) : na
            int zoneType = manualSlot ? 5 : hasZone ? array.get(positionTpTypes, i) : 0
            float exitPrice = manualSlot ? positionManualTpPriceInput : hasZone ? f_exitZoneNearEdge(positionRequestedDirection, zoneTop, zoneBottom) : na
            color baseColor = f_tpPaletteColor(tpNumber)
            color selectedColor = color.rgb(255, 235, 59)
            color borderColor = selectedTp ? selectedColor : baseColor
            color fillColor = selectedTp ? color.new(selectedColor, positionTradeClosed ? 68 : 74) : color.new(baseColor, 88)
            int borderWidth = selectedTp ? 4 : 2
            string stateText = positionTradeClosed and selectedTp ? "✓ 已觸碰／獲利出場｜" : selectedTp ? "★ 預計出場｜" : ""
            string zoneText = hasZone ? stateText + (manualSlot ? "手動 TP" : "TP" + str.tostring(tpNumber)) + "｜" + f_exitZoneTypeText(positionRequestedDirection, zoneType) + "｜區域中線 " + str.tostring(exitPrice, format.mintick) : ""
            box currentBox = array.get(positionTpVisualBoxes, i)
            box updatedBox = f_syncExitBox(currentBox, showThisTp, exitLeftBar, exitRightBar, zoneTop, zoneBottom, zoneText, borderColor, fillColor, borderWidth)
            array.set(positionTpVisualBoxes, i, updatedBox)
    0

f_renderPositionExitVisuals()

// 【COPYRIGHT-DCTJ97TRZWGW】Threads • @hongshihong19｜核心區：教練面板與表格
var table coachTable = table.new(
     coachPanelPosition,
     2,
     23,
     bgcolor = color.new(color.black, 12),
     frame_color = color.new(color.white, 55),
     frame_width = 1,
     border_color = color.new(color.white, 80),
     border_width = 1)

// 固定右上角步驟 8 大型提醒面板。若主教練面板也設定為右上，建議將主面板改為右中或右下，避免重疊。
var table coachStep8TopRightTable = table.new(
     position.top_right,
     1,
     1,
     bgcolor = color.new(color.black, 100),
     frame_color = color.new(color.white, 30),
     frame_width = 2,
     border_color = color.new(color.white, 45),
     border_width = 2)

// 面板最大寬度控制：Pine table 不會自動依指定字數換行，因此長狀態文字在組字階段加入 \n。
// 主面板維持緊湊格式：僅步驟 6 的候選／等待內容分為兩行；步驟 1～5 維持單行，步驟 7 保留必要分段。
f_panelRow(int row, string titleText, string valueText, color valueBg) =>
    table.cell(coachTable, 0, row, titleText, text_color = coachText, bgcolor = coachNeutralBg, text_size = coachPanelTextSize)
    table.cell(coachTable, 1, row, valueText, text_color = color.white, bgcolor = valueBg, text_size = coachPanelTextSize, text_halign = text.align_left)

f_waitStepTitle(stepNo) =>
    switch stepNo
        1 => "步驟 1｜方向"
        2 => "步驟 2｜區域"
        3 => "步驟 3｜掃蕩"
        4 => "步驟 4｜轉向"
        5 => "步驟 5｜延續"
        6 => "步驟 6｜掛單＋反應 K"
        => "步驟 7｜進場條件完成"

f_drawWaitingFlow(startRow) =>
    table.cell(coachTable, 0, startRow, "程式正在等待：", text_color = color.white, bgcolor = color.rgb(21, 101, 192), text_size = coachPanelTextSize)
    table.cell(coachTable, 1, startRow, coachWaitFlowTitle, text_color = color.white, bgcolor = coachHeaderBg, text_size = coachPanelTextSize)
    for waitStep = 1 to 7
        table.cell(coachTable, 0, startRow + waitStep, f_waitStepTitle(waitStep), text_color = coachText, bgcolor = coachNeutralBg, text_size = coachPanelTextSize)
        table.cell(coachTable, 1, startRow + waitStep, f_waitStepText(waitStep), text_color = color.white, bgcolor = f_waitStepBg(waitStep), text_size = coachPanelTextSize, text_halign = text.align_left)

f_renderCoachStepGuides() =>
    var line coachStep2TopLine = na
    var line coachStep2BottomLine = na
    var line coachStep3Line = na
    var line coachStep4Line = na
    var line coachStep5Line = na
    var line coachStep6TopLine = na
    var line coachStep6BottomLine = na
    var line coachStep7Line = na
    var box coachStep2ZoneBox = na
    var box coachStep6ZoneBox = na
    var box coachStep6ShortPendingOrderOverlayBox = na
    var label coachStep2TopLabel = na
    var label coachStep2BottomLabel = na
    var label coachStep3Label = na
    var label coachStep4Label = na
    var label coachStep4CenterLabel = na
    var label coachStep5Label = na
    var label coachStep6TopLabel = na
    var label coachStep6BottomLabel = na
    var label coachStep7Label = na
    if barstate.islast
        // 步驟 3～7 僅屬於 15M 執行流程；步驟 2 候選區另外允許在其來源時間軸顯示。
        bool processGuideActive = showCoach and showCoachStepGuides and coachOn15m and coachTfConfigValid and coachWaitFlowDirection != 0
        int guideStage = coachWaitFlowStage
        int guideDirection = coachWaitFlowDirection
        int guideLeftBar = math.max(bar_index - 60, 0)
        int guideRightBar = math.min(bar_index + coachStepGuideRightBars, bar_index + 500)
        bool step2Locked = guideDirection == 1 ? guideStage >= 2 and not na(coachLongEnteredZoneTop) and not na(coachLongEnteredZoneBottom) : guideStage >= 2 and not na(coachShortEnteredZoneTop) and not na(coachShortEnteredZoneBottom)
        bool step2PreviewDataAvailable = not na(coachStep2PreviewTop) and not na(coachStep2PreviewBottom) and str.length(coachStep2PreviewName) > 0
        bool step2SourceTimeframeChart = step2PreviewDataAvailable and ((coachOn1h and coachStep2PreviewFrom1h) or (coachOn4h and coachStep2PreviewFrom4h))
        bool step2Preview = step2PreviewDataAvailable and ((coachOn15m and guideStage == 1) or step2SourceTimeframeChart)
        float step2RawTop = step2Locked ? (guideDirection == 1 ? coachLongEnteredZoneTop : coachShortEnteredZoneTop) : step2Preview ? coachStep2PreviewTop : na
        float step2RawBottom = step2Locked ? (guideDirection == 1 ? coachLongEnteredZoneBottom : coachShortEnteredZoneBottom) : step2Preview ? coachStep2PreviewBottom : na
        float step2Top = f_zoneUpperEdge(step2RawTop, step2RawBottom)
        float step2Bottom = f_zoneLowerEdge(step2RawTop, step2RawBottom)
        string step2ZoneName = step2Locked ? (guideDirection == 1 ? coachLongEnteredHtfZone : coachShortEnteredHtfZone) : step2Preview ? coachStep2PreviewName : guideDirection == 1 ? "多方高週期區" : "空方高週期區"
        string step2ZoneState = step2Locked ? "已進入並鎖定" : step2SourceTimeframeChart ? "來源時間軸驗證｜上一根已確認 " + coachStep2PreviewSourceTf + " K" : coachStep2PreviewInside ? (guideDirection == 1 ? "多單方向候選｜價格已進入" : "空單方向候選｜價格已進入") : (guideDirection == 1 ? "多單方向候選｜尚未進入" : "空單方向候選｜尚未進入")
        int step2ZoneBias = step2Locked ? guideDirection : coachStep2PreviewBias
        bool step2GuideActive = showCoach and showCoachStepGuides and coachTfConfigValid and guideDirection != 0 and (coachOn15m or step2SourceTimeframeChart)
        // 當步驟 6 已完成並進入步驟 7 後，步驟 2 區域與步驟 3 掃蕩線已完成任務，從圖面自動移除以降低干擾。
        bool hideStep2And3Visuals = guideStage >= 7
        bool showStep2Guide = step2GuideActive and not hideStep2And3Visuals and (step2Locked or step2Preview) and not na(step2Top) and not na(step2Bottom)
        float step3Price = guideDirection == 1 ? coachLongSweepLow : coachShortSweepHigh
        float step4Price = guideDirection == 1 ? coachLongTurnTriggerPrice : coachShortTurnTriggerPrice
        float step5Price = guideDirection == 1 ? coachLongBosTriggerPrice : coachShortBosTriggerPrice
        bool step6Locked = guideDirection == 1 ? guideStage >= 6 and not na(coachLongPullbackTop) and not na(coachLongPullbackBottom) : guideStage >= 6 and not na(coachShortPullbackTop) and not na(coachShortPullbackBottom)
        bool step6CandidateReady = guideDirection == 1 ? guideStage >= 5 and not na(coachStep6LongCandidateTop) and not na(coachStep6LongCandidateBottom) and str.length(coachStep6LongCandidateName) > 0 : guideStage >= 5 and not na(coachStep6ShortCandidateTop) and not na(coachStep6ShortCandidateBottom) and str.length(coachStep6ShortCandidateName) > 0
        float step6RawTop = step6Locked ? (guideDirection == 1 ? coachLongPullbackTop : coachShortPullbackTop) : step6CandidateReady ? (guideDirection == 1 ? coachStep6LongCandidateTop : coachStep6ShortCandidateTop) : na
        float step6RawBottom = step6Locked ? (guideDirection == 1 ? coachLongPullbackBottom : coachShortPullbackBottom) : step6CandidateReady ? (guideDirection == 1 ? coachStep6LongCandidateBottom : coachStep6ShortCandidateBottom) : na
        float step6Top = f_zoneUpperEdge(step6RawTop, step6RawBottom)
        float step6Bottom = f_zoneLowerEdge(step6RawTop, step6RawBottom)
        string step6ZoneName = step6Locked ? (guideDirection == 1 ? (str.length(coachLongEntryZone) > 0 ? "15M " + coachLongEntryZone : "15M 多方 OB／FVG") : (str.length(coachShortEntryZone) > 0 ? "15M " + coachShortEntryZone : "15M 空方 OB／FVG")) : guideDirection == 1 ? coachStep6LongCandidateName : coachStep6ShortCandidateName
        bool showStep6Guide = processGuideActive and guideStage >= 5 and (step6Locked or step6CandidateReady) and not na(step6Top) and not na(step6Bottom)
        string step6DirectionText = guideDirection == 1 ? "由上往下回踩" : "由下往上回測"
        string step6StateText = coachTouchTriggersEntry ? (guideStage >= 7 ? "步驟 6 完成｜盤中價格已觸碰" + (guideDirection == 1 ? "多單" : "空單") + "掛單區" : "步驟 6｜" + (guideDirection == 1 ? "多單" : "空單") + "掛單候選區｜等待盤中價格觸碰；觸碰即進入步驟 7") : (guideStage >= 7 ? "步驟 6 完成｜已" + step6DirectionText + "且 15M " + (guideDirection == 1 ? "多方反應 K" : "空方反應 K") + " 已確認" : step6Locked ? "步驟 6 進行中｜價格已" + step6DirectionText + "｜等待 15M " + (guideDirection == 1 ? "多方反應 K" : "空方反應 K") + " 收盤確認" : "步驟 6｜" + (guideDirection == 1 ? "多單" : "空單") + "掛單＋反應 K 候選區｜等待價格" + step6DirectionText + "並確認" + (guideDirection == 1 ? "多方反應 K" : "空方反應 K"))
        float step7Price = guideDirection == 1 ? coachLongReactionTriggerPrice : coachShortReactionTriggerPrice
        color step2Color = step2ZoneBias == 1 ? color.rgb(0, 188, 212) : step2ZoneBias == -1 ? color.rgb(255, 152, 0) : color.rgb(158, 158, 158)
        color step3Color = color.rgb(41, 182, 246)
        color step4Color = color.rgb(171, 71, 188)
        color step5Color = guideDirection == 1 ? color.rgb(0, 200, 83) : color.rgb(255, 82, 82)
        color step6Color = guideDirection == 1 ? color.rgb(0, 188, 212) : color.rgb(255, 193, 7)
        color step7Color = color.rgb(255, 235, 59)
        color step2LineColor = color.new(step2Color, coachStepGuideLineTransparency)
        color step3LineColor = color.new(step3Color, coachStepGuideLineTransparency)
        color step4LineColor = color.new(step4Color, coachStepGuideLineTransparency)
        color step5LineColor = color.new(step5Color, coachStepGuideLineTransparency)
        color step6LineColor = color.new(step6Color, coachStepGuideLineTransparency)
        color step7LineColor = color.new(step7Color, coachStepGuideLineTransparency)
        color step2LabelColor = color.new(step2Color, coachStepGuideLabelTransparency)
        color step3LabelColor = color.new(step3Color, coachStepGuideLabelTransparency)
        color step4LabelColor = color.new(step4Color, coachStepGuideLabelTransparency)
        color step5LabelColor = color.new(step5Color, coachStepGuideLabelTransparency)
        color step6LabelColor = color.new(step6Color, coachStepGuideLabelTransparency)
        color step7LabelColor = color.new(step7Color, coachStepGuideLabelTransparency)
        int step2BoxLeftBar = step2Locked or step2SourceTimeframeChart ? guideLeftBar : math.max(bar_index - 10, 0)
        string step2GuideText = "步驟2｜" + step2ZoneName + "\n上緣 " + str.tostring(step2Top, format.mintick) + "｜下緣 " + str.tostring(step2Bottom, format.mintick) + "\n" + step2ZoneState
        coachStep2ZoneBox := f_syncExitBox(coachStep2ZoneBox, showStep2Guide, step2BoxLeftBar, guideRightBar, step2Top, step2Bottom, "", color.new(step2Color, 0), color.new(step2Color, step2Locked ? 84 : 91), step2Locked ? 3 : 2)
        coachStep2TopLine := f_syncPanelLine(coachStep2TopLine, showStep2Guide and showCoachStepGuideLines, guideLeftBar, guideRightBar, step2Top, step2LineColor, not step2Locked, step2Locked ? 2 : 1)
        coachStep2BottomLine := f_syncPanelLine(coachStep2BottomLine, showStep2Guide and showCoachStepGuideLines, guideLeftBar, guideRightBar, step2Bottom, step2LineColor, not step2Locked, step2Locked ? 2 : 1)
        coachStep2TopLabel := f_syncPanelLabel(coachStep2TopLabel, showStep2Guide and showCoachStepGuideLabels, guideRightBar, (step2Top + step2Bottom) / 2.0, step2GuideText, step2LabelColor)
        coachStep2BottomLabel := f_syncPanelLabel(coachStep2BottomLabel, false, guideRightBar, step2Bottom, "", step2LabelColor)
        coachStep3Line := f_syncPanelLine(coachStep3Line, processGuideActive and not hideStep2And3Visuals and showCoachStepGuideLines and guideStage >= 3 and not na(step3Price), guideLeftBar, guideRightBar, step3Price, step3LineColor, true, 2)
        coachStep3Label := f_syncPanelLabel(coachStep3Label, processGuideActive and not hideStep2And3Visuals and showCoachStepGuideLabels and guideStage >= 3 and not na(step3Price), guideRightBar, step3Price, "步驟3｜" + str.tostring(step3Price, format.mintick) + "｜" + (guideDirection == 1 ? "已掃前低" : "已掃前高"), step3LabelColor)
        int step4SourceBarRaw = guideDirection == 1 ? coachLongTurnTriggerBar : coachShortTurnTriggerBar
        int step4ConfirmBarRaw = guideDirection == 1 ? coachLongTurnBar : coachShortTurnBar
        int step4SweepBarRaw = guideDirection == 1 ? coachLongSweepBar : coachShortSweepBar
        int step4SearchedSourceBar = not na(step4Price) ? f_findRecentStructureBar(step4Price, guideDirection == 1) : na
        int step4SourceBarResolved = not na(step4SourceBarRaw) ? step4SourceBarRaw : not na(step4SearchedSourceBar) ? step4SearchedSourceBar : not na(step4SweepBarRaw) ? math.max(step4SweepBarRaw - 1, 0) : math.max(bar_index - structureLen, 0)
        bool step4Completed = guideStage >= 4 and not na(step4ConfirmBarRaw)
        // 等待步驟 4 時保留原本向右延伸的虛線；完成後刪除動態引導線，
        // 僅保留由結構 Pivot K 棒連到第一根 15M MSS 確認 K 棒的歷史線。
        bool showStep4WaitingLine = processGuideActive and guideStage >= 3 and not step4Completed and not na(step4Price) and showMssGuide and showCoachStepGuideLines
        int step4LineLeftBar = math.max(step4SourceBarResolved, bar_index - 9999)
        int step4LineRightBar = guideRightBar
        coachStep4Line := f_syncPanelLine(coachStep4Line, showStep4WaitingLine, step4LineLeftBar, step4LineRightBar, step4Price, step4LineColor, true, 2)
        string step4LabelState = guideStage >= 4 ? (guideDirection == 1 ? "15M 收盤已站上 " + str.tostring(step4Price, format.mintick) + "｜多方 MSS 確認完成" : "15M 收盤已跌破 " + str.tostring(step4Price, format.mintick) + "｜空方 MSS 確認完成") : (guideDirection == 1 ? "等待 15M 多方 MSS 確認價 " + str.tostring(step4Price, format.mintick) + "｜等待 15M 收盤站上" : "等待 15M 空方 MSS 確認價 " + str.tostring(step4Price, format.mintick) + "｜等待 15M 收盤跌破")
        coachStep4Label := f_syncPanelLabel(coachStep4Label, processGuideActive and showCoachStepGuideLabels and guideStage >= 3 and not na(step4Price), guideRightBar, step4Price, "步驟4｜" + step4LabelState, step4LabelColor)
        bool showStep4CenterText = showStep4WaitingLine and showStructureText
        int step4CenterBar = step4LineLeftBar + int(math.floor((step4LineRightBar - step4LineLeftBar) * 0.5))
        string step4CenterTooltip = f_mssTooltip(guideDirection == 1, step4Price, step4SourceBarResolved, na, step4LabelState)
        coachStep4CenterLabel := f_syncPanelLabel(coachStep4CenterLabel, showStep4CenterText, step4CenterBar, step4Price, "MSS", step4LineColor)
        if not na(coachStep4CenterLabel)
            label.set_style(coachStep4CenterLabel, label.style_label_down)
            label.set_color(coachStep4CenterLabel, color.new(step4Color, 100))
            label.set_textcolor(coachStep4CenterLabel, step4Color)
            label.set_tooltip(coachStep4CenterLabel, step4CenterTooltip)
        coachStep5Line := f_syncPanelLine(coachStep5Line, processGuideActive and showCoachStepGuideLines and guideStage >= 4 and not na(step5Price), guideLeftBar, guideRightBar, step5Price, step5LineColor, false, 2)
        coachStep5Label := f_syncPanelLabel(coachStep5Label, processGuideActive and showCoachStepGuideLabels and guideStage >= 4 and not na(step5Price), guideRightBar, step5Price, "步驟5｜" + str.tostring(step5Price, format.mintick) + "｜" + (guideStage >= 5 ? "BOS 完成" : "等待 BOS"), step5LabelColor)
        string step6BoxText = showStep6Guide ? step6StateText + "｜" + step6ZoneName + "｜" + f_priceRangeText(step6Top, step6Bottom) : ""
        coachStep6ZoneBox := f_syncExitBox(coachStep6ZoneBox, showStep6Guide, math.max(bar_index - 10, 0), guideRightBar, step6Top, step6Bottom, step6BoxText, color.new(step6Color, 0), color.new(step6Color, step6Locked ? 84 : 92), step6Locked ? 3 : 2)
        // 圖面層級（由內到外）：原始空方訂單區 → 掛單(空)區域覆蓋層 → 步驟 6 上下緣與標籤。
        bool step6ShortOverlayVisible = showStep6ShortPendingOrderOverlay and showStep6Guide and guideDirection == -1 and str.contains(step6ZoneName, "空方訂單區")
        int step6OverlayLeftBar = math.max(bar_index - 10, 0)
        color step6ShortOverlayBorder = color.rgb(255, 183, 77)
        color step6ShortOverlayFill = color.new(color.rgb(104, 55, 0), 0)
        string step6ShortOverlayText = step6ShortOverlayVisible ? (coachTouchTriggersEntry ? "掛單(空)區域｜盤中觸碰即進場｜" : "掛單(空)區域｜") + f_priceRangeText(step6Top, step6Bottom) : ""
        coachStep6ShortPendingOrderOverlayBox := f_syncStep6OrderOverlayBox(coachStep6ShortPendingOrderOverlayBox, step6ShortOverlayVisible, step6OverlayLeftBar, guideRightBar, step6Top, step6Bottom, step6ShortOverlayText, step6ShortOverlayBorder, step6ShortOverlayFill, 2)
        coachStep6TopLine := f_syncPanelLine(coachStep6TopLine, showStep6Guide and showCoachStepGuideLines, guideLeftBar, guideRightBar, step6Top, step6LineColor, not step6Locked, step6Locked ? 2 : 1)
        coachStep6BottomLine := f_syncPanelLine(coachStep6BottomLine, showStep6Guide and showCoachStepGuideLines, guideLeftBar, guideRightBar, step6Bottom, step6LineColor, not step6Locked, step6Locked ? 2 : 1)
        coachStep6TopLabel := f_syncPanelLabel(coachStep6TopLabel, showStep6Guide and showCoachStepGuideLabels, guideRightBar, step6Top, "步驟6 上緣｜" + str.tostring(step6Top, format.mintick) + "｜" + step6ZoneName + "｜" + step6StateText, step6LabelColor)
        coachStep6BottomLabel := f_syncPanelLabel(coachStep6BottomLabel, showStep6Guide and showCoachStepGuideLabels, guideRightBar, step6Bottom, "步驟6 下緣｜" + str.tostring(step6Bottom, format.mintick) + "｜" + step6ZoneName + "｜" + step6StateText, step6LabelColor)
        coachStep7Line := f_syncPanelLine(coachStep7Line, processGuideActive and showCoachStepGuideLines and guideStage >= 7 and not na(step7Price), guideLeftBar, guideRightBar, step7Price, step7LineColor, false, 3)
        string step7DirectionText = guideDirection == 1 ? "多單" : "空單"
        string step7ReactionText = guideDirection == 1 ? "多方反應 K" : "空方反應 K"
        string step7LabelText = coachTouchTriggersEntry ? "步驟7完成｜盤中價格已觸碰掛單區｜建議" + step7DirectionText + "進場價 " + str.tostring(step7Price, format.mintick) + "｜請手動更新持倉設定" : "步驟7完成｜15M " + step7ReactionText + " 已確認｜建議" + step7DirectionText + "進場價 " + str.tostring(step7Price, format.mintick) + "｜請手動更新持倉設定"
        coachStep7Label := f_syncPanelLabel(coachStep7Label, processGuideActive and showCoachStepGuideLabels and guideStage >= 7 and not na(step7Price), guideRightBar, step7Price, step7LabelText, step7LabelColor)
    0

f_renderCoachStepGuides()

f_renderStep8TopRightPanel() =>
    if barstate.islast
        table.clear(coachStep8TopRightTable, 0, 0, 0, 0)
        if coachStep8TopRightVisible
            table.cell(
                 coachStep8TopRightTable,
                 0,
                 0,
                 coachStep8TopRightText,
                 text_color = color.white,
                 bgcolor = coachStep8TopRightBg,
                 text_size = step8TopRightTextSize,
                 text_halign = text.align_center,
                 text_valign = text.align_center,
                 width = 28)
    0

f_renderCoachTable() =>
    if barstate.islast
        if showCoach
            table.clear(coachTable, 0, 0, 1, 22)

            if coachOn15m and coachTfConfigValid
                bool panelCompact = coachPanelMode == "精簡面板"

                if panelCompact
                    table.cell(coachTable, 0, 0, "SMC 教練", text_color = color.white, bgcolor = coachHeaderBg, text_size = coachPanelTextSize)
                    table.cell(coachTable, 1, 0, coachModeText, text_color = color.white, bgcolor = coachHeaderBg, text_size = coachPanelTextSize)
                    f_panelRow(1, "持倉狀態", positionPanelText, positionStatusBg)
                    f_panelRow(2, "方向", coachDirectionText, coachTrendConflict ? coachFailBg : coachNeutralBg)
                    f_panelRow(3, "進場／持倉進度", coachStageDisplayText, coachStageDisplayBg)
                    f_panelRow(4, "市場位置", coachActiveZoneStatus, coachHtfZoneBg)
                    f_panelRow(5, "1H 通道", channel1hCoachStatus, channel1hCoachBg)
                    f_drawWaitingFlow(6)
                else
                    table.cell(coachTable, 0, 0, "SMC 多空教練", text_color = color.white, bgcolor = coachHeaderBg, text_size = coachPanelTextSize)
                    table.cell(coachTable, 1, 0, coachModeText, text_color = color.white, bgcolor = coachHeaderBg, text_size = coachPanelTextSize)
                    f_panelRow(1, "持倉狀態", positionPanelText, positionStatusBg)
                    f_panelRow(2, "目前教練", coachDirectionText, coachIsLongView ? coachLongBg : coachIsShortView ? coachShortBg : coachTrendConflict ? coachWaitBg : coachNeutralBg)
                    f_panelRow(3, "日線／4H 背景", coach1d4hStateText + "｜" + coachDailyRelationText, color.new(f_trendColor(coachTrend4h), 30))
                    f_panelRow(4, "1H 階段", coach1hBearTurnPanelText, color.new(f_trendColor(coachTrend1h), 30))
                    f_panelRow(5, "15M 結構", f_trendText(structureTrend), color.new(f_trendColor(structureTrend), 30))
                    f_panelRow(6, coachZoneRowTitle, coachActiveZoneStatus, coachHtfZoneBg)
                    f_panelRow(7, coachSweepRowTitle, coachActiveSweepStatus, coachActiveStage >= 3 ? coachPassBg : coachWaitBg)
                    f_panelRow(8, coachChochRowTitle, coachActiveChochStatus, coachActiveStage >= 4 ? coachPassBg : coachWaitBg)
                    f_panelRow(9, "15M 結構突破確認", coachActiveBosStatus, coachActiveStage >= 5 ? coachPassBg : coachWaitBg)
                    f_panelRow(10, coachPullbackRowTitle, coachActivePullbackStatus, coachActiveInvalid ? coachFailBg : coachActiveStage >= 7 ? coachReactionDoneBg : coachWaitBg)
                    f_panelRow(11, "1H 平行通道", channel1hCoachStatus, channel1hCoachBg)
                    f_panelRow(12, "進場／持倉提示", coachStageDisplayText, coachTrendConflict and not coachStep8WaitingManualPosition and not coachStep8PositionActive ? coachWaitBg : coachStageDisplayBg)
                    f_drawWaitingFlow(13)
            else if showDedicatedTfPanels and (coachOn1d or coachOn1h or coachOn4h) and coachTfConfigValid
                if coachOn1d
                    table.cell(coachTable, 0, 0, "日線市場背景", text_color = color.white, bgcolor = color.rgb(63, 81, 181), text_size = coachPanelTextSize)
                    table.cell(coachTable, 1, 0, "步驟 1｜確認大環境與重大高低點", text_color = color.white, bgcolor = color.rgb(63, 81, 181), text_size = coachPanelTextSize)
                    f_panelRow(1, "持倉狀態", positionPanelText, positionStatusBg)
                    f_panelRow(2, "日線方向", f_trendText(coachTrend1d), color.new(f_trendColor(coachTrend1d), 30))
                    f_panelRow(3, "結構高低點", panelDailyStructure, coachNeutralBg)
                    f_panelRow(4, "最近結構事件", panelDailyEvent, coachEvent1d == 0 ? coachNeutralBg : coachPassBg)
                    f_panelRow(5, "目前階段", f_marketPhaseText(coachPhase1d), coachWaitBg)
                    f_panelRow(6, "目前位置", f_rangePositionText(coachPosition1d), coachPosition1d == -1 ? coachLongBg : coachPosition1d == 1 ? coachShortBg : coachNeutralBg)
                    f_panelRow(7, "日線重大高點", panelDailyHigh, coachNeutralBg)
                    f_panelRow(8, "日線重大低點", panelDailyLow, coachNeutralBg)
                    f_panelRow(9, "流動性掃蕩", panelDailySweep, coachNeutralBg)
                    f_panelRow(10, "結構失效／轉向價", f_breakLevelText(coachTrend1d, coachSwingHigh1d, coachSwingLow1d), coachWaitBg)
                    f_panelRow(11, "日線教練結論", panelDailyAction, color.new(f_trendColor(coachTrend1d), 35))
                else if coachOn4h
                    table.cell(coachTable, 0, 0, "4H 主方向面板", text_color = color.white, bgcolor = color.rgb(63, 81, 181), text_size = coachPanelTextSize)
                    table.cell(coachTable, 1, 0, "步驟 2～3｜方向、流動性與交易區域", text_color = color.white, bgcolor = color.rgb(63, 81, 181), text_size = coachPanelTextSize)
                    f_panelRow(1, "持倉狀態", positionPanelText, positionStatusBg)
                    f_panelRow(2, "日線關係", coachDailyRelationText, coachTrend1d == coachTrend4h and coachTrend4h != 0 ? coachPassBg : coachWaitBg)
                    f_panelRow(3, "4H 主方向", f_trendText(coachTrend4h), color.new(f_trendColor(coachTrend4h), 30))
                    f_panelRow(4, "結構高低點", panel4hStructure, coachNeutralBg)
                    f_panelRow(5, "最近 BOS／CHoCH", panel4hEvent, coachEvent4h == 0 ? coachNeutralBg : coachPassBg)
                    f_panelRow(6, "推進／回調", f_marketPhaseText(coachPhase4h), coachWaitBg)
                    f_panelRow(7, "溢價／折價", f_rangePositionText(coachPosition4h), coachPosition4h == -1 ? coachLongBg : coachPosition4h == 1 ? coachShortBg : coachNeutralBg)
                    f_panelRow(8, "上方結構／流動性", panel4hHigh, coachNeutralBg)
                    f_panelRow(9, "下方結構／流動性", panel4hLow, coachNeutralBg)
                    f_panelRow(10, "流動性掃蕩", panel4hSweep, coachNeutralBg)
                    f_panelRow(11, "下方多方區", panel4hBullZone, coachLongBg)
                    f_panelRow(12, "上方空方區", panel4hBearZone, coachShortBg)
                    f_panelRow(13, "步驟2候選區", coachStep2PreviewFrom4h ? coachStep2PreviewConfirmedText : "目前步驟 2 候選來源不是 4H", coachStep2PreviewFrom4h ? coachWaitBg : coachNeutralBg)
                    f_panelRow(14, "1H 所處階段", coach1hRelationText, coachWaitBg)
                    f_panelRow(15, "4H 教練結論", panel4hAction, color.new(f_trendColor(coachTrend4h), 35))
                else
                    bool showPositionExitPanel = positionRequestedHasValidEntry or positionTradeClosed
                    table.cell(coachTable, 0, 0, showPositionExitPanel ? "1H 持倉離場面板" : "1H 內部結構面板", text_color = color.white, bgcolor = color.rgb(0, 121, 107), text_size = coachPanelTextSize)
                    table.cell(coachTable, 1, 0, showPositionExitPanel ? "步驟 8｜TP1～TP4／手動 TP 管理" : "步驟 4～5｜細化結構與等待區域", text_color = color.white, bgcolor = color.rgb(0, 121, 107), text_size = coachPanelTextSize)
                    if showPositionExitPanel
                        f_panelRow(1, "持倉狀態", positionPanelText, positionStatusBg)
                        f_panelRow(2, "預計出場 TP", positionPlannedTpPanelText, positionSelectedTpValid ? color.new(color.rgb(255, 235, 59), 52) : coachNeutralBg)
                        f_panelRow(3, "15M SMC 停損／SL 區", positionStopPanelText, not na(positionSelectedStopPrice) ? color.new(color.rgb(244, 67, 54), 72) : coachWaitBg)
                        int panelTpCount = positionManualTpMode ? 1 : math.min(positionTpCount, POSITION_MAX_TP)
                        if positionManualTpMode
                            float manualRewardDistance = positionManualTpValid ? math.abs(positionEntryPriceInput - positionManualTpPriceInput) : na
                            float manualRr = not na(manualRewardDistance) and not na(positionRiskDistance) and positionRiskDistance > 0 ? manualRewardDistance / positionRiskDistance : na
                            string manualTpValue = positionManualTpValid ? "手動 TP｜離場點 " + str.tostring(positionManualTpPriceInput, format.mintick) + (not na(manualRr) ? "｜盈虧比 1:" + str.tostring(manualRr, "#.##") : "") + (positionTradeClosed and positionTradeClosedTp == 0 ? "｜已觸碰獲利出場" : "｜等待觸碰") : "請輸入正確方向且大於 0 的手動 TP 價格"
                            f_panelRow(4, "手動 TP ★ 預計出場", manualTpValue, positionManualTpValid ? color.new(color.rgb(255, 235, 59), 52) : coachWaitBg)
                        else if panelTpCount > 0
                            for i = 0 to panelTpCount - 1
                                int tpNumber = i + 1
                                float zoneTop = array.get(positionTpTops, i)
                                float zoneBottom = array.get(positionTpBottoms, i)
                                int zoneType = array.get(positionTpTypes, i)
                                float exitPrice = f_exitZoneNearEdge(positionRequestedDirection, zoneTop, zoneBottom)
                                float rewardDistance = math.abs(positionEntryPriceInput - exitPrice)
                                float rrMultiple = not na(positionRiskDistance) and positionRiskDistance > 0 ? rewardDistance / positionRiskDistance : na
                                bool selectedTp = positionPlannedTpNumber == tpNumber
                                bool touchedTp = positionTradeClosed and positionTradeClosedTp == tpNumber
                                string tpTitle = "TP" + str.tostring(tpNumber) + (selectedTp ? " ★ 預計出場" : "")
                                string tpValue = f_exitZoneTypeText(positionRequestedDirection, zoneType) + "｜" + f_priceRangeText(zoneTop, zoneBottom) + "｜區域中線 " + str.tostring(exitPrice, format.mintick) + (not na(rrMultiple) ? "｜盈虧比 1:" + str.tostring(rrMultiple, "#.##") : "") + (touchedTp ? "｜已觸碰獲利出場" : selectedTp ? "｜等待觸碰" : "")
                                color tpBg = touchedTp ? coachPassBg : selectedTp ? color.new(color.rgb(255, 235, 59), 52) : color.new(f_tpPaletteColor(tpNumber), 70)
                                f_panelRow(4 + i, tpTitle, tpValue, tpBg)
                        int exitCoachRow = 4 + panelTpCount
                        f_panelRow(exitCoachRow, positionManualTpMode ? "手動 TP 狀態" : "TP 區域統計", positionTpCountText, positionManualTpMode ? (positionManualTpValid ? coachPassBg : coachWaitBg) : positionTpCount > 0 ? coachPassBg : coachWaitBg)
                        f_panelRow(exitCoachRow + 1, "步驟 8 離場教練", positionExitCoachText, positionTradeClosed ? coachPassBg : positionHasValidEntry ? coachPassBg : coachWaitBg)
                        f_panelRow(exitCoachRow + 2, "4H／1H 關係", coach1hRelationText, coachTrend4h == coachTrend1h and coachTrend1h != 0 ? coachPassBg : coachWaitBg)
                        f_panelRow(exitCoachRow + 3, "1H 結構方向", f_trendText(coachTrend1h), color.new(f_trendColor(coachTrend1h), 30))
                        f_panelRow(exitCoachRow + 4, "最近 BOS／CHoCH", panel1hEvent, coachEvent1h == 0 ? coachNeutralBg : coachPassBg)
                    else
                        f_panelRow(1, "持倉狀態", positionPanelText, positionStatusBg)
                        f_panelRow(2, "4H／1H 關係", coach1hRelationText, coachTrend4h == coachTrend1h and coachTrend1h != 0 ? coachPassBg : coachWaitBg)
                        f_panelRow(3, "1H 結構方向", f_trendText(coachTrend1h), color.new(f_trendColor(coachTrend1h), 30))
                        f_panelRow(4, "結構高低點", panel1hStructure, coachNeutralBg)
                        f_panelRow(5, "最近 BOS／CHoCH", panel1hEvent, coachEvent1h == 0 ? coachNeutralBg : coachPassBg)
                        f_panelRow(6, "推進／回調", f_marketPhaseText(coachPhase1h), coachWaitBg)
                        f_panelRow(7, "溢價／折價", f_rangePositionText(coachPosition1h), coachPosition1h == -1 ? coachLongBg : coachPosition1h == 1 ? coachShortBg : coachNeutralBg)
                        f_panelRow(8, "上方結構／流動性", panel1hHigh, coachNeutralBg)
                        f_panelRow(9, "下方結構／流動性", panel1hLow, coachNeutralBg)
                        f_panelRow(10, "流動性掃蕩", panel1hSweep, coachNeutralBg)
                        f_panelRow(11, "下方多方區", panel1hBullZone, coachLongBg)
                        f_panelRow(12, "上方空方區", panel1hBearZone, coachShortBg)
                        f_panelRow(13, "步驟2候選區", coachStep2PreviewFrom1h ? coachStep2PreviewConfirmedText : "目前步驟 2 候選來源不是 1H", coachStep2PreviewFrom1h ? coachWaitBg : coachNeutralBg)
                        f_panelRow(14, "結構失效／轉向價", f_breakLevelText(coachTrend1h, coachSwingHigh1h, coachSwingLow1h), coachWaitBg)
                        f_panelRow(15, "下一步", panel1hAction, color.new(f_trendColor(coachTrend4h), 35))
            else
                table.cell(coachTable, 0, 0, "SMC 多空教練", text_color = color.white, bgcolor = color.rgb(13, 37, 63), text_size = coachPanelTextSize)
                table.cell(coachTable, 1, 0, not coachTfConfigValid ? coachTfConfigErrorText : coachWrongTfText, text_color = color.white, bgcolor = color.new(color.rgb(110, 55, 65), 8), text_size = coachPanelTextSize)
                f_panelRow(1, "持倉狀態", positionPanelText, positionStatusBg)
        else
            table.clear(coachTable, 0, 0, 1, 22)
    0

f_renderCoachTable()
f_renderStep8TopRightPanel()

// ============================================================================
// 警報採單一 Any alert() function call；15M 通知步驟 1～8 與退回，1H 通知 TP／SL。
// ============================================================================
