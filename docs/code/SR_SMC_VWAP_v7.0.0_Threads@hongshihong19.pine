// 進場位置獨立放在盈虧比圖左側，不再與 SL／TP 區域文字共用同一個位置。
f_syncPositionEntryLabel(label currentLabel, bool visible, int labelBar, float price, string labelText, color labelColor) =>
    label resultLabel = currentLabel
    if visible and not na(price)
        if na(resultLabel)
            resultLabel := label.new(labelBar, price, labelText, xloc = xloc.bar_index, style = label.style_label_right, color = color.new(labelColor, 8), textcolor = color.white, size = size.small)
        else
            label.set_xy(resultLabel, labelBar, price)
            label.set_text(resultLabel, labelText)
            label.set_style(resultLabel, label.style_label_right)
            label.set_color(resultLabel, color.new(labelColor, 8))
            label.set_textcolor(resultLabel, color.white)
            label.set_size(resultLabel, size.small)
    else if not na(resultLabel)
        label.delete(resultLabel)
        resultLabel := na
    resultLabel

// 面板區域採 OB 優先、FVG 次之、支撐／阻力備援；以 tuple 減少 main body 敘述。
f_selectPanelZone(float firstTop, float firstBottom, float secondTop, float secondBottom, float thirdTop, float thirdBottom) =>
    bool useFirst = not na(firstTop) and not na(firstBottom)
    bool useSecond = not useFirst and not na(secondTop) and not na(secondBottom)
    float selectedTop = useFirst ? firstTop : useSecond ? secondTop : thirdTop
    float selectedBottom = useFirst ? firstBottom : useSecond ? secondBottom : thirdBottom
    [selectedTop, selectedBottom]

// 回傳面板實際採用的區域類型：1＝OB、2＝FVG、3＝支撐／阻力、0＝無有效區域。
f_selectPanelZoneType(float firstTop, float firstBottom, float secondTop, float secondBottom, float thirdTop, float thirdBottom) =>
    bool useFirst = not na(firstTop) and not na(firstBottom)
    bool useSecond = not useFirst and not na(secondTop) and not na(secondBottom)
    bool useThird = not useFirst and not useSecond and not na(thirdTop) and not na(thirdBottom)
    useFirst ? 1 : useSecond ? 2 : useThird ? 3 : 0

f_bullZoneSummary(string tfName, float obTop, float obBottom, float fvgTop, float fvgBottom, float supportTop, float supportBottom) =>
    not na(obTop) and not na(obBottom) ? tfName + " 多方 OB｜" + f_priceRangeText(obTop, obBottom) : not na(fvgTop) and not na(fvgBottom) ? tfName + " 多方 FVG｜" + f_priceRangeText(fvgTop, fvgBottom) : not na(supportTop) and not na(supportBottom) ? tfName + " 支撐區｜" + f_priceRangeText(supportTop, supportBottom) : tfName + " 尚無下方有效區域"

f_bearZoneSummary(string tfName, float obTop, float obBottom, float fvgTop, float fvgBottom, float resistanceTop, float resistanceBottom) =>
    not na(obTop) and not na(obBottom) ? tfName + " 空方 OB｜" + f_priceRangeText(obTop, obBottom) : not na(fvgTop) and not na(fvgBottom) ? tfName + " 空方 FVG｜" + f_priceRangeText(fvgTop, fvgBottom) : not na(resistanceTop) and not na(resistanceBottom) ? tfName + " 阻力區｜" + f_priceRangeText(resistanceTop, resistanceBottom) : tfName + " 尚無上方有效區域"


// 同類型區域重疊率：重疊高度 ÷ 較小區域高度。
// 各類型使用獨立陣列，因此支撐只比支撐、阻力只比阻力、OB／FVG 也只比同方向同類型。
f_sameTypeZoneOverlapRatio(float firstTop, float firstBottom, float secondTop, float secondBottom) =>
    float firstUpper = math.max(firstTop, firstBottom)
    float firstLower = math.min(firstTop, firstBottom)
    float secondUpper = math.max(secondTop, secondBottom)
    float secondLower = math.min(secondTop, secondBottom)
    float overlapHeight = math.max(math.min(firstUpper, secondUpper) - math.max(firstLower, secondLower), 0.0)
    float smallerHeight = math.min(firstUpper - firstLower, secondUpper - secondLower)
    smallerHeight > 0.0 ? overlapHeight / smallerHeight : 0.0

// 完整包含只看價格上下界：內層區域保留原色顯示在外層區域裡，不做跨類型抑制。
f_zoneFullyContains(float outerTop, float outerBottom, float innerTop, float innerBottom) =>
    float outerUpper = math.max(outerTop, outerBottom)
    float outerLower = math.min(outerTop, outerBottom)
    float innerUpper = math.max(innerTop, innerBottom)
    float innerLower = math.min(innerTop, innerBottom)
    outerUpper >= innerUpper and outerLower <= innerLower

f_zoneHasFullContainment(float firstTop, float firstBottom, float secondTop, float secondBottom) =>
    f_zoneFullyContains(firstTop, firstBottom, secondTop, secondBottom) or f_zoneFullyContains(secondTop, secondBottom, firstTop, firstBottom)

// 候選區域與較高優先級區域只有「部分重疊」時才抑制；完整包含時保留兩者。
f_boxPartiallyOverlapsHigher(box candidateBox, array<box> higherPriorityBoxes, float overlapThreshold) =>
    bool found = false
    if array.size(higherPriorityBoxes) > 0
        int higherIndex = array.size(higherPriorityBoxes) - 1
        while higherIndex >= 0 and not found
            box higherBox = array.get(higherPriorityBoxes, higherIndex)
            bool horizontalOverlap = math.min(box.get_right(candidateBox), box.get_right(higherBox)) > math.max(box.get_left(candidateBox), box.get_left(higherBox))
            float overlapRatio = f_sameTypeZoneOverlapRatio(box.get_top(candidateBox), box.get_bottom(candidateBox), box.get_top(higherBox), box.get_bottom(higherBox))
            bool fullyContained = f_zoneHasFullContainment(box.get_top(candidateBox), box.get_bottom(candidateBox), box.get_top(higherBox), box.get_bottom(higherBox))
            found := horizontalOverlap and overlapRatio >= overlapThreshold and not fullyContained
            higherIndex -= 1
    found

f_boxSuppressedByPriority(box candidateBox, array<box> higherPriorityOne, array<box> higherPriorityTwo, bool useHigherOne, bool useHigherTwo, bool applyPriority, float overlapThreshold) =>
    applyPriority and ((useHigherOne and f_boxPartiallyOverlapsHigher(candidateBox, higherPriorityOne, overlapThreshold)) or (useHigherTwo and f_boxPartiallyOverlapsHigher(candidateBox, higherPriorityTwo, overlapThreshold)))

// 面板投影區域使用相同規則：部分重疊依優先級抑制，完整包含則保留。
f_floatZonePartiallyOverlapsHigher(float zoneTop, float zoneBottom, int zoneLeft, int zoneRight, array<box> higherPriorityBoxes, float overlapThreshold) =>
    bool found = false
    if not na(zoneTop) and not na(zoneBottom) and array.size(higherPriorityBoxes) > 0
        int higherIndex = array.size(higherPriorityBoxes) - 1
        while higherIndex >= 0 and not found
            box higherBox = array.get(higherPriorityBoxes, higherIndex)
            bool horizontalOverlap = math.min(zoneRight, box.get_right(higherBox)) > math.max(zoneLeft, box.get_left(higherBox))
            float overlapRatio = f_sameTypeZoneOverlapRatio(zoneTop, zoneBottom, box.get_top(higherBox), box.get_bottom(higherBox))
            bool fullyContained = f_zoneHasFullContainment(zoneTop, zoneBottom, box.get_top(higherBox), box.get_bottom(higherBox))
            found := horizontalOverlap and overlapRatio >= overlapThreshold and not fullyContained
            higherIndex -= 1
    found

// 檢查高週期投影是否與目前圖表已存在的同類實體區域重疊。
// 用於避免同一個 4H／1H OB、FVG、支撐或阻力同時以「實體區域＋投影區域」畫兩次。
f_hasSameTypeZoneOverlap(array<box> id, float zoneTop, float zoneBottom, float overlapThreshold) =>
    bool found = false
    if not na(zoneTop) and not na(zoneBottom) and array.size(id) > 0
        int overlapIndex = array.size(id) - 1
        while overlapIndex >= 0 and not found
            box currentBox = array.get(id, overlapIndex)
            float overlapRatio = f_sameTypeZoneOverlapRatio(box.get_top(currentBox), box.get_bottom(currentBox), zoneTop, zoneBottom)
            found := overlapRatio >= overlapThreshold
            overlapIndex -= 1
    found

// 同類區域底層物件不再改成外接大矩形。
// 每一個原始 box 都保留，供失效、角色互換、FVG 回補與教練計算使用；
// 重疊抑制只在最後一根 K 棒建立獨立的階梯形視覺聯集。
// §UNJ73QO5AFQ6§ ©2026 Threads(@hongshihong19)｜函數／f_addBox
f_addBox(array<box> id, box newBox, int maxCount, bool suppressOverlap, float overlapThreshold) =>
    array.push(id, newBox)
    if array.size(id) > maxCount
        box oldBox = array.shift(id)
        box.delete(oldBox)

// 清除上一輪動態建立的階梯形聯集圖面。
f_clearStepZoneVisuals(array<polyline> outlines, array<box> textBoxes) =>
    while array.size(outlines) > 0
        polyline.delete(array.pop(outlines))
    while array.size(textBoxes) > 0
        box.delete(array.pop(textBoxes))

// 還原底層矩形的正常顯示樣式。
f_restoreZoneBoxes(array<box> id, bool visible, color borderColor, color fillColor, string zoneText, bool showText, array<box> higherPriorityOne, array<box> higherPriorityTwo, bool useHigherOne, bool useHigherTwo, bool applyPriority, float overlapThreshold) =>
    if array.size(id) > 0
        for currentBox in id
            bool prioritySuppressed = f_boxSuppressedByPriority(currentBox, higherPriorityOne, higherPriorityTwo, useHigherOne, useHigherTwo, applyPriority, overlapThreshold)
            bool currentVisible = visible and not prioritySuppressed
            box.set_border_color(currentBox, currentVisible ? borderColor : color.new(borderColor, 100))
            box.set_bgcolor(currentBox, currentVisible ? fillColor : color.new(fillColor, 100))
            box.set_text(currentBox, currentVisible and showText ? zoneText : "")
            box.set_text_color(currentBox, zoneTextColor)
            box.set_text_size(currentBox, size.auto)
            box.set_text_halign(currentBox, text.align_center)
            box.set_text_valign(currentBox, text.align_center)

// 以兩個同類矩形的聯集建立階梯形多邊形。
// 較早開始的區域保留左側高度，較晚開始後改用兩區上下界聯集，形成使用者示意圖中的階梯外框。
f_createStepZoneVisual(box firstBox, box secondBox, color borderColor, color fillColor, string zoneText, bool showText, array<polyline> outlines, array<box> textBoxes) =>
    int firstLeft = box.get_left(firstBox)
    int secondLeft = box.get_left(secondBox)
    box earlyBox = firstLeft <= secondLeft ? firstBox : secondBox
    box lateBox = firstLeft <= secondLeft ? secondBox : firstBox
    int earlyLeft = box.get_left(earlyBox)
    int stepLeft = box.get_left(lateBox)
    int rightEdge = math.max(box.get_right(earlyBox), box.get_right(lateBox))
    float earlyTop = box.get_top(earlyBox)
    float earlyBottom = box.get_bottom(earlyBox)
    float unionTop = math.max(earlyTop, box.get_top(lateBox))
    float unionBottom = math.min(earlyBottom, box.get_bottom(lateBox))
    array<chart.point> points = array.new<chart.point>()
    array.push(points, chart.point.from_index(earlyLeft, earlyTop))
    array.push(points, chart.point.from_index(stepLeft, earlyTop))
    array.push(points, chart.point.from_index(stepLeft, unionTop))
    array.push(points, chart.point.from_index(rightEdge, unionTop))
    array.push(points, chart.point.from_index(rightEdge, unionBottom))
    array.push(points, chart.point.from_index(stepLeft, unionBottom))
    array.push(points, chart.point.from_index(stepLeft, earlyBottom))
    array.push(points, chart.point.from_index(earlyLeft, earlyBottom))
    polyline outline = polyline.new(points, curved = false, closed = true, xloc = xloc.bar_index, line_color = borderColor, fill_color = fillColor, line_style = line.style_solid, line_width = 1)
    array.push(outlines, outline)
    if showText
        box textBox = box.new(left = stepLeft, top = unionTop, right = rightEdge, bottom = unionBottom, xloc = xloc.bar_index, border_color = color.new(borderColor, 100), border_width = 0, bgcolor = color.new(fillColor, 100), text = zoneText, text_color = zoneTextColor, text_size = size.small, text_halign = text.align_left, text_valign = text.align_top)
        array.push(textBoxes, textBox)

// 每個同類陣列最多把一組「重疊度最高」的區域畫成階梯形聯集。
// 其他未配對區域維持原矩形，避免三個以上區域連鎖合併成巨大區塊。
f_renderStepZonePair(array<box> id, bool visible, color borderColor, color fillColor, string zoneText, bool showText, float overlapThreshold, array<box> higherPriorityOne, array<box> higherPriorityTwo, bool useHigherOne, bool useHigherTwo, bool applyPriority, array<polyline> outlines, array<box> textBoxes) =>
    f_restoreZoneBoxes(id, visible, borderColor, fillColor, zoneText, showText, higherPriorityOne, higherPriorityTwo, useHigherOne, useHigherTwo, applyPriority, overlapThreshold)
    if visible and suppressSameTypeZoneOverlap and array.size(id) >= 2
        int bestFirst = -1
        int bestSecond = -1
        float bestRatio = overlapThreshold
        for i = 0 to array.size(id) - 2
            box firstBox = array.get(id, i)
            bool firstSuppressed = f_boxSuppressedByPriority(firstBox, higherPriorityOne, higherPriorityTwo, useHigherOne, useHigherTwo, applyPriority, overlapThreshold)
            if not firstSuppressed
                for j = i + 1 to array.size(id) - 1
                    box secondBox = array.get(id, j)
                    bool secondSuppressed = f_boxSuppressedByPriority(secondBox, higherPriorityOne, higherPriorityTwo, useHigherOne, useHigherTwo, applyPriority, overlapThreshold)
                    if not secondSuppressed
                        float ratio = f_sameTypeZoneOverlapRatio(box.get_top(firstBox), box.get_bottom(firstBox), box.get_top(secondBox), box.get_bottom(secondBox))
                        bool horizontalOverlap = math.min(box.get_right(firstBox), box.get_right(secondBox)) > math.max(box.get_left(firstBox), box.get_left(secondBox))
                        if horizontalOverlap and ratio >= bestRatio
                            bestRatio := ratio
                            bestFirst := i
                            bestSecond := j
        if bestFirst >= 0 and bestSecond >= 0
            box firstBox = array.get(id, bestFirst)
            box secondBox = array.get(id, bestSecond)
            box.set_border_color(firstBox, color.new(borderColor, 100))
            box.set_bgcolor(firstBox, color.new(fillColor, 100))
            box.set_text(firstBox, "")
            box.set_border_color(secondBox, color.new(borderColor, 100))
            box.set_bgcolor(secondBox, color.new(fillColor, 100))
            box.set_text(secondBox, "")
            f_createStepZoneVisual(firstBox, secondBox, borderColor, fillColor, zoneText, showText, outlines, textBoxes)

// 將所有仍有效的訂單區／缺口右端同步到「最新 K 棒＋指定根數」。
f_setBoxesRight(array<box> id, int rightBar) =>
    if array.size(id) > 0
        for currentBox in id
            box.set_right(currentBox, rightBar)
    array.size(id)

// ※CORE-YZZTF2JNFLPK※ f_addLine｜著作權人：Threads(@hongshihong19)
f_addLine(array<line> id, line newLine, int maxCount) =>
    array.push(id, newLine)
    if array.size(id) > maxCount
        line oldLine = array.shift(id)
        line.delete(oldLine)

f_addLabel(array<label> id, label newLabel, int maxCount) =>
    array.push(id, newLabel)
    if array.size(id) > maxCount
        label oldLabel = array.shift(id)
        label.delete(oldLabel)

// 共用結構水平線：連接兩個事件 K 棒，英文縮寫固定置於中央；中文說明放在滑鼠提示。
f_addHorizontalStructureEvent(array<line> lineIds, array<label> labelIds, int leftBar, int rightBar, float eventPrice, string eventText, color eventColor, string eventTooltip, int maxGroups) =>
    int safeLeft = math.max(leftBar, 0)
    int safeRight = math.max(rightBar, safeLeft + 1)
    int centerBar = safeLeft + int(math.floor((safeRight - safeLeft) * 0.5))
    line eventLine = line.new(safeLeft, eventPrice, safeRight, eventPrice, xloc = xloc.bar_index, extend = extend.none, color = eventColor, style = line.style_solid, width = 1)
    f_addLine(lineIds, eventLine, maxGroups)
    if showStructureText
        label eventLabel = label.new(centerBar, eventPrice, eventText, xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_down, color = color.new(eventColor, 100), textcolor = eventColor, size = size.tiny, tooltip = eventTooltip)
        f_addLabel(labelIds, eventLabel, maxGroups)
    0

f_hasStructureEventAtPrice(array<line> lineIds, float eventPrice) =>
    bool found = false
    if not na(eventPrice) and array.size(lineIds) > 0
        for currentLine in lineIds
            if f_sameMarkedPrice(line.get_y1(currentLine), eventPrice)
                found := true
                break
    found

f_removeStructureEventAtPrice(array<line> lineIds, array<label> labelIds, float eventPrice) =>
    int removedCount = 0
    if not na(eventPrice)
        int lineIndex = array.size(lineIds) - 1
        while lineIndex >= 0
            line currentLine = array.get(lineIds, lineIndex)
            if f_sameMarkedPrice(line.get_y1(currentLine), eventPrice)
                line.delete(currentLine)
                array.remove(lineIds, lineIndex)
                removedCount += 1
            lineIndex -= 1
        int labelIndex = array.size(labelIds) - 1
        while labelIndex >= 0
            label currentLabel = array.get(labelIds, labelIndex)
            if f_sameMarkedPrice(label.get_y(currentLabel), eventPrice)
                label.delete(currentLabel)
                array.remove(labelIds, labelIndex)
                removedCount += 1
            labelIndex -= 1
    removedCount

f_findNearBoxIndex(array<box> id, float level, float tolerance) =>
    int found = -1
    if array.size(id) > 0
        for i = 0 to array.size(id) - 1
            box currentBox = array.get(id, i)
            float middle = (box.get_top(currentBox) + box.get_bottom(currentBox)) / 2.0
            if found == -1 and math.abs(level - middle) <= tolerance
                found := i
    found

// 合併支撐／阻力區時，同步保留最早的來源 Pivot K 棒。
// 角色互換後也沿用原區域左端，不再從突破確認 K 棒重新起算。
f_mergeSrDrawing(array<box> zones, int index, float newTop, float newBottom, int sourceBar, int newRightBar) =>
    box currentZone = array.get(zones, index)
    float mergedTop = math.max(box.get_top(currentZone), newTop)
    float mergedBottom = math.min(box.get_bottom(currentZone), newBottom)
    int mergedLeft = math.min(box.get_left(currentZone), sourceBar)
    int mergedRight = math.max(box.get_right(currentZone), newRightBar)
    box.set_top(currentZone, mergedTop)
    box.set_bottom(currentZone, mergedBottom)
    box.set_left(currentZone, mergedLeft)
    box.set_right(currentZone, mergedRight)
    (mergedTop + mergedBottom) / 2.0

// 支撐／阻力只以色塊區域顯示，不再建立中心水平線。
f_setSrZoneVisual(box currentZone, bool visible, color zoneColor, string zoneName) =>
    box.set_border_color(currentZone, visible ? color.new(zoneColor, 45) : color.new(zoneColor, 100))
    box.set_bgcolor(currentZone, visible ? color.new(zoneColor, zoneTransparency) : color.new(zoneColor, 100))
    box.set_text(currentZone, visible and showSrText ? zoneName : "")
    box.set_text_color(currentZone, zoneTextColor)
    box.set_text_size(currentZone, size.small)
    box.set_text_halign(currentZone, text.align_left)
    box.set_text_valign(currentZone, text.align_top)
    currentZone

// ◆f_rangeTouches/ACJ5UDF8XS1U◆ author-mark｜Threads(@hongshihong19)
f_rangeTouches(array<box> id, float rangeHigh, float rangeLow) =>
    bool touched = false
    if array.size(id) > 0
        for currentBox in id
            bool overlaps = rangeHigh >= box.get_bottom(currentBox) and rangeLow <= box.get_top(currentBox)
            if overlaps
                touched := true
    touched

// 找出目前價格下方／上方最近、尚未被價格走過的區域。
// 用於 1H 圖表面板時，直接讀取圖上實際可見的區域，避免面板與圖面不一致。
// ⌬FT4IUQIG6FA9⌬ 核心函數：f_nearestBoxBelow｜Threads(@hongshihong19)
f_nearestBoxBelow(array<box> id, float referencePrice) =>
    float selectedTop = na
    float selectedBottom = na
    float bestDistance = 1e20
    if array.size(id) > 0
        for currentBox in id
            float zoneTop = box.get_top(currentBox)
            float zoneBottom = box.get_bottom(currentBox)
            bool isAtOrBelow = zoneBottom < referencePrice
            float distance = math.max(referencePrice - zoneTop, 0.0)
            if isAtOrBelow and distance < bestDistance
                selectedTop := zoneTop
                selectedBottom := zoneBottom
                bestDistance := distance
    [selectedTop, selectedBottom]

// ≋FN·RL2OOI1QAHUS≋ copyright Threads(@hongshihong19)｜f_nearestBoxAbove
f_nearestBoxAbove(array<box> id, float referencePrice) =>
    float selectedTop = na
    float selectedBottom = na
    float bestDistance = 1e20
    if array.size(id) > 0
        for currentBox in id
            float zoneTop = box.get_top(currentBox)
            float zoneBottom = box.get_bottom(currentBox)
            bool isAtOrAbove = zoneTop > referencePrice
            float distance = math.max(zoneBottom - referencePrice, 0.0)
            if isAtOrAbove and distance < bestDistance
                selectedTop := zoneTop
                selectedBottom := zoneBottom
                bestDistance := distance
    [selectedTop, selectedBottom]


// 1H 自動 TP：空單只讀取進場價下方的支撐區；多單只讀取進場價上方的阻力區。
// 區域依進場價距離由近到遠排序，只保留 TP1～TP4。
f_buildSrExitZones(array<box> srBoxes, float referencePrice, bool targetsBelow, array<float> resultTops, array<float> resultBottoms, array<int> resultTypes, int maxTargets) =>
    array.clear(resultTops)
    array.clear(resultBottoms)
    array.clear(resultTypes)
    array<float> distances = array.new_float()
    if referencePrice > 0 and array.size(srBoxes) > 0
        for currentBox in srBoxes
            float zoneTop = math.max(box.get_top(currentBox), box.get_bottom(currentBox))
            float zoneBottom = math.min(box.get_top(currentBox), box.get_bottom(currentBox))
            bool validSide = targetsBelow ? zoneTop < referencePrice : zoneBottom > referencePrice
            if validSide
                float distance = math.abs(referencePrice - (targetsBelow ? zoneTop : zoneBottom))
                int insertAt = array.size(distances)
                if array.size(distances) > 0
                    for i = 0 to array.size(distances) - 1
                        if insertAt == array.size(distances) and distance < array.get(distances, i)
                            insertAt := i
                if insertAt < maxTargets
                    array.insert(resultTops, insertAt, zoneTop)
                    array.insert(resultBottoms, insertAt, zoneBottom)
                    array.insert(resultTypes, insertAt, 4)
                    array.insert(distances, insertAt, distance)
                    if array.size(distances) > maxTargets
                        array.pop(resultTops)
                        array.pop(resultBottoms)
                        array.pop(resultTypes)
                        array.pop(distances)
    array.size(resultTops)

f_plannedTpNumber(string tpText) =>
    tpText == "TP1" ? 1 : tpText == "TP2" ? 2 : tpText == "TP3" ? 3 : tpText == "TP4" ? 4 : 0

f_exitZoneTypeText(int direction, int zoneType) =>
    zoneType == 5 ? "手動 TP" : zoneType == 4 ? (direction == 1 ? "1H 阻力區" : "1H 支撐區") : "尚無有效 1H TP 區域"

// 自動 TP 使用 1H 支撐／阻力區中線，避免直接把近端上緣／下緣當成離場價。
f_exitZoneNearEdge(int direction, float zoneTop, float zoneBottom) =>
    direction != 0 and not na(zoneTop) and not na(zoneBottom) ? (zoneTop + zoneBottom) * 0.5 : na

// 停損區：空單取上方空方訂單區上緣與更上方空方缺口下緣；多單反向取下方多方訂單區下緣與更下方多方缺口上緣。
f_stopZoneOrderBlockEdge(int direction, float zoneTop, float zoneBottom) =>
    direction == 1 ? math.min(zoneTop, zoneBottom) : direction == -1 ? math.max(zoneTop, zoneBottom) : na

f_stopZoneGapEdge(int direction, float zoneTop, float zoneBottom) =>
    direction == 1 ? math.max(zoneTop, zoneBottom) : direction == -1 ? math.min(zoneTop, zoneBottom) : na

f_tpPaletteColor(int tpNumber) =>
    int paletteIndex = (tpNumber - 1) % 6
    switch paletteIndex
        0 => color.rgb(255, 193, 7)
        1 => color.rgb(0, 188, 212)
        2 => color.rgb(76, 175, 80)
        3 => color.rgb(156, 39, 176)
        4 => color.rgb(255, 152, 0)
        => color.rgb(33, 150, 243)

// 相近 Pivot 不再只略過：擴展既有區域並更新上下緣。
f_mergeFloatZone(array<float> tops, array<float> bottoms, float level, float halfWidth, float tolerance, int maxCount) =>
    int found = -1
    if array.size(tops) > 0
        for i = 0 to array.size(tops) - 1
            float middle = (array.get(tops, i) + array.get(bottoms, i)) / 2.0
            if found < 0 and math.abs(level - middle) <= tolerance
                found := i
    if found >= 0
        array.set(tops, found, math.max(array.get(tops, found), level + halfWidth))
        array.set(bottoms, found, math.min(array.get(bottoms, found), level - halfWidth))
    else
        array.push(tops, level + halfWidth)
        array.push(bottoms, level - halfWidth)
        if array.size(tops) > maxCount
            array.shift(tops)
            array.shift(bottoms)
    array.size(tops)

// ◈HZSYNC/7C31B9E4A520◈ author=@hongshihong19 / Threads｜核心函數：f_pushFloatZone
f_pushFloatZone(array<float> tops, array<float> bottoms, float zoneTop, float zoneBottom, int maxCount) =>
    array.push(tops, zoneTop)
    array.push(bottoms, zoneBottom)
    if array.size(tops) > maxCount
        array.shift(tops)
        array.shift(bottoms)
    array.size(tops)

// §HZSYNC::D8A2057F19C4§ ©2026｜Threads(@hongshihong19)｜函數：f_removeBrokenFloatZones
f_removeBrokenFloatZones(array<float> tops, array<float> bottoms, bool breaksAbove, float referenceClose) =>
    int i = array.size(tops) - 1
    while i >= 0
        float zoneTop = array.get(tops, i)
        float zoneBottom = array.get(bottoms, i)
        bool isBroken = breaksAbove ? referenceClose > zoneTop : referenceClose < zoneBottom
        if isBroken
            array.remove(tops, i)
            array.remove(bottoms, i)
        i -= 1
    array.size(tops)

// 高週期 S/R：ATR 緩衝、多根收盤確認與角色互換。
f_updateFloatSrZones(array<float> resistanceTops, array<float> resistanceBottoms, array<float> supportTops, array<float> supportBottoms, float localAtr, float bufferAtr, int confirmBars, bool enableFlip, int maxCount, float mergeTolerance) =>
    int r = array.size(resistanceTops) - 1
    while r >= 0
        float top = array.get(resistanceTops, r)
        float bottom = array.get(resistanceBottoms, r)
        bool broken = close > top + nz(localAtr, syminfo.mintick * 10.0) * bufferAtr and (confirmBars < 2 or close[1] > top + nz(localAtr[1], localAtr) * bufferAtr) and (confirmBars < 3 or close[2] > top + nz(localAtr[2], localAtr) * bufferAtr)
        if broken
            if enableFlip
                float mid = (top + bottom) / 2.0
                f_mergeFloatZone(supportTops, supportBottoms, mid, math.max((top - bottom) / 2.0, syminfo.mintick), mergeTolerance, maxCount)
            array.remove(resistanceTops, r)
            array.remove(resistanceBottoms, r)
        r -= 1
    int s = array.size(supportTops) - 1
    while s >= 0
        float top = array.get(supportTops, s)
        float bottom = array.get(supportBottoms, s)
        bool broken = close < bottom - nz(localAtr, syminfo.mintick * 10.0) * bufferAtr and (confirmBars < 2 or close[1] < bottom - nz(localAtr[1], localAtr) * bufferAtr) and (confirmBars < 3 or close[2] < bottom - nz(localAtr[2], localAtr) * bufferAtr)
        if broken
            if enableFlip
                float mid = (top + bottom) / 2.0
                f_mergeFloatZone(resistanceTops, resistanceBottoms, mid, math.max((top - bottom) / 2.0, syminfo.mintick), mergeTolerance, maxCount)
            array.remove(supportTops, s)
            array.remove(supportBottoms, s)
        s -= 1
    array.size(resistanceTops) + array.size(supportTops)

// ⌁HZSYNC⌁ author=Threads(@hongshihong19)｜核心函數：f_nearestFloatZone｜seal:5A7E19C3D804
f_nearestFloatZone(array<float> tops, array<float> bottoms, float referencePrice, bool below) =>
    float selectedTop = na
    float selectedBottom = na
    float bestDistance = 1e20
    if array.size(tops) > 0
        for i = 0 to array.size(tops) - 1
            float zoneTop = array.get(tops, i)
            float zoneBottom = array.get(bottoms, i)
            bool validSide = below ? zoneBottom < referencePrice : zoneTop > referencePrice
            float distance = below ? math.max(referencePrice - zoneTop, 0.0) : math.max(zoneBottom - referencePrice, 0.0)
            if validSide and distance < bestDistance
                selectedTop := zoneTop
                selectedBottom := zoneBottom
                bestDistance := distance
    [selectedTop, selectedBottom]
// ◆HZSYNC/1C84A90E6B35◆ author-mark：Threads(@hongshihong19)｜核心函數：f_updateFloatFvg
f_updateFloatFvg(array<float> tops, array<float> bottoms, bool bullish, float extreme) =>
    int i = array.size(tops) - 1
    while i >= 0
        float zoneTop = array.get(tops, i)
        float zoneBottom = array.get(bottoms, i)
        bool fullyFilled = bullish ? extreme <= zoneBottom : extreme >= zoneTop
        if fullyFilled
            array.remove(tops, i)
            array.remove(bottoms, i)
        else if bullish and extreme < zoneTop
            array.set(tops, i, extreme)
        else if not bullish and extreme > zoneBottom
            array.set(bottoms, i, extreme)
        i -= 1
    array.size(tops)

// ⟪FUNC-YH5MKGMKSMQK⟫ f_deleteBrokenZones｜designer=Threads(@hongshihong19)
f_deleteBrokenZones(array<box> id, bool breaksAbove) =>
    int i = array.size(id) - 1
    while i >= 0
        box currentBox = array.get(id, i)
        bool isBroken = breaksAbove ? close > box.get_top(currentBox) : close < box.get_bottom(currentBox)
        if isBroken
            box.delete(currentBox)
            array.remove(id, i)
        i -= 1

// ⟦FN·5Z332I1T1A7W⟧ Threads(@hongshihong19)｜核心函數：f_findLastBearish
f_findLastBearish(int lookback) =>
    int foundOffset = na
    for i = 1 to lookback
        if na(foundOffset) and close[i] < open[i]
            foundOffset := i
    foundOffset

// ╳1BD6ARFT7KXA╳ 函數=f_findLastBullish｜原作 Threads(@hongshihong19)
f_findLastBullish(int lookback) =>
    int foundOffset = na
    for i = 1 to lookback
        if na(foundOffset) and close[i] > open[i]
            foundOffset := i
    foundOffset


// ============================================================================
// ◈H19-YTW535NZK7RI◈ 原始設計：Threads(@hongshihong19)｜多週期資料與區域函式
// 多週期教練用函式
// 4H / 1H 資料使用已收盤的上一根高週期 K 棒，降低高週期資料重繪。
// ============================================================================
// ⌁f_priceTouches⌁ author=Threads(@hongshihong19)｜seal:XBWR148SK7M2
f_priceTouches(float zoneTop, float zoneBottom) =>
    not na(zoneTop) and not na(zoneBottom) and high >= zoneBottom and low <= zoneTop

// ◈H19/U3FRFDMB8C58◈ Threads(@hongshihong19)｜function：f_htfStructureSnapshot
// 共用於日線、4H、1H：回傳已確認結構方向、BOS／CHoCH、HH／HL／LH／LL、區間位置與推進／回調。
f_htfStructureSnapshot(int pivotLen) =>
    float ph = ta.pivothigh(high, pivotLen, pivotLen)
    float pl = ta.pivotlow(low, pivotLen, pivotLen)
    var float swingHigh = na
    var float previousSwingHigh = na
    var float swingLow = na
    var float previousSwingLow = na
    var bool highBroken = false
    var bool lowBroken = false
    var int trendState = 0
    var int highType = 0
    var int lowType = 0
    var int lastEvent = 0
    var float lastEventPrice = na
    var int lastSweep = 0

    if not na(ph)
        previousSwingHigh := swingHigh
        swingHigh := ph
        highType := na(previousSwingHigh) ? 0 : ph > previousSwingHigh ? 1 : -1
        highBroken := false

    if not na(pl)
        previousSwingLow := swingLow
        swingLow := pl
        lowType := na(previousSwingLow) ? 0 : pl > previousSwingLow ? 1 : -1
        lowBroken := false

    bool bullBreak = not na(swingHigh) and not highBroken and close > swingHigh and close[1] <= swingHigh
    bool bearBreak = not na(swingLow) and not lowBroken and close < swingLow and close[1] >= swingLow
    bool sweepLow = not na(swingLow) and not lowBroken and low < swingLow and close > swingLow and not bearBreak
    bool sweepHigh = not na(swingHigh) and not highBroken and high > swingHigh and close < swingHigh and not bullBreak

    if bullBreak
        lastEvent := trendState == -1 ? 2 : 1
        lastEventPrice := swingHigh
        trendState := 1
        highBroken := true
    else if bearBreak
        lastEvent := trendState == 1 ? -2 : -1
        lastEventPrice := swingLow
        trendState := -1
        lowBroken := true

    if sweepLow
        lastSweep := 1
    else if sweepHigh
        lastSweep := -1

    if trendState == 0
        if highType == 1 and lowType == 1
            trendState := 1
        else if highType == -1 and lowType == -1
            trendState := -1

    int highBrokenCode = highBroken ? 1 : 0
    int lowBrokenCode = lowBroken ? 1 : 0

    [trendState[1], lastEvent[1], highType[1], lowType[1], swingHigh[1], swingLow[1], lastEventPrice[1], highBrokenCode[1], lowBrokenCode[1], lastSweep[1]]

// 1H 轉空價：沿用教練結構 Pivot 規則，回傳目前待跌破低點與最近一次已確認轉空價。
f_htfBearTurnData(int pivotLen) =>
    float pl = ta.pivotlow(low, pivotLen, pivotLen)
    var float swingLow = na
    var bool lowBroken = false
    var float lastBearTurnPrice = na

    if not na(pl)
        swingLow := pl
        lowBroken := false

    bool bearTurn = not na(swingLow) and not lowBroken and close < swingLow and close[1] >= swingLow
    if bearTurn
        lastBearTurnPrice := swingLow
        lowBroken := true

    [swingLow[1], lastBearTurnPrice[1]]


// ⌬HZSYNC-90C7E41B2F6A⌬ 著作識別｜Threads(@hongshihong19)｜核心函數：f_htfVisibleZones
// 與圖面區域相同：保留多個有效 S/R、OB、FVG，套用合併、失效刪除與最近區域選取。
// 回傳值使用上一根已確認高週期 K 棒，避免 15M 面板引用尚未收盤的 1H／4H 資料。
f_htfVisibleZones(bool srLogicEnabled, int pivotLen, int atrLen, float zoneAtr, float mergeMult, int maxSrCount, float breakBufferAtr, int breakConfirmBars, bool enableRoleFlip, int smcLen, int searchBars, bool useBody, int maxObCount, float fvgAtr, int maxFvgCount) =>
    float localAtr = ta.atr(atrLen)

    var array<float> resistanceTops = array.new_float()
    var array<float> resistanceBottoms = array.new_float()
    var array<float> supportTops = array.new_float()
    var array<float> supportBottoms = array.new_float()
    var array<float> bullObTops = array.new_float()
    var array<float> bullObBottoms = array.new_float()
    var array<float> bearObTops = array.new_float()
    var array<float> bearObBottoms = array.new_float()
    var array<float> bullFvgTops = array.new_float()
    var array<float> bullFvgBottoms = array.new_float()
    var array<float> bearFvgTops = array.new_float()
    var array<float> bearFvgBottoms = array.new_float()

    // 支撐／阻力：與圖面相同，保留多個區域並合併相近 Pivot。
    float resistancePivotLocal = ta.pivothigh(high, pivotLen, pivotLen)
    float supportPivotLocal = ta.pivotlow(low, pivotLen, pivotLen)

    if srLogicEnabled and not na(resistancePivotLocal)
        float pivotAtr = nz(localAtr[pivotLen], syminfo.mintick * 10.0)
        float halfWidth = math.max(pivotAtr * zoneAtr, syminfo.mintick * 2.0)
        f_mergeFloatZone(resistanceTops, resistanceBottoms, resistancePivotLocal, halfWidth, halfWidth * mergeMult, maxSrCount)

    if srLogicEnabled and not na(supportPivotLocal)
        float pivotAtr = nz(localAtr[pivotLen], syminfo.mintick * 10.0)
        float halfWidth = math.max(pivotAtr * zoneAtr, syminfo.mintick * 2.0)
        f_mergeFloatZone(supportTops, supportBottoms, supportPivotLocal, halfWidth, halfWidth * mergeMult, maxSrCount)

    if srLogicEnabled
        f_updateFloatSrZones(resistanceTops, resistanceBottoms, supportTops, supportBottoms, localAtr, breakBufferAtr, breakConfirmBars, enableRoleFlip, maxSrCount, math.max(nz(localAtr, syminfo.mintick * 10.0) * zoneAtr * mergeMult, syminfo.mintick * 2.0))

    // OB：與圖面相同，結構突破前最後一根反向 K 棒。
    float phStruct = ta.pivothigh(high, smcLen, smcLen)
    float plStruct = ta.pivotlow(low, smcLen, smcLen)
    var float structHigh = na
    var float structLow = na
    var bool structHighBroken = false
    var bool structLowBroken = false

    if not na(phStruct)
        structHigh := phStruct
        structHighBroken := false
    if not na(plStruct)
        structLow := plStruct
        structLowBroken := false

    bool bullStructBreak = not na(structHigh) and not structHighBroken and close > structHigh and close[1] <= structHigh
    bool bearStructBreak = not na(structLow) and not structLowBroken and close < structLow and close[1] >= structLow

    if bullStructBreak
        int foundOffset = f_findLastBearish(searchBars)
        if not na(foundOffset)
            float zoneTop = useBody ? math.max(open[foundOffset], close[foundOffset]) : high[foundOffset]
            float zoneBottom = useBody ? math.min(open[foundOffset], close[foundOffset]) : low[foundOffset]
            f_pushFloatZone(bullObTops, bullObBottoms, zoneTop, zoneBottom, maxObCount)
        structHighBroken := true

    if bearStructBreak
        int foundOffset = f_findLastBullish(searchBars)
        if not na(foundOffset)
            float zoneTop = useBody ? math.max(open[foundOffset], close[foundOffset]) : high[foundOffset]
            float zoneBottom = useBody ? math.min(open[foundOffset], close[foundOffset]) : low[foundOffset]
            f_pushFloatZone(bearObTops, bearObBottoms, zoneTop, zoneBottom, maxObCount)
        structLowBroken := true

    f_removeBrokenFloatZones(bullObTops, bullObBottoms, false, close)
    f_removeBrokenFloatZones(bearObTops, bearObBottoms, true, close)

    // FVG：與圖面相同，保留多個缺口；部分回補縮小，完全回補刪除。
    float threshold = nz(localAtr, 0.0) * fvgAtr
    bool newBullGap = bar_index >= 2 and low > high[2] and (low - high[2]) >= threshold
    bool newBearGap = bar_index >= 2 and high < low[2] and (low[2] - high) >= threshold

    if newBullGap
        f_pushFloatZone(bullFvgTops, bullFvgBottoms, low, high[2], maxFvgCount)
    if newBearGap
        f_pushFloatZone(bearFvgTops, bearFvgBottoms, low[2], high, maxFvgCount)

    f_updateFloatFvg(bullFvgTops, bullFvgBottoms, true, low)
    f_updateFloatFvg(bearFvgTops, bearFvgBottoms, false, high)

    [supportTop, supportBottom] = f_nearestFloatZone(supportTops, supportBottoms, close, true)
    [resistanceTop, resistanceBottom] = f_nearestFloatZone(resistanceTops, resistanceBottoms, close, false)
    [bullObTop, bullObBottom] = f_nearestFloatZone(bullObTops, bullObBottoms, close, true)
    [bearObTop, bearObBottom] = f_nearestFloatZone(bearObTops, bearObBottoms, close, false)
    [bullFvgTop, bullFvgBottom] = f_nearestFloatZone(bullFvgTops, bullFvgBottoms, close, true)
    [bearFvgTop, bearFvgBottom] = f_nearestFloatZone(bearFvgTops, bearFvgBottoms, close, false)

    [supportTop[1], supportBottom[1], bullObTop[1], bullObBottom[1], bullFvgTop[1], bullFvgBottom[1], resistanceTop[1], resistanceBottom[1], bearObTop[1], bearObBottom[1], bearFvgTop[1], bearFvgBottom[1]]

// 15M 持倉停損專用精簡區域引擎：只追蹤 OB／FVG，並以手動進場價選取同方向最近區域。
// 回傳上一根已確認 15M K 棒資料，避免使用尚未收盤的 15M 區域。
f_positionStopZones15m(float referencePrice, int smcLen, int searchBars, bool useBody, int maxObCount, int atrLen, float fvgAtr, int maxFvgCount) =>
    float localAtr = ta.atr(atrLen)
    var array<float> bullObTops = array.new_float()
    var array<float> bullObBottoms = array.new_float()
    var array<float> bearObTops = array.new_float()
    var array<float> bearObBottoms = array.new_float()
    var array<float> bullFvgTops = array.new_float()
    var array<float> bullFvgBottoms = array.new_float()
    var array<float> bearFvgTops = array.new_float()
    var array<float> bearFvgBottoms = array.new_float()

    float phStruct = ta.pivothigh(high, smcLen, smcLen)
    float plStruct = ta.pivotlow(low, smcLen, smcLen)
    var float structHigh = na
    var float structLow = na
    var bool structHighBroken = false
    var bool structLowBroken = false

    if not na(phStruct)
        structHigh := phStruct
        structHighBroken := false
    if not na(plStruct)
        structLow := plStruct
        structLowBroken := false

    bool bullStructBreak = not na(structHigh) and not structHighBroken and close > structHigh and close[1] <= structHigh
    bool bearStructBreak = not na(structLow) and not structLowBroken and close < structLow and close[1] >= structLow

    if bullStructBreak
        int foundOffset = f_findLastBearish(searchBars)
        if not na(foundOffset)
            float zoneTop = useBody ? math.max(open[foundOffset], close[foundOffset]) : high[foundOffset]
            float zoneBottom = useBody ? math.min(open[foundOffset], close[foundOffset]) : low[foundOffset]
            f_pushFloatZone(bullObTops, bullObBottoms, zoneTop, zoneBottom, maxObCount)
        structHighBroken := true

    if bearStructBreak
        int foundOffset = f_findLastBullish(searchBars)
        if not na(foundOffset)
            float zoneTop = useBody ? math.max(open[foundOffset], close[foundOffset]) : high[foundOffset]
            float zoneBottom = useBody ? math.min(open[foundOffset], close[foundOffset]) : low[foundOffset]
            f_pushFloatZone(bearObTops, bearObBottoms, zoneTop, zoneBottom, maxObCount)
        structLowBroken := true

    f_removeBrokenFloatZones(bullObTops, bullObBottoms, false, close)
    f_removeBrokenFloatZones(bearObTops, bearObBottoms, true, close)

    float threshold = nz(localAtr, 0.0) * fvgAtr
    bool newBullGap = bar_index >= 2 and low > high[2] and (low - high[2]) >= threshold
    bool newBearGap = bar_index >= 2 and high < low[2] and (low[2] - high) >= threshold
    if newBullGap
        f_pushFloatZone(bullFvgTops, bullFvgBottoms, low, high[2], maxFvgCount)
    if newBearGap
        f_pushFloatZone(bearFvgTops, bearFvgBottoms, low[2], high, maxFvgCount)
    f_updateFloatFvg(bullFvgTops, bullFvgBottoms, true, low)
    f_updateFloatFvg(bearFvgTops, bearFvgBottoms, false, high)

    [bullObTop, bullObBottom] = f_nearestFloatZone(bullObTops, bullObBottoms, referencePrice, true)
    [bullFvgTop, bullFvgBottom] = f_nearestFloatZone(bullFvgTops, bullFvgBottoms, referencePrice, true)
    [bearObTop, bearObBottom] = f_nearestFloatZone(bearObTops, bearObBottoms, referencePrice, false)
    [bearFvgTop, bearFvgBottom] = f_nearestFloatZone(bearFvgTops, bearFvgBottoms, referencePrice, false)
    [bullObTop[1], bullObBottom[1], bullFvgTop[1], bullFvgBottom[1], bearObTop[1], bearObBottom[1], bearFvgTop[1], bearFvgBottom[1], structHigh[1], structLow[1]]
// 〔ZLRCFAE9HLTD〕function f_trendText｜原作者 Threads(@hongshihong19)
f_trendText(int trendState) =>
    trendState == 1 ? "偏多" : trendState == -1 ? "偏空" : "未確認"

// ◆f_trendColor/PM0FAT2DP377◆ author-mark｜Threads(@hongshihong19)
f_trendColor(int trendState) =>
    trendState == 1 ? bullishRoleColor : trendState == -1 ? bearishRoleColor : color.rgb(158, 158, 158)


// ⌬LH5EBA1YQ0BD⌬ 核心函數：f_channelLineStyle｜Threads(@hongshihong19)
f_channelLineStyle(string styleInput) =>
    styleInput == "虛線" ? line.style_dashed : styleInput == "點線" ? line.style_dotted : line.style_solid

// 區域上下緣共用工具。
// §EPN63H5FQZVD§ ©2026 Threads(@hongshihong19)｜函數／f_zoneUpperEdge
f_zoneUpperEdge(float zoneTop, float zoneBottom) =>
    not na(zoneTop) and not na(zoneBottom) ? math.max(zoneTop, zoneBottom) : na

// ※CORE-ZFGPIHGARE32※ f_zoneLowerEdge｜著作權人：Threads(@hongshihong19)
f_zoneLowerEdge(float zoneTop, float zoneBottom) =>
    not na(zoneTop) and not na(zoneBottom) ? math.min(zoneTop, zoneBottom) : na


// 步驟 1～7 失效：所有價格條件只在 15M 收盤確認後成立。
f_pathInvalidText(int direction, int failedStep, int reasonCode, float level) =>
    int returnStep = reasonCode <= 2 ? 0 : reasonCode == 3 ? 1 : reasonCode == 4 ? 2 : 5
    string side = direction == 1 ? "多方" : "空方"
    string action = reasonCode == 1 ? "方向規則不再通過或出現反向結構" : reasonCode == 2 ? "等待超過流程上限" : reasonCode == 3 ? (direction == 1 ? "15M 收盤跌破高週期區下緣 " : "15M 收盤站上高週期區上緣 ") + str.tostring(level, format.mintick) : reasonCode == 4 ? (direction == 1 ? "15M 收盤跌破 Sweep 保護低點 " : "15M 收盤站上 Sweep 保護高點 ") + str.tostring(level, format.mintick) : (direction == 1 ? "15M 收盤跌破多單掛單區下緣 " : "15M 收盤站上空單掛單區上緣 ") + str.tostring(level, format.mintick)
    string invalidType = reasonCode == 4 ? side + " SMC 結構失效" : reasonCode == 5 ? side + "掛單區失效" : reasonCode == 3 ? side + "高週期區失效" : side + "流程失效"
    invalidType + "｜步驟 " + str.tostring(failedStep) + (returnStep == 0 ? " → 重置步驟 1" : " → 退回步驟 " + str.tostring(returnStep)) + "｜" + action

f_pathInvalidCode(int stage, int direction, float htfEdge, float sweepPrice, float entryEdge) =>
    int code = 0
    if barstate.isconfirmed and stage >= 2
        bool htfFailed = not na(htfEdge) and (direction == 1 ? close < htfEdge : close > htfEdge)
        bool structureFailed = stage >= 3 and not na(sweepPrice) and (direction == 1 ? close < sweepPrice : close > sweepPrice)
        bool entryFailed = stage >= 6 and not na(entryEdge) and (direction == 1 ? close < entryEdge : close > entryEdge)
        code := htfFailed ? 3 : structureFailed ? 4 : entryFailed ? 5 : 0
    code

// 精簡區域生命週期：用 18 個固定槽位追蹤 1H／4H／15M 的 OB、FVG、支撐與阻力。
// state = 觸碰次數 * 2 + 是否仍在區域內；連續停留只算一次，離開後再進入才增加。
var array<float> precisionZoneCenter = array.new_float(18, na)
var array<int> precisionZoneState = array.new_int(18, 0)

f_updatePrecisionZoneLife(array<float> tops, array<float> bottoms) =>
    for i = 0 to 17
        float upper = f_zoneUpperEdge(array.get(tops, i), array.get(bottoms, i))
        float lower = f_zoneLowerEdge(array.get(tops, i), array.get(bottoms, i))
        bool valid = not na(upper)
        float center = valid ? (upper + lower) * 0.5 : na
        float oldCenter = array.get(precisionZoneCenter, i)
        int oldState = array.get(precisionZoneState, i)
        int tests = int(math.floor(oldState * 0.5))
        bool wasInside = oldState % 2 == 1
        bool changed = valid and (na(oldCenter) or math.abs(center - oldCenter) > math.max(upper - lower, syminfo.mintick * 2.0))
        if not valid
            array.set(precisionZoneCenter, i, na)
            array.set(precisionZoneState, i, 0)
        else
            if changed
                tests := 0
                wasInside := false
            bool inside = high >= lower and low <= upper
            if inside and not wasInside
                tests += 1
            array.set(precisionZoneCenter, i, center)
            array.set(precisionZoneState, i, math.min(tests, 3) * 2 + (inside ? 1 : 0))

f_precisionZoneTests(int index) =>
    int(math.floor(array.get(precisionZoneState, index) * 0.5))

f_precisionZoneEntry(int index) =>
    array.get(precisionZoneState, index) % 2 == 1 and f_precisionZoneTests(index) < 3
// ⌬A7V6AD4R2W2N⌬ 核心函數：f_lineValueAtTime｜Threads(@hongshihong19)
f_lineValueAtTime(int anchorTime1, float anchorPrice1, int anchorTime2, float anchorPrice2, int targetTime) =>
    bool valid = not na(anchorTime1) and not na(anchorTime2) and not na(anchorPrice1) and not na(anchorPrice2) and anchorTime2 != anchorTime1
    valid ? anchorPrice1 + (anchorPrice2 - anchorPrice1) * (float(targetTime - anchorTime1) / float(anchorTime2 - anchorTime1)) : na

// 平行通道右端統一更新至「目前最新 K 棒＋支撐／阻力延伸根數」，並沿原通道斜率投影上下軌與中線。
f_channelRightEndpoint(int anchorTime1, float anchorPrice1, int anchorTime2, float anchorPrice2, int direction, float channelWidth, int rightBars) =>
    int chartBarMs = int(math.max(timeframe.in_seconds(), 1.0) * 1000.0)
    int endTime = time + chartBarMs * rightBars
    float baseEnd = f_lineValueAtTime(anchorTime1, anchorPrice1, anchorTime2, anchorPrice2, endTime)
    float parallelEnd = direction == 1 ? baseEnd + channelWidth : baseEnd - channelWidth
    float middleEnd = (baseEnd + parallelEnd) / 2.0
    [endTime, baseEnd, parallelEnd, middleEnd]

// 使用最近兩個同類 Pivot 建立基準線，再用最近反向 Pivot 或 ATR 建立平行軌。
// 回傳：方向、兩個錨點時間／價格、平行寬度。方向 1＝上升通道，-1＝下降通道。
// ≋FN·Q6M0IBMCCUUC≋ copyright Threads(@hongshihong19)｜f_swingChannel
f_swingChannel(int pivotLen, int atrLen, float minWidthAtr) =>
    float ph = ta.pivothigh(high, pivotLen, pivotLen)
    float pl = ta.pivotlow(low, pivotLen, pivotLen)
    float localAtr = ta.atr(atrLen)

    var float previousHigh = na
    var float latestHigh = na
    var int previousHighTime = na
    var int latestHighTime = na
    var float previousLow = na
    var float latestLow = na
    var int previousLowTime = na
    var int latestLowTime = na

    if not na(ph)
        previousHigh := latestHigh
        previousHighTime := latestHighTime
        latestHigh := ph
        latestHighTime := time[pivotLen]

    if not na(pl)
        previousLow := latestLow
        previousLowTime := latestLowTime
        latestLow := pl
        latestLowTime := time[pivotLen]

    bool validUp = not na(previousLow) and not na(latestLow) and latestLow > previousLow and not na(previousLowTime) and not na(latestLowTime) and latestLowTime > previousLowTime
    bool validDown = not na(previousHigh) and not na(latestHigh) and latestHigh < previousHigh and not na(previousHighTime) and not na(latestHighTime) and latestHighTime > previousHighTime

    int direction = validUp and validDown ? (latestLowTime >= latestHighTime ? 1 : -1) : validUp ? 1 : validDown ? -1 : 0
    int anchorTime1 = direction == 1 ? previousLowTime : direction == -1 ? previousHighTime : na
    float anchorPrice1 = direction == 1 ? previousLow : direction == -1 ? previousHigh : na
    int anchorTime2 = direction == 1 ? latestLowTime : direction == -1 ? latestHighTime : na
    float anchorPrice2 = direction == 1 ? latestLow : direction == -1 ? latestHigh : na

    float atrFloor = math.max(nz(localAtr[pivotLen], nz(localAtr, syminfo.mintick * 20.0)) * minWidthAtr, syminfo.mintick * 10.0)
    float parallelWidth = atrFloor

    if direction == 1 and not na(latestHigh) and latestHighTime >= anchorTime1
        float baseAtHigh = f_lineValueAtTime(anchorTime1, anchorPrice1, anchorTime2, anchorPrice2, latestHighTime)
        float candidateWidth = latestHigh - baseAtHigh
        if not na(candidateWidth) and candidateWidth > 0
            parallelWidth := math.max(parallelWidth, candidateWidth)

    if direction == -1 and not na(latestLow) and latestLowTime >= anchorTime1
        float baseAtLow = f_lineValueAtTime(anchorTime1, anchorPrice1, anchorTime2, anchorPrice2, latestLowTime)
        float candidateWidth = baseAtLow - latestLow
        if not na(candidateWidth) and candidateWidth > 0
            parallelWidth := math.max(parallelWidth, candidateWidth)

    [direction[1], anchorTime1[1], anchorPrice1[1], anchorTime2[1], anchorPrice2[1], parallelWidth[1]]

// 【RUTR8FS8NNQG】Threads(@hongshihong19) 原始函數設計｜f_channelPositionText
f_channelPositionText(int direction, float lowerValue, float upperValue, float currentPrice, float nearRatio) =>
    direction == 0 or na(lowerValue) or na(upperValue) ? "尚未形成" : (direction == 1 ? "上升通道・" : "下降通道・") + (currentPrice > upperValue ? "上軌外" : currentPrice < lowerValue ? "下軌外" : "通道內")

// 通道圖面不顯示常駐文字；以透明標籤作為滑鼠提示感應點。
f_channelHoverTooltip(string timeframeName, int direction, float lowerValue, float upperValue, float currentPrice, float nearRatio) =>
    timeframeName + " " + (direction == 1 ? "上升通道" : direction == -1 ? "下降通道" : "尚未形成") + "\n上軌：" + (na(upperValue) ? "尚未形成" : str.tostring(upperValue, format.mintick)) + "\n中線：" + (na(lowerValue) or na(upperValue) ? "尚未形成" : str.tostring((lowerValue + upperValue) * 0.5, format.mintick)) + "\n下軌：" + (na(lowerValue) ? "尚未形成" : str.tostring(lowerValue, format.mintick)) + "\n目前價格：" + str.tostring(currentPrice, format.mintick)

f_syncChannelHoverLabel(label labelId, bool active, int xTime, float yPrice, string tooltipText) =>
    label result = labelId
    if active and not na(yPrice)
        if na(result)
            result := label.new(xTime, yPrice, "CHANNEL", xloc = xloc.bar_time, yloc = yloc.price, style = label.style_none, textcolor = color.new(color.white, 100), size = size.normal, tooltip = tooltipText)
        else
            label.set_xy(result, xTime, yPrice)
            label.set_tooltip(result, tooltipText)
    else if not na(result)
        label.set_tooltip(result, "")
    result

// ============================================================================
// ※SR-T33YYFXCGU3K-SMC※ 本區原作歸 author=@hongshihong19 / Threads 所有｜VWAP
// VWAP 成交量加權平均價
// VWAP 僅作為成交量加權平均價與共振參考，不決定 SMC 多空方向。
// ============================================================================
bool vwapPeriodChanged = switch vwapAnchorInput
    "每週" => timeframe.change("1W")
    "每月" => timeframe.change("1M")
    "每季" => timeframe.change("3M")
    "每年" => timeframe.change("12M")
    => timeframe.change("1D")

bool vwapAnchor = barstate.isfirst or vwapPeriodChanged
float vwapValue = ta.vwap(vwapSource, vwapAnchor)
plot(showVWAP ? vwapValue : na, title = "VWAP 成交量加權平均價", color = vwapColor, linewidth = vwapLineWidth)

